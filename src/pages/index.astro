---
import BaseLayout from '../layouts/BaseLayout.astro';
import MetricsBar from '../components/sections/MetricsBar.astro';
import SecuritySection from '../components/sections/SecuritySection.astro';
import TestimonialsCarousel from '../components/sections/TestimonialsCarousel.astro';
import CtaSection from '../components/sections/CtaSection.astro';
import ShiftCard from '../components/cards/ShiftCard.astro';
import GlowCard from '../components/cards/GlowCard.astro';
import { ArrowRight, Monitor, Activity, Route, FileText, Wrench, BarChart3, LayoutDashboard } from 'lucide-astro';
import SectionHeader from '../components/ui/SectionHeader.astro';
import WhatsAppIcon from '../assets/icons/social/WhatsAppIcon.astro';
import TelegramIcon from '../assets/icons/social/TelegramIcon.astro';
import LineIcon from '../assets/icons/social/LineIcon.astro';
import MessengerIcon from '../assets/icons/social/MessengerIcon.astro';
import ViberIcon from '../assets/icons/social/ViberIcon.astro';
import OpenAIIcon from '../assets/icons/brands/OpenAIIcon.astro';
import ClaudeIcon from '../assets/icons/brands/ClaudeIcon.astro';
import GeminiIcon from '../assets/icons/brands/GeminiIcon.astro';
import LlamaIcon from '../assets/icons/brands/LlamaIcon.astro';
import BedrockIcon from '../assets/icons/brands/BedrockIcon.astro';
import AWSIcon from '../assets/icons/brands/AWSIcon.astro';
import GoogleCloudIcon from '../assets/icons/brands/GoogleCloudIcon.astro';
import AzureIcon from '../assets/icons/brands/AzureIcon.astro';
import SalesforceIcon from '../assets/icons/brands/SalesforceIcon.astro';
import HubSpotIcon from '../assets/icons/brands/HubSpotIcon.astro';
import ZendeskIcon from '../assets/icons/brands/ZendeskIcon.astro';
import RestAPIIcon from '../assets/icons/brands/RestAPIIcon.astro';
import { pillarsData, channelsData, integrationGroupsData, homeStructuredData } from '../data/home';
import { icons, type IconName } from '../assets/icons/svgs';
import { getEntry } from 'astro:content';

const cms = await getEntry('indexPage', 'index');
if (!cms) throw new Error('Missing indexPage/index content entry');

const {
  heroBadgePlatform, heroHeadingPart1, heroHeadingAccent, heroHeadingPart2,
  heroSubtext, heroCtaText,
  shiftLabel, shiftHeading, shiftCallout,
  glucoseLabel, glucoseHeading,
  demoHighlightBadge, demoHighlightHeading, demoHighlightBody,
  demoVideoCategory, demoVideoTitle,
  whyLabel, whyHeading,
  platformBadge, platformHeadingLine1, platformHeadingLine2, platformSubtext, channelsLabel,
  securityHeadingLine1, securityHeadingHighlight, securityBody, securityTrustLinkText,
  ctaHeadingPre, ctaHeadingPost, ctaBody,
} = cms.data;

type ShiftCard  = { label: string; title: string; body: string };
type DescBlock  = { heading: string; body: string };
type WhyCard    = { iconName: string; title: string; body: string };
type Metric     = { value: string; label: string };
type SecBadge   = { src: string; alt: string; label: string };
type Testimonial = { quote: string; avatarSrc: string; avatarAlt: string; name: string; role: string };

const shiftCards      = cms.data.shiftCards      as ShiftCard[];
const glucoseDescBlocks = cms.data.glucoseDescBlocks as DescBlock[];
const homeMetrics     = cms.data.metrics         as Metric[];
const securityBadges  = cms.data.securityBadges  as SecBadge[];
const testimonials    = cms.data.testimonials    as Testimonial[];

// Map iconName → iconSVG for GlowCard
const whyCards = (cms.data.whyCards as WhyCard[]).map((c) => ({
  ...c,
  iconSVG: icons[c.iconName as IconName] ?? '',
}));

// Resolve Lucide icon components for pillars (stays in code — iconKey maps to Astro imports)
const pillarIconMap = { Route, FileText, Wrench, BarChart3, LayoutDashboard };
const pillars = pillarsData
  .map((p) => ({ ...p, Icon: pillarIconMap[p.iconKey] }))
  .filter((p) => Boolean(p.Icon));

// Resolve Astro icon components for channels
const channelIconMap = {
  WhatsApp: WhatsAppIcon, Telegram: TelegramIcon, Line: LineIcon,
  Messenger: MessengerIcon, Viber: ViberIcon, Monitor, Activity,
};
const channels = channelsData
  .map((c) => ({ ...c, Icon: channelIconMap[c.iconKey] }))
  .filter((c) => Boolean(c.Icon));

// Resolve Astro icon components for integration groups
const integrationIconMap = {
  OpenAI: OpenAIIcon, Claude: ClaudeIcon, Gemini: GeminiIcon, Llama: LlamaIcon,
  Bedrock: BedrockIcon, AWS: AWSIcon, GoogleCloud: GoogleCloudIcon, Azure: AzureIcon,
  Salesforce: SalesforceIcon, HubSpot: HubSpotIcon, Zendesk: ZendeskIcon, RestAPI: RestAPIIcon,
};
const integrationGroups = integrationGroupsData.map((group) => ({
  ...group,
  items: group.items.map((item) => ({ ...item, Icon: integrationIconMap[item.iconKey] })),
}));
---

<BaseLayout
  title="5.Y | AI Experience Agents for Brand & Product Experiences"
  description="GLUCOSE AI Experience Agents deliver autonomous brand and product experiences across every channel. Own your brand representation with enterprise-grade agentic AI."
  keywords="AI experience agents, brand experience AI, product experience AI, agentic AI platform, autonomous customer engagement, GLUCOSE AI, enterprise AI agents, brand representation AI, multi-channel AI"
  canonicalUrl="https://www.five-whys.com/"
  ogTitle="5.Y | AI Experience Agents for Brand & Product Experiences"
  ogDescription="GLUCOSE AI Experience Agents deliver autonomous brand and product experiences across every channel. Enterprise-grade, SOC 2 certified."
  ogImage="https://www.five-whys.com/Images/og-image.png"
  twitterTitle="5.Y | AI Experience Agents for Brand & Product Experiences"
  twitterDescription="GLUCOSE AI Experience Agents deliver autonomous brand and product experiences. Enterprise-grade agentic AI."
  structuredData={homeStructuredData}
  transparentNav={true}
>

  <!-- Hero Section - Full Screen Video -->
  <section class="relative w-full overflow-hidden flex items-center [aspect-ratio:16/9] max-h-[90vh]">
    <div class="absolute top-0 left-0 w-full h-full z-0">
      <video autoplay muted loop playsinline class="w-full h-full object-cover object-center">
        <source src="/Videos/Video Banner.mp4" type="video/mp4" />
      </video>
    </div>
    <div class="relative z-[2] w-full max-w-[1400px] mx-auto px-8 pt-[72px]">
      <div class="max-w-[700px]">
        <h1 class="hero-headline font-display text-[clamp(2.5rem,6vw,4rem)] font-medium leading-[1.1] tracking-[-0.02em] mb-5 text-[#fcfcfc]">
          {heroHeadingPart1} <span class="text-accent">{heroHeadingAccent}</span> {heroHeadingPart2}
        </h1>
        <p class="hero-sub text-[clamp(1rem,1.5vw,1.25rem)] text-white/85 max-w-[600px] mb-8">
          {heroSubtext}
        </p>
        <a href="/product" class="hero-cta-btn inline-flex items-center justify-center py-4 px-8 font-primary text-base font-medium no-underline rounded-pill bg-[#fcfcfc] text-[#000000] border-0 cursor-pointer transition-all hover:-translate-y-0.5 hover:shadow-[0_8px_24px_rgba(0,0,0,0.3)]">{heroCtaText}</a>
      </div>
    </div>
  </section>

  <!-- Metrics Bar -->
  <MetricsBar metrics={homeMetrics} />


  <!-- The Shift - Problem Statement -->
  <section class="py-20 px-8 bg-bg-primary">
    <div class="max-w-[900px] mx-auto text-center">
      <SectionHeader label={shiftLabel} heading={shiftHeading} class="max-w-full mb-10" />
      <div class="shift-cards-grid grid grid-cols-3 max-md:grid-cols-1 gap-8 mt-10 text-left">
        {shiftCards.map((card) => <ShiftCard {...card} />)}
      </div>
      <div class="shift-callout flex items-center justify-center gap-3 mt-10 p-5 px-8 bg-accent-soft border border-[rgba(255,192,0,0.2)] rounded-xl">
        <ArrowRight class="w-5 h-5 text-accent shrink-0" />
        <span class="text-base font-medium text-accent">{shiftCallout}</span>
      </div>
    </div>
  </section>

  <!-- What Is GLUCOSE -->
  <section
    class="py-32 px-8 pt-12 pb-12"
    id="product"
  >
    <div class="max-w-[1200px] mx-auto">
      <SectionHeader label={glucoseLabel} heading={glucoseHeading} centered={true} class="max-w-[900px] mb-12" />
      <div class="glucose-grid grid grid-cols-2 max-[1024px]:grid-cols-1 gap-16 items-center">
        <div class="glucose-desc-col max-w-[520px]">
          <div class="flex flex-col gap-6 mb-6">
            {glucoseDescBlocks.map((block) => (
              <div>
                <h4 class="text-[1.125rem] font-semibold text-text-primary mb-2">{block.heading}</h4>
                <p class="text-base text-text-secondary leading-relaxed">{block.body}</p>
              </div>
            ))}
          </div>
          <a href="/product" class="btn btn-accent">Learn more</a>
        </div>
        <div class="glucose-visual-col what-is-visual relative bg-bg-tertiary rounded-2xl overflow-hidden border border-border-theme [aspect-ratio:4/3]">
          <div class="absolute inset-8 flex flex-col gap-4">
            <div class="flex items-center gap-2">
              <span class="mockup-dot w-2 h-2 rounded-full"></span>
              <span class="mockup-dot w-2 h-2 rounded-full"></span>
              <span class="mockup-dot w-2 h-2 rounded-full"></span>
            </div>
            <div class="flex-1 flex flex-col gap-3 overflow-hidden">
              <div class="chat-message user py-[0.875rem] px-4 rounded-xl text-sm max-w-[80%] animate-messageSlide bg-accent text-bg-primary self-end rounded-br-[4px]">
                How do I activate cruise control?
              </div>
              <div class="chat-message agent py-[0.875rem] px-4 rounded-xl text-sm max-w-[80%] animate-messageSlide bg-bg-secondary border border-border-theme self-start rounded-bl-[4px]">
                I'd be happy to help you with cruise control! On your RAV4,
                the controls are on the right side of your steering wheel.
              </div>
              <div class="chat-message agent py-[0.875rem] px-4 rounded-xl text-sm max-w-[80%] animate-messageSlide bg-bg-secondary border border-border-theme self-start rounded-bl-[4px]">
                First, press the ON/OFF button to activate the system. You'll
                see an indicator on your dashboard.
              </div>
              <div class="chat-message user py-[0.875rem] px-4 rounded-xl text-sm max-w-[80%] animate-messageSlide bg-accent text-bg-primary self-end rounded-br-[4px]">Got it, thanks!</div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Demo Highlight -->
  <section class="py-24 px-8 bg-bg-secondary border-y border-border-theme">
    <div class="max-w-[1200px] mx-auto">
      <div class="demo-highlight-grid grid grid-cols-2 gap-12 items-center">
        <div class="demo-highlight-copy max-w-[560px]">
          <span class="inline-flex items-center gap-2 text-[0.75rem] font-semibold tracking-[0.1em] uppercase text-accent mb-4">
            {demoHighlightBadge}
          </span>
          <h2 class="font-display text-[clamp(2rem,4vw,3rem)] font-medium leading-[1.15] tracking-[-0.02em] text-text-primary mb-4">
            {demoHighlightHeading}
          </h2>
          <p class="text-text-secondary text-[1.05rem] leading-[1.75] mb-8">
            {demoHighlightBody}
          </p>
          <div class="flex flex-wrap gap-3">
            <a href="/demo" class="btn btn-accent inline-flex items-center gap-2">
              Watch More Demos
              <ArrowRight size={16} class="w-4 h-4" />
            </a>
            <a href="/contact" class="inline-flex items-center justify-center py-3.5 px-6 rounded-pill border border-border-theme text-text-primary no-underline font-medium transition-all hover:border-accent hover:text-accent">
              Request Demo
            </a>
          </div>
        </div>

        <a href="/demo" class="demo-highlight-media group relative block rounded-2xl overflow-hidden border border-border-theme bg-bg-tertiary no-underline">
          <video class="w-full h-full object-cover aspect-[16/10]" autoplay muted loop playsinline>
            <source src="/Videos/5.Y GLUCOSE Agentic-AI - Sales Opportunity Signal - Test Drive Booking.mp4" type="video/mp4" />
          </video>
          <div class="absolute inset-0 bg-gradient-to-t from-black/55 via-black/10 to-transparent"></div>
          <div class="absolute left-5 right-5 bottom-5 flex items-end justify-between gap-4">
            <div>
              <p class="text-[0.72rem] font-semibold tracking-[0.1em] uppercase text-accent m-0 mb-1">{demoVideoCategory}</p>
              <p class="text-white text-[1rem] font-semibold leading-tight m-0">{demoVideoTitle}</p>
            </div>
            <span class="w-11 h-11 rounded-full bg-white/90 text-black flex items-center justify-center shrink-0 transition-transform duration-300 group-hover:scale-105">
              <svg viewBox="0 0 24 24" class="w-5 h-5 fill-current" aria-hidden="true"><polygon points="8 6 19 12 8 18 8 6"/></svg>
            </span>
          </div>
        </a>
      </div>
    </div>
  </section>

  <!-- Why It Matters -->
  <section class="py-32 px-8 bg-bg-secondary">
    <div class="max-w-[1200px] mx-auto">
      <SectionHeader label={whyLabel} heading={whyHeading} centered={true} />
      <div class="why-cards-grid grid grid-cols-4 max-md:grid-cols-2 gap-6">
        {whyCards.map((card, i) => (
          <GlowCard iconSVG={card.iconSVG} title={card.title} body={card.body} variant={i % 2 === 0 ? 'gold' : 'teal'} />
        ))}
      </div>
    </div>
  </section>

  <!-- Make AI Your Own Section -->
  <section class="py-32 px-8" id="platform">
    <div class="max-w-[1200px] mx-auto">
      <div class="relative text-center overflow-hidden py-8">
        <!-- Background Glows -->
        <div class="absolute rounded-full pointer-events-none z-0 w-[700px] h-[500px] top-[10%] left-1/2 -translate-x-1/2 opacity-60 bg-[radial-gradient(ellipse,rgba(255,192,0,0.4)_0%,transparent_70%)] blur-[100px]"></div>
        <div class="absolute rounded-full pointer-events-none z-0 w-[500px] h-[400px] top-[40%] left-[5%] opacity-50 bg-[radial-gradient(ellipse,rgba(3,94,123,0.5)_0%,transparent_70%)] blur-[100px]"></div>
        <div class="absolute rounded-full pointer-events-none z-0 w-[500px] h-[400px] top-[50%] right-[5%] opacity-50 bg-[radial-gradient(ellipse,rgba(139,92,246,0.4)_0%,transparent_70%)] blur-[100px]"></div>

        <div class="relative z-[1]">
          <div class="platform-badge-el inline-flex items-center gap-2 bg-bg-secondary border border-accent rounded-[50px] py-[0.625rem] px-6 mb-8">
            <div class="w-[10px] h-[10px] bg-accent rounded-full animate-showcase-pulse"></div>
            <span class="text-[0.85rem] font-semibold text-accent tracking-[0.12em]">{platformBadge}</span>
          </div>

          <h2 class="platform-heading-el font-display font-medium text-text-primary mb-5 leading-[1.1] text-[clamp(2.5rem,6vw,4rem)]">
            {platformHeadingLine1}<br />{platformHeadingLine2}
          </h2>
          <p class="platform-subtext-el text-lg text-text-secondary max-w-[650px] mx-auto mb-12 leading-[1.7]">
            {platformSubtext}
          </p>

          <!-- Channels Flow -->
          <div class="channels-row relative my-12">
            <div class="text-[0.65rem] font-semibold uppercase tracking-[0.1em] text-text-muted mb-3">{channelsLabel}</div>
            <div class="flex justify-center items-center gap-4 flex-wrap mb-6">
              {channels.map(({ Icon, label, props }) => (
                <span class="channel-btn-el inline-flex items-center gap-3 bg-bg-tertiary border border-border-theme rounded-[50px] py-3 px-6 text-base font-semibold text-text-primary cursor-pointer transition-all hover:bg-accent hover:border-accent hover:text-bg-primary"><Icon {...(props as any)} />{label}</span>
              ))}
            </div>
          </div>

          <!-- Voice - GLUCOSE - Chat Layout -->
          <div class="glucose-hero-row flex justify-center items-center gap-8 my-12 px-4">
            <div class="phone-frame-left flex flex-col items-center group transition-transform duration-[0.4s]">
              <div class="phone-frame w-[220px] h-[440px] bg-[#1a1a1a] rounded-[36px] p-3 relative transition-transform duration-[0.4s] group-hover:-translate-y-[10px] shadow-[0_25px_60px_rgba(0,0,0,0.4),inset_0_0_0_2px_#333]">
                <div class="w-full h-full rounded-[26px] overflow-hidden relative">
                  <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[90px] h-[22px] bg-[#1a1a1a] z-[2] rounded-b-2xl"></div>
                  <div class="bg-[#fafafa] text-[#111] flex flex-col items-center h-full box-border pt-9 px-[14px] pb-[14px]">
                    <div class="font-display text-[1.2rem] font-medium tracking-[0.08em] mb-1 text-[#111]">GLUCOSE AI</div>
                    <div class="font-primary text-[0.85rem] text-[#888] mb-4">Listening...</div>
                    <div class="voice-waveform flex items-center justify-center gap-[3px] h-9 mb-4">
                      <span class="block w-[3px] rounded-sm bg-accent animate-waveform"></span><span class="block w-[3px] rounded-sm bg-accent animate-waveform"></span><span class="block w-[3px] rounded-sm bg-accent animate-waveform"></span><span class="block w-[3px] rounded-sm bg-accent animate-waveform"></span
                      ><span class="block w-[3px] rounded-sm bg-accent animate-waveform"></span><span class="block w-[3px] rounded-sm bg-accent animate-waveform"></span><span class="block w-[3px] rounded-sm bg-accent animate-waveform"></span>
                    </div>
                    <div class="w-full flex-1 overflow-hidden font-primary text-[0.7rem] leading-[1.5] text-[#333] text-left">
                      <p>
                        <span class="font-bold text-[#111]">User (voice):</span> My car is
                        making a strange noise when I brake
                      </p>
                      <p>
                        <span class="font-bold text-accent">GLUCOSE AI:</span> I understand
                        you're hearing a noise during braking. Can you
                        describe it — is it a squealing, grinding, or clicking
                        sound?
                      </p>
                      <p>
                        <span class="font-bold text-[#111]">User (voice):</span> It's more
                        like a grinding sound
                      </p>
                      <p>
                        <span class="font-bold text-accent">GLUCOSE AI:</span> Grinding during
                        braking typically indicates worn brake pads. I
                        recommend having this checked soon. Would you like me
                        to book a service appointment?
                      </p>
                    </div>
                  </div>
                </div>
              </div>
              <span class="mt-4 text-sm font-semibold uppercase tracking-[0.1em] text-accent">Voice</span>
            </div>
            <div class="glucose-center-badge flex items-center justify-center py-8 px-12 border-2 border-accent rounded-2xl relative bg-[linear-gradient(135deg,rgba(255,192,0,0.15)_0%,rgba(255,192,0,0.05)_100%)]">
              <h3 class="text-[1.75rem] font-bold text-accent tracking-[0.15em] m-0">
                <span class="font-[family-name:var(--font-display)]">GLUCOSE</span>
              </h3>
            </div>
            <div class="phone-frame-right flex flex-col items-center group transition-transform duration-[0.4s]">
              <div class="phone-frame w-[220px] h-[440px] bg-[#1a1a1a] rounded-[36px] p-3 relative transition-transform duration-[0.4s] group-hover:-translate-y-[10px] shadow-[0_25px_60px_rgba(0,0,0,0.4),inset_0_0_0_2px_#333]">
                <div class="w-full h-full rounded-[26px] overflow-hidden relative">
                  <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[90px] h-[22px] bg-[#1a1a1a] z-[2] rounded-b-2xl"></div>
                  <div class="flex flex-col h-full box-border bg-[linear-gradient(135deg,#0a1628_0%,#0d1f3c_100%)]">
                    <div class="flex items-center gap-[0.4rem] pt-7 px-[10px] pb-2 bg-[rgba(0,0,0,0.3)]">
                      <div class="w-6 h-6 rounded-full bg-accent flex items-center justify-center font-display text-[0.65rem] font-bold text-[#111]">G</div>
                      <div class="font-primary text-[0.8rem] font-bold text-white">GLUCOSE AI</div>
                      <svg class="w-3 h-3 fill-[#25d366]" viewBox="0 0 24 24">
                        <path
                          d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-1 15l-5-5 1.41-1.41L11 14.17l7.59-7.59L20 8l-9 9z"
                        />
                      </svg>
                    </div>
                    <div class="flex-1 p-2 overflow-hidden flex flex-col gap-[5px]">
                      <div class="max-w-[85%] font-primary text-[0.7rem] leading-[1.45] rounded-[10px] py-[6px] px-[10px] self-end text-white bg-[rgba(255,192,0,0.2)] rounded-br-[3px]">
                        I just got my new smartwatch, how do I set it up?
                      </div>
                      <div class="max-w-[85%] font-primary text-[0.7rem] leading-[1.45] rounded-[10px] py-[6px] px-[10px] self-start text-white/90 bg-[rgba(255,255,255,0.1)] rounded-bl-[3px]">
                        Congratulations! I'll guide you through setup. First,
                        make sure your watch is charged to at least 50%.
                      </div>
                      <div class="max-w-[85%] font-primary text-[0.7rem] leading-[1.45] rounded-[10px] py-[6px] px-[10px] self-start text-white/90 bg-[rgba(255,255,255,0.1)] rounded-bl-[3px]">
                        Then download the companion app from the App Store and
                        enable Bluetooth on your phone.
                      </div>
                      <div class="max-w-[85%] font-primary text-[0.7rem] leading-[1.45] rounded-[10px] py-[6px] px-[10px] self-end text-white bg-[rgba(255,192,0,0.2)] rounded-br-[3px]">Done! What's next?</div>
                      <div class="max-w-[85%] font-primary text-[0.7rem] leading-[1.45] rounded-[10px] py-[6px] px-[10px] self-start text-white/90 bg-[rgba(255,255,255,0.1)] rounded-bl-[3px]">
                        <div class="text-[0.625rem] font-bold text-accent mb-0.5">Step 3 of 5</div>
                        Now hold your phone near the watch. You should see a
                        pairing prompt appear...
                      </div>
                    </div>
                  </div>
                </div>
              </div>
              <span class="mt-4 text-sm font-semibold uppercase tracking-[0.1em] text-brand-secondary">Chat</span>
            </div>
          </div>

          <!-- Core Pillars -->
          <div class="showcase-pillars grid grid-cols-5 gap-5 max-w-[900px] my-12 mx-auto">
            {pillars.map(({ Icon, title, desc, rotate }) => (
              <div class="pillar-card-el flex flex-col items-center gap-4 bg-bg-secondary border border-border-theme rounded-[20px] py-7 px-4 transition-all hover:border-accent hover:-translate-y-2 hover:shadow-[0_20px_40px_rgba(0,0,0,0.2)]">
                <div class="showcase-pillar-icon w-14 h-14 bg-accent-soft border border-accent rounded-2xl flex items-center justify-center" style={rotate ? 'transform: rotate(90deg)' : undefined}>
                  <Icon size={24} />
                </div>
                <h4 class="text-base font-semibold text-text-primary m-0">{title}</h4>
                <span class="text-xs text-text-muted text-center leading-[1.4]">{desc}</span>
              </div>
            ))}
          </div>

          <!-- Integrations Row -->
          <div class="integrations-row flex justify-center gap-12 my-12 flex-wrap">
            {integrationGroups.map(({ heading, items }) => (
              <div class="integration-group-el text-center">
                <h5 class="text-[0.7rem] font-semibold uppercase tracking-[0.1em] text-text-muted mb-4">{heading}</h5>
                <div class="flex gap-4 justify-center flex-wrap">
                  {items.map(({ Icon, label }) => (
                    <span class="flex items-center justify-center gap-3 bg-bg-tertiary border border-border-theme rounded-[14px] py-4 px-7 text-base font-bold text-text-primary cursor-pointer transition-all hover:bg-accent hover:border-accent hover:text-bg-primary"><Icon width={16} height={16} />{label}</span>
                  ))}
                </div>
              </div>
            ))}
          </div>

          <a href="/product" class="btn btn-accent inline-flex items-center gap-3 mt-8 text-base group">
            Explore GLUCOSE
            <ArrowRight size={18} class="w-5 h-5 transition-transform group-hover:translate-x-[6px]" />
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Security Section -->
  <SecuritySection
    heading={`${securityHeadingLine1}<br /><span class="highlight">${securityHeadingHighlight}</span>`}
    body={securityBody}
    badges={securityBadges}
    trustLinkHref="https://trust.five-whys.com/"
    trustLinkText={securityTrustLinkText}
  />

  <!-- Testimonials Carousel -->
  <TestimonialsCarousel testimonials={testimonials} />

  <!-- CTA -->
  <CtaSection
    id="demo"
    heading={`${ctaHeadingPre} <span class="highlight">GLUCOSE</span> ${ctaHeadingPost}`}
    body={ctaBody}
    primaryCta={{ text: 'Request Demo', href: '/contact' }}
  />

</BaseLayout>

<script>
  import { gsap } from 'gsap'
  import { ScrollTrigger } from 'gsap/ScrollTrigger'

  gsap.registerPlugin(ScrollTrigger)

  // Tab interaction
  document.querySelectorAll('.tab-button').forEach((button) => {
    button.addEventListener('click', () => {
      document
        .querySelectorAll('.tab-button')
        .forEach((b) => b.classList.remove('active'));
      button.classList.add('active');
    });
  });

  // Navbar scroll effect
  const navbar = document.querySelector('.navbar') as HTMLElement | null;

  function handleNavbarScroll() {
    if (!navbar) return;
    if (window.scrollY > 50) {
      navbar.classList.add('scrolled');
    } else {
      navbar.classList.remove('scrolled');
    }
  }

  window.addEventListener('scroll', handleNavbarScroll);
  handleNavbarScroll();

  // ─── Animations ──────────────────────────────────────────────────────────
  const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  if (!prefersReducedMotion) {
    const ease = 'power3.out';

    // Hero entrance — staggered timeline, no ScrollTrigger (above fold)
    gsap.timeline({ delay: 0.15, defaults: { ease, duration: 0.85 } })
      .from('.hero-headline', { opacity: 0, y: 50 })
      .from('.hero-sub',      { opacity: 0, y: 30, duration: 0.75 }, '-=0.55')
      .from('.hero-cta-btn',  { opacity: 0, y: 20, duration: 0.65 }, '-=0.45');

    // Shift section — cards fade in together (no y stagger to avoid misalignment)
    gsap.from('.shift-cards-grid > *', {
      scrollTrigger: { trigger: '.shift-cards-grid', start: 'top 82%' },
      opacity: 0, y: 16, duration: 0.6, stagger: 0.08, ease,
    });
    gsap.from('.shift-callout', {
      scrollTrigger: { trigger: '.shift-callout', start: 'top 90%' },
      opacity: 0, y: 20, duration: 0.5, ease,
    });

    // What is GLUCOSE — left slides in from left, right from right
    gsap.from('.glucose-desc-col', {
      scrollTrigger: { trigger: '.glucose-grid', start: 'top 80%' },
      opacity: 0, x: -45, duration: 0.8, ease,
    });
    gsap.from('.glucose-visual-col', {
      scrollTrigger: { trigger: '.glucose-grid', start: 'top 80%' },
      opacity: 0, x: 45, duration: 0.8, ease,
    });

    // Why It Matters cards
    gsap.from('.why-cards-grid > *', {
      scrollTrigger: { trigger: '.why-cards-grid', start: 'top 82%' },
      opacity: 0, y: 40, duration: 0.6, stagger: 0.1, ease,
    });

    // Platform badge → heading → subtext
    gsap.timeline({
      scrollTrigger: { trigger: '.platform-badge-el', start: 'top 85%' },
      defaults: { ease, duration: 0.65 },
    })
      .from('.platform-badge-el',   { opacity: 0, y: 20 })
      .from('.platform-heading-el', { opacity: 0, y: 30 }, '-=0.4')
      .from('.platform-subtext-el', { opacity: 0, y: 20, duration: 0.55 }, '-=0.35');

    // Channel buttons stagger
    gsap.from('.channel-btn-el', {
      scrollTrigger: { trigger: '.channels-row', start: 'top 85%' },
      opacity: 0, y: 20, duration: 0.5, stagger: 0.07, ease,
      immediateRender: false,
    });

    // Phone frames slide in from sides, badge scales up
    gsap.from('.phone-frame-left', {
      scrollTrigger: { trigger: '.glucose-hero-row', start: 'top 80%' },
      opacity: 0, x: -60, duration: 0.85, ease,
    });
    gsap.from('.glucose-center-badge', {
      scrollTrigger: { trigger: '.glucose-hero-row', start: 'top 80%' },
      opacity: 0, scale: 0.75, duration: 0.75, delay: 0.2, ease: 'back.out(1.5)',
    });
    gsap.from('.phone-frame-right', {
      scrollTrigger: { trigger: '.glucose-hero-row', start: 'top 80%' },
      opacity: 0, x: 60, duration: 0.85, ease,
    });

    // Core pillars stagger
    gsap.from('.pillar-card-el', {
      scrollTrigger: { trigger: '.showcase-pillars', start: 'top 85%' },
      opacity: 0, y: 30, duration: 0.55, stagger: 0.08, ease,
      immediateRender: false,
    });

    // Integration groups stagger
    gsap.from('.integration-group-el', {
      scrollTrigger: { trigger: '.integrations-row', start: 'top 85%' },
      opacity: 0, y: 25, duration: 0.55, stagger: 0.1, ease,
    });
  }
</script>

