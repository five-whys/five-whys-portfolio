---
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionHeader from '../components/ui/SectionHeader.astro';
import ShiftCard from '../components/cards/ShiftCard.astro';
import GlowCard from '../components/cards/GlowCard.astro';
import DifferentiatorsStack from '../components/sections/DifferentiatorsStack.astro';
import WhatsAppIcon from '../assets/icons/social/WhatsAppIcon.astro';
import TelegramIcon from '../assets/icons/social/TelegramIcon.astro';
import LineIcon from '../assets/icons/social/LineIcon.astro';
import MessengerIcon from '../assets/icons/social/MessengerIcon.astro';
import ViberIcon from '../assets/icons/social/ViberIcon.astro';
import ZaloIcon from '../assets/icons/social/ZaloIcon.astro';
import IntegrationCard from '../components/cards/IntegrationCard.astro';
import ChannelIcon from '../components/cards/ChannelIcon.astro';
import {
  Monitor, Boxes, Globe, Search, Settings, Plus,
  BookOpen, Wrench, BarChart3, FileText, HelpCircle, Edit3, Sparkles,
  LineChart, Bell, Check, X, ArrowRight, ExternalLink,
} from 'lucide-astro';
import { benefits, diffItems, productChannelsData, integrations, techCards, devCards } from '../data/product';

// Resolve icon components for channels
const channelIconMap = {
  WhatsApp: WhatsAppIcon, Telegram: TelegramIcon, Line: LineIcon,
  Messenger: MessengerIcon, Viber: ViberIcon, Zalo: ZaloIcon,
  Monitor, Plus,
};
const channels = productChannelsData.map((c) => ({ ...c, Icon: channelIconMap[c.iconKey] }));

---

<BaseLayout
  title="GLUCOSE Agentic AI Platform - Brand & Product Experiences | 5.Y"
  description="GLUCOSE AI Experience Agents represent your brand across every channel—engaging customers, delivering product experiences, and driving outcomes autonomously."
  canonicalUrl="https://www.five-whys.com/product"
  activeNav="product"
>
  <style>
    /* descendant selectors that cannot be inlined */
    .int-panel-search svg { width: 14px; height: 14px; stroke: currentColor; }
    .int-card-icon svg, .int-card-icon img { width: 100%; height: 100%; }
    .agnostic-logo svg, .agnostic-logo img { width: 100%; height: 100%; object-fit: contain; }

    /* ── Agnostic Cards ───────────────────────────────────────────────────── */
    .agnostic-card {
      position: relative;
      overflow: hidden;
      border-radius: 20px;
      border: 1px solid var(--color-border);
      background: var(--color-bg-tertiary);
      padding: 1.5rem;
      min-height: 160px;
      transition: transform 0.3s ease, border-color 0.3s ease, box-shadow 0.3s ease;
    }
    /* thin gold top-edge line */
    .agnostic-card::before {
      content: '';
      position: absolute;
      top: 0; left: 0; right: 0;
      height: 1px;
      background: linear-gradient(90deg, transparent, rgba(255,192,0,0.75), transparent);
      z-index: 1;
    }
    /* radial glow from top */
    .agnostic-card::after {
      content: '';
      position: absolute;
      inset: 0;
      background: radial-gradient(ellipse 130% 55% at 50% 0%, rgba(255,192,0,0.09) 0%, transparent 65%);
      pointer-events: none;
      z-index: 0;
      transition: opacity 0.3s ease;
    }
    .agnostic-card:hover {
      transform: translateY(-5px);
      border-color: rgba(255,192,0,0.3);
      box-shadow: 0 16px 36px rgba(255,192,0,0.06);
    }
    .agnostic-card:hover::after { opacity: 1.6; }
    /* keep children above pseudo-elements */
    .agnostic-card > * { position: relative; z-index: 1; }

    /* category label — accent pill badge */
    .agnostic-card h4 {
      display: inline-flex;
      align-items: center;
      font-size: 0.6875rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      color: var(--color-accent);
      background: var(--color-accent-soft);
      padding: 0.25rem 0.625rem;
      border-radius: 100px;
      margin-bottom: 1.25rem;
    }

    /* responsive breakpoints for auto-fill grids — cannot be expressed in Tailwind */
    .int-panel-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 1px;
      background: var(--color-border);
    }
    @media (max-width: 768px) {
      .int-panel-grid { grid-template-columns: 1fr 1fr; }
      .comparison-row { grid-template-columns: 1fr; }
    }
    @media (max-width: 480px) {
      .int-panel-grid { grid-template-columns: 1fr; }
    }

  </style>

  <main class="min-h-screen" style="background: var(--color-bg-primary);">
    <!-- Hero -->
    <section style="padding: 5rem 2rem 3rem; text-align: center; background: var(--color-bg-secondary); border-bottom: 1px solid var(--color-border);">
      <h1 style="font-family: var(--font-display); font-size: clamp(2.5rem, 5vw, 4rem); font-weight: 500; letter-spacing: -0.02em; color: var(--color-text-primary); margin-bottom: 1.25rem;">Agentic AI for<br><span style="color: var(--color-accent);">Brand &amp; Product Experiences</span></h1>
      <p style="color: var(--color-text-secondary); font-size: 1.125rem; max-width: 600px; margin: 0 auto; line-height: 1.7;">GLUCOSE AI Experience Agents represent your brand across every channel—engaging customers, delivering product experiences, and driving outcomes autonomously across every touchpoint.</p>
    </section>

    <!-- Why Choose GLUCOSE -->
    <section class="py-16 px-8 bg-bg-secondary">
      <div class="max-w-[1200px] mx-auto">
        <SectionHeader
          label="Why Choose GLUCOSE"
          heading="Own Every Customer Moment"
          subtext="Your customers expect instant, personal, on-brand interactions at every touchpoint. GLUCOSE makes that possible—without scaling headcount, without losing brand control, and without waiting on engineering."
          centered={true}
          class="max-w-[700px] mb-12"
        />
        <div class="grid grid-cols-3 max-md:grid-cols-2 max-sm:grid-cols-1 gap-5">
          {benefits.map((b, i) => (
            <GlowCard iconSVG={b.iconSVG} title={b.title} body={b.body} variant={i % 2 === 0 ? 'gold' : 'teal'} />
          ))}
        </div>
      </div>
    </section>

    <!-- Differentiators - DifferentiatorsStack component -->
    <DifferentiatorsStack
      label="What Sets Us Apart"
      heading="Built Different. By Design."
      subtext="Every capability of GLUCOSE is purpose-built so your brand shows up brilliantly for every customer—across every channel, every moment."
      items={diffItems}
    />

<!-- Seamlessly Integrated -->
<section style="padding: 4rem 2rem; background: var(--color-bg-primary); border-top: 1px solid var(--color-border);" id="connectors">
  <div style="max-width: 1200px; margin: 0 auto;">
    <SectionHeader
      label="Works With Your Systems"
      heading="Seamlessly Integrated"
      subtext="GLUCOSE connects to your existing tools and platforms. Deploy across channels, integrate with enterprise systems, and maintain your current workflows."
      centered={true}
      class="max-w-[540px] mb-12"
    />
    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 4rem; align-items: center; max-width: 1100px; margin: 0 auto;">
      <div style="border-radius: 16px; overflow: hidden; border: 1px solid var(--color-border); box-shadow: 0 20px 60px rgba(0,0,0,0.2);">
        <img src="/Images/Connectors.jpg" alt="GLUCOSE Connectors panel" style="width: 100%; height: auto; display: block;" />
      </div>
      <div style="display: flex; flex-direction: column; gap: 2rem;">
        <div style="display: flex; gap: 1rem; align-items: flex-start;">
          <div style="width: 40px; height: 40px; min-width: 40px; background: var(--color-accent-soft); border-radius: 10px; display: flex; align-items: center; justify-content: center;">
            <Settings size={20} color="var(--color-accent)" />
          </div>
          <div><h3 style="font-size: 1rem; font-weight: 600; color: var(--color-text-primary); margin-bottom: 0.25rem;">One-Click Connectors</h3><p style="font-size: 0.9375rem; color: var(--color-text-secondary); line-height: 1.6;">Connect third-party services to enhance your GLUCOSE environment — from e-commerce platforms to CRMs and messaging channels.</p></div>
        </div>
        <div style="display: flex; gap: 1rem; align-items: flex-start;">
          <div style="width: 40px; height: 40px; min-width: 40px; background: var(--color-accent-soft); border-radius: 10px; display: flex; align-items: center; justify-content: center;">
            <Boxes size={20} color="var(--color-accent)" />
          </div>
          <div><h3 style="font-size: 1rem; font-weight: 600; color: var(--color-text-primary); margin-bottom: 0.25rem;">Categorized by Function</h3><p style="font-size: 0.9375rem; color: var(--color-text-secondary); line-height: 1.6;">Browse connectors by type — Portfolio, Corpus, Tools, Users, Analytics, and Channels — to find exactly what you need.</p></div>
        </div>
        <div style="display: flex; gap: 1rem; align-items: flex-start;">
          <div style="width: 40px; height: 40px; min-width: 40px; background: var(--color-accent-soft); border-radius: 10px; display: flex; align-items: center; justify-content: center;">
            <Check size={20} color="var(--color-accent)" />
          </div>
          <div><h3 style="font-size: 1rem; font-weight: 600; color: var(--color-text-primary); margin-bottom: 0.25rem;">Real-Time Status</h3><p style="font-size: 0.9375rem; color: var(--color-text-secondary); line-height: 1.6;">See which connectors are active, pending configuration, or available to connect — all from a single management panel.</p></div>
        </div>
        <div style="display: flex; gap: 1rem; align-items: flex-start;">
          <div style="width: 40px; height: 40px; min-width: 40px; background: var(--color-accent-soft); border-radius: 10px; display: flex; align-items: center; justify-content: center;">
            <ArrowRight size={20} color="var(--color-accent)" />
          </div>
          <div><h3 style="font-size: 1rem; font-weight: 600; color: var(--color-text-primary); margin-bottom: 0.25rem;">Request New Connectors</h3><p style="font-size: 0.9375rem; color: var(--color-text-secondary); line-height: 1.6;">Need an integration we don't have yet? Request new connectors directly from the panel and our team will build it.</p></div>
        </div>
      </div>
    </div>
  </div>
</section>

    <!-- Journey Analytics -->
    <section style="padding: 4rem 2rem; background: var(--color-bg-secondary); border-top: 1px solid var(--color-border);" id="analytics">
      <div style="max-width: 1200px; margin: 0 auto;">
        <SectionHeader
          label="Insights"
          heading="Journey Analytics"
          subtext="Understand how your AI agents perform, uncover customer patterns, and optimize every interaction with real-time analytics and reporting."
          centered={true}
          class="max-w-[540px] mb-12"
        />
        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 4rem; align-items: center; max-width: 1100px; margin: 0 auto;">
          <div style="border-radius: 16px; overflow: hidden; border: 1px solid var(--color-border); box-shadow: 0 20px 60px rgba(0,0,0,0.2);">
            <img src="/Images/Analytics.jpg" alt="GLUCOSE Journey Analytics dashboard" style="width: 100%; height: auto; display: block;" />
          </div>
          <div style="display: flex; flex-direction: column; gap: 2rem;">
            <div style="display: flex; gap: 1rem; align-items: flex-start;">
              <div style="width: 40px; height: 40px; min-width: 40px; background: var(--color-accent-soft); border-radius: 10px; display: flex; align-items: center; justify-content: center;">
                <LineChart size={20} color="var(--color-accent)" />
              </div>
              <div><h3 style="font-size: 1rem; font-weight: 600; color: var(--color-text-primary); margin-bottom: 0.25rem;">Key Metrics</h3><p style="font-size: 0.9375rem; color: var(--color-text-secondary); line-height: 1.6;">Track agent performance against critical KPIs — session volume, conversation depth, GLUCOSE Score, and customer satisfaction.</p></div>
            </div>
            <div style="display: flex; gap: 1rem; align-items: flex-start;">
              <div style="width: 40px; height: 40px; min-width: 40px; background: var(--color-accent-soft); border-radius: 10px; display: flex; align-items: center; justify-content: center;">
                <Search size={20} color="var(--color-accent)" />
              </div>
              <div><h3 style="font-size: 1rem; font-weight: 600; color: var(--color-text-primary); margin-bottom: 0.25rem;">Journey Explorer</h3><p style="font-size: 0.9375rem; color: var(--color-text-secondary); line-height: 1.6;">Visualize conversation flows and transition paths to understand how customers navigate through your AI agent experiences.</p></div>
            </div>
            <div style="display: flex; gap: 1rem; align-items: flex-start;">
              <div style="width: 40px; height: 40px; min-width: 40px; background: var(--color-accent-soft); border-radius: 10px; display: flex; align-items: center; justify-content: center;">
                <Edit3 size={20} color="var(--color-accent)" />
              </div>
              <div><h3 style="font-size: 1rem; font-weight: 600; color: var(--color-text-primary); margin-bottom: 0.25rem;">Score Distribution</h3><p style="font-size: 0.9375rem; color: var(--color-text-secondary); line-height: 1.6;">Monitor quality scores across all conversations to identify trends, spot anomalies, and continuously improve agent behavior.</p></div>
            </div>
            <div style="display: flex; gap: 1rem; align-items: flex-start;">
              <div style="width: 40px; height: 40px; min-width: 40px; background: var(--color-accent-soft); border-radius: 10px; display: flex; align-items: center; justify-content: center;">
                <Bell size={20} color="var(--color-accent)" />
              </div>
              <div><h3 style="font-size: 1rem; font-weight: 600; color: var(--color-text-primary); margin-bottom: 0.25rem;">Real-Time Alerts</h3><p style="font-size: 0.9375rem; color: var(--color-text-secondary); line-height: 1.6;">Get notified when agent performance drops below thresholds so you can intervene before it impacts customer experience.</p></div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Technology -->
    <section class="py-16 px-8 bg-bg-secondary border-t border-border-theme" id="technology">
      <div class="max-w-[1200px] mx-auto">
        <SectionHeader
          label="Technology"
          heading="Enterprise-Grade Solution"
          subtext="GLUCOSE runs on enterprise-grade cloud infrastructure—reliable, secure, and fully managed. You focus on experiences, not servers."
          centered={true}
          class="max-w-[540px] mb-8"
        />
        <div class="flex gap-4 flex-wrap justify-center mb-10">
          <span class="inline-flex items-center gap-2 py-2 px-4 bg-accent-soft rounded-pill text-sm font-medium text-accent"><Sparkles size={16} />Model-Agnostic</span>
          <span class="inline-flex items-center gap-2 py-2 px-4 bg-accent-soft rounded-pill text-sm font-medium text-accent"><Monitor size={16} />Multi-Modal</span>
          <span class="inline-flex items-center gap-2 py-2 px-4 bg-accent-soft rounded-pill text-sm font-medium text-accent"><Boxes size={16} />Single-Tenant</span>
          <span class="inline-flex items-center gap-2 py-2 px-4 bg-accent-soft rounded-pill text-sm font-medium text-accent"><Globe size={16} />Technology-Agnostic</span>
        </div>
        <div class="grid grid-cols-4 max-md:grid-cols-2 gap-5">
          {techCards.map((c, i) => (
            <GlowCard iconSVG={c.iconSVG} title={c.title} body={c.body} variant={i % 2 === 0 ? 'gold' : 'teal'} />
          ))}
        </div>
      </div>
    </section>

    {/* <!-- Integrations (commented out) -->
    <section style="padding: 4rem 2rem; background: var(--color-bg-primary); border-top: 1px solid var(--color-border);" id="integrations">
      <div style="max-width: 1200px; margin: 0 auto;">
        <SectionHeader
          label="Works With Your Systems"
          heading="Seamlessly Integrated"
          subtext="GLUCOSE connects to your existing tools and platforms. Deploy across channels, integrate with enterprise systems, and maintain your current workflows."
          centered={true}
          class="max-w-[540px] mb-8"
        />
        <div class="bg-bg-secondary border border-border-theme rounded-2xl overflow-hidden max-w-[900px] mx-auto mt-8">
          <div class="flex items-center gap-6 px-6 py-4 border-b border-border-theme bg-bg-tertiary flex-wrap">
            <div class="int-panel-title">
              <span class="font-display text-base text-accent font-medium">GLUCOSE</span>
              <span class="text-xs text-text-muted ml-2">Integrations Panel</span>
            </div>
            <div class="text-[0.8125rem] text-text-secondary ml-auto">Active Integrations: <strong>6</strong></div>
            <div class="int-panel-search flex items-center gap-2 px-3 py-2 bg-bg-primary border border-border-theme rounded-[6px] text-[0.8125rem] text-text-muted">
              <Search size={14} />
              Search integrations...
            </div>
          </div>
          <div class="int-panel-grid">
            {integrations.map((integration) => <IntegrationCard {...integration} />)}
          </div>
        </div>
      </div>
    </section> */}


    <!-- Technology Agnostic -->
    <section style="padding: 4rem 2rem; background: var(--color-bg-secondary); border-top: 1px solid var(--color-border);" id="agnostic">
      <div style="max-width: 1200px; margin: 0 auto;">
        <SectionHeader
          label="Technology Agnostic"
          heading="Your Stack. Your Choice."
          subtext="GLUCOSE connects to your channels, enterprise systems, AI models, and cloud providers. No vendor lock-in—your stack, your choice."
          centered={true}
          class="max-w-[540px] mb-8"
        />
        <div class="grid grid-cols-3 max-md:grid-cols-2 max-sm:grid-cols-1 gap-5 mt-8">
          <div class="agnostic-card">
            <h4>AI Models</h4>
            <div class="flex flex-wrap gap-3 items-center">
              <div class="agnostic-logo w-8 h-8 flex items-center justify-center opacity-80 hover:opacity-100 transition-opacity duration-200"><svg viewBox="0 0 16 16" fill="#10A37F"><path d="M14.949 6.547a3.94 3.94 0 0 0-.348-3.273 4.11 4.11 0 0 0-4.4-1.934A4.1 4.1 0 0 0 8.423.2 4.15 4.15 0 0 0 6.305.086a4.1 4.1 0 0 0-1.891.948 4.04 4.04 0 0 0-1.158 1.753 4.1 4.1 0 0 0-1.563.679A4 4 0 0 0 .554 4.72a3.99 3.99 0 0 0 .502 4.731 3.94 3.94 0 0 0 .346 3.274 4.11 4.11 0 0 0 4.402 1.933c.382.425.852.764 1.377.995.526.231 1.095.35 1.67.346 1.78.002 3.358-1.132 3.901-2.804a4.1 4.1 0 0 0 1.563-.68 4 4 0 0 0 1.14-1.253 3.99 3.99 0 0 0-.506-4.716"/></svg></div>
