---
import { getEntry } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionHeader from '../components/ui/SectionHeader.astro';
import ShiftCard from '../components/cards/ShiftCard.astro';
import GlowCard from '../components/cards/GlowCard.astro';
import DifferentiatorsStack from '../components/sections/DifferentiatorsStack.astro';
import WhatsAppIcon from '../assets/icons/social/WhatsAppIcon.astro';
import TelegramIcon from '../assets/icons/social/TelegramIcon.astro';
import LineIcon from '../assets/icons/social/LineIcon.astro';
import MessengerIcon from '../assets/icons/social/MessengerIcon.astro';
import ViberIcon from '../assets/icons/social/ViberIcon.astro';
import ZaloIcon from '../assets/icons/social/ZaloIcon.astro';
import IntegrationCard from '../components/cards/IntegrationCard.astro';
import ChannelIcon from '../components/cards/ChannelIcon.astro';
import {
  Monitor, Boxes, Globe, Search, Settings, Plus,
  BookOpen, Wrench, BarChart3, FileText, HelpCircle, Edit3, Sparkles,
  LineChart, Bell, Check, X, ArrowRight, ExternalLink,
} from 'lucide-astro';
import { benefits, diffItems, productChannelsData, integrations, techCards, devCards, agnosticCards } from '../data/product';

const cmsEntry = await getEntry('productPage', 'index');
if (!cmsEntry) throw new Error('productPage CMS entry not found');
const p = cmsEntry.data;

// Resolve icon components for channels
const channelIconMap = {
  WhatsApp: WhatsAppIcon, Telegram: TelegramIcon, Line: LineIcon,
  Messenger: MessengerIcon, Viber: ViberIcon, Zalo: ZaloIcon,
  Monitor, Plus,
};
const channels = productChannelsData.map((c) => ({ ...c, Icon: channelIconMap[c.iconKey] }));

// Resolve Lucide icon components for CMS feature rows
const featureIconMap: Record<string, any> = { Settings, Boxes, Check, ArrowRight, LineChart, Search, Edit3, Bell };
const connectorRows = p.connectorFeatures.map((f) => ({ ...f, Icon: featureIconMap[f.iconName] }));
const analyticsRows = p.analyticsFeatures.map((f) => ({ ...f, Icon: featureIconMap[f.iconName] }));

---

<BaseLayout
  title="GLUCOSE Agentic AI Platform - Brand & Product Experiences | 5.Y"
  description="GLUCOSE AI Experience Agents represent your brand across every channel—engaging customers, delivering product experiences, and driving outcomes autonomously."
  canonicalUrl="https://www.five-whys.com/product"
  activeNav="product"
>
  <style>
    /* descendant selectors that cannot be inlined */
    .int-panel-search svg { width: 14px; height: 14px; stroke: currentColor; }
    .int-card-icon svg, .int-card-icon img { width: 100%; height: 100%; }
    .agnostic-logo svg, .agnostic-logo img { width: 100%; height: 100%; object-fit: contain; }

    /* ── Agnostic Cards ───────────────────────────────────────────────────── */
    .agnostic-card {
      position: relative;
      overflow: hidden;
      border-radius: 20px;
      border: 1px solid var(--color-border);
      background: var(--color-bg-tertiary);
      padding: 1.5rem;
      min-height: 160px;
      transition: transform 0.3s ease, border-color 0.3s ease, box-shadow 0.3s ease;
    }
    /* thin gold top-edge line */
    .agnostic-card::before {
      content: '';
      position: absolute;
      top: 0; left: 0; right: 0;
      height: 1px;
      background: linear-gradient(90deg, transparent, rgba(255,192,0,0.75), transparent);
      z-index: 1;
    }
    /* radial glow from top */
    .agnostic-card::after {
      content: '';
      position: absolute;
      inset: 0;
      background: radial-gradient(ellipse 130% 55% at 50% 0%, rgba(255,192,0,0.09) 0%, transparent 65%);
      pointer-events: none;
      z-index: 0;
      transition: opacity 0.3s ease;
    }
    .agnostic-card:hover {
      transform: translateY(-5px);
      border-color: rgba(255,192,0,0.3);
      box-shadow: 0 16px 36px rgba(255,192,0,0.06);
    }
    .agnostic-card:hover::after { opacity: 1.6; }
    /* keep children above pseudo-elements */
    .agnostic-card > * { position: relative; z-index: 1; }

    /* category label — accent pill badge */
    .agnostic-card h4 {
      display: inline-flex;
      align-items: center;
      font-size: 0.6875rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      color: var(--color-accent);
      background: var(--color-accent-soft);
      padding: 0.25rem 0.625rem;
      border-radius: 100px;
      margin-bottom: 1.25rem;
    }

    /* responsive breakpoints for auto-fill grids — cannot be expressed in Tailwind */
    .int-panel-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 1px;
      background: var(--color-border);
    }
    @media (max-width: 768px) {
      .int-panel-grid { grid-template-columns: 1fr 1fr; }
      .comparison-row { grid-template-columns: 1fr; }
    }
    @media (max-width: 480px) {
      .int-panel-grid { grid-template-columns: 1fr; }
    }

  </style>

  <main class="min-h-screen bg-bg-primary">
    <!-- Hero -->
    <section class="pt-20 px-8 pb-12 text-center bg-bg-secondary border-b border-border-theme">
      <h1 class="font-[family-name:var(--font-display)] text-[clamp(2.5rem,5vw,4rem)] font-medium tracking-[-0.02em] text-text-primary mb-5">{p.heroHeadingPart1}<br><span class="text-accent">{p.heroHeadingAccent}</span></h1>
      <p class="text-text-secondary text-lg max-w-[600px] mx-auto leading-[1.7]">{p.heroSubtext}</p>
    </section>

    <!-- Why Choose GLUCOSE -->
    <section class="py-16 px-8 bg-bg-secondary">
      <div class="max-w-[1200px] mx-auto">
        <SectionHeader
          label={p.whyLabel}
          heading={p.whyHeading}
          subtext={p.whySubtext}
          centered={true}
          class="max-w-[700px] mb-12"
        />
        <div class="grid grid-cols-3 max-md:grid-cols-2 max-sm:grid-cols-1 gap-5">
          {benefits.map((b, i) => (
            <GlowCard iconSVG={b.iconSVG} title={b.title} body={b.body} variant={i % 2 === 0 ? 'gold' : 'teal'} />
          ))}
        </div>
      </div>
    </section>

    <!-- Differentiators - DifferentiatorsStack component -->
    <DifferentiatorsStack
      label={p.diffLabel}
      heading={p.diffHeading}
      subtext={p.diffSubtext}
      items={diffItems}
    />

<!-- Seamlessly Integrated -->
<section class="py-16 px-8 bg-bg-primary border-t border-border-theme" id="connectors">
  <div class="max-w-[1200px] mx-auto">
    <SectionHeader
      label={p.connectorsLabel}
      heading={p.connectorsHeading}
      subtext={p.connectorsSubtext}
      centered={true}
      class="max-w-[540px] mb-12"
    />
    <div class="grid grid-cols-2 gap-16 items-center max-w-[1100px] mx-auto">
      <div class="rounded-[16px] overflow-hidden border border-border-theme shadow-[0_20px_60px_rgba(0,0,0,0.2)]">
        <img src="/Images/Connectors.jpg" alt="GLUCOSE Connectors panel" class="w-full h-auto block" />
      </div>
      <div class="flex flex-col gap-8">
        {connectorRows.map((f) => (
          <div class="flex gap-4 items-start">
            <div class="w-10 h-10 min-w-[40px] bg-accent-soft rounded-[10px] flex items-center justify-center text-accent">
              <f.Icon size={20} />
            </div>
            <div><h3 class="text-base font-semibold text-text-primary mb-1">{f.title}</h3><p class="text-[0.9375rem] text-text-secondary leading-[1.6]">{f.body}</p></div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

    <!-- Journey Analytics -->
    <section class="py-16 px-8 bg-bg-secondary border-t border-border-theme" id="analytics">
      <div class="max-w-[1200px] mx-auto">
        <SectionHeader
          label={p.analyticsLabel}
          heading={p.analyticsHeading}
          subtext={p.analyticsSubtext}
          centered={true}
          class="max-w-[540px] mb-12"
        />
        <div class="grid grid-cols-2 gap-16 items-center max-w-[1100px] mx-auto">
          <div class="rounded-[16px] overflow-hidden border border-border-theme shadow-[0_20px_60px_rgba(0,0,0,0.2)]">
            <img src="/Images/Analytics.jpg" alt="GLUCOSE Journey Analytics dashboard" class="w-full h-auto block" />
          </div>
          <div class="flex flex-col gap-8">
            {analyticsRows.map((f) => (
              <div class="flex gap-4 items-start">
                <div class="w-10 h-10 min-w-[40px] bg-accent-soft rounded-[10px] flex items-center justify-center text-accent">
                  <f.Icon size={20} />
                </div>
                <div><h3 class="text-base font-semibold text-text-primary mb-1">{f.title}</h3><p class="text-[0.9375rem] text-text-secondary leading-[1.6]">{f.body}</p></div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>

    <!-- Technology -->
    <section class="py-16 px-8 bg-bg-secondary border-t border-border-theme" id="technology">
      <div class="max-w-[1200px] mx-auto">
        <SectionHeader
          label={p.technologyLabel}
          heading={p.technologyHeading}
          subtext={p.technologySubtext}
          centered={true}
          class="max-w-[540px] mb-8"
        />
        <div class="flex gap-4 flex-wrap justify-center mb-10">
          {p.technologyBadges.map((badge) => (
            <span class="inline-flex items-center gap-2 py-2 px-4 bg-accent-soft rounded-pill text-sm font-medium text-accent">{badge}</span>
          ))}
        </div>
        <div class="grid grid-cols-4 max-md:grid-cols-2 gap-5">
          {techCards.map((c, i) => (
            <GlowCard iconSVG={c.iconSVG} title={c.title} body={c.body} variant={i % 2 === 0 ? 'gold' : 'teal'} />
          ))}
        </div>
      </div>
    </section>

    <!-- Technology Agnostic -->
    <section class="py-16 px-8 bg-bg-secondary border-t border-border-theme" id="agnostic">
      <div class="max-w-[1200px] mx-auto">
        <SectionHeader
          label={p.agnosticLabel}
          heading={p.agnosticHeading}
          subtext={p.agnosticSubtext}
          centered={true}
          class="max-w-[540px] mb-8"
        />
        <div class="grid grid-cols-3 max-md:grid-cols-2 max-sm:grid-cols-1 gap-5 mt-8">
          {agnosticCards.map((card) => (
            <div class="agnostic-card">
              <h4>{card.title}</h4>
              <div class="flex flex-wrap gap-3 items-center">
                {card.logos.map((logo) => (
                  logo.href
                    ? <a href={logo.href} target="_blank" rel="noopener noreferrer" class="agnostic-logo w-8 h-8 flex items-center justify-center opacity-80 hover:opacity-100 transition-opacity duration-200" set:html={logo.logoHtml} />
                    : <div class="agnostic-logo w-8 h-8 flex items-center justify-center opacity-80 hover:opacity-100 transition-opacity duration-200" set:html={logo.logoHtml} />
                ))}
              </div>
              {(card as any).trustCenterHref && (
                <a href={(card as any).trustCenterHref} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 text-accent text-sm font-medium no-underline mt-4">View our Trust Center <ExternalLink size={14} /></a>
              )}
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- How It Works -->
    <section class="py-16 px-8 bg-bg-primary border-t border-border-theme" id="platform">
      <div class="max-w-[1200px] mx-auto">
        <p class="text-center text-xs font-semibold uppercase tracking-[0.15em] text-accent mb-10">
          {p.platformLabel}
        </p>

        <!-- Channel Icons Row -->
        <div class="flex flex-wrap gap-6 justify-center mb-8">
          {channels.map(({ name, Icon, props }) => (
            <ChannelIcon name={name}>
              <Icon {...(props as any)} />
            </ChannelIcon>
          ))}
        </div>

        <!-- Connector: Channels → GLUCOSE -->
        <div class="flex flex-col items-center mb-6">
          <div class="w-px h-16 bg-[linear-gradient(to_bottom,rgba(255,192,0,0.5),rgba(255,192,0,0.15))]"></div>
          <svg width="14" height="9" viewBox="0 0 14 9" fill="none"><path d="M1 1L7 7.5L13 1" stroke="rgba(255,192,0,0.75)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </div>

        <!-- GLUCOSE core description -->
        <div class="text-center p-10 bg-bg-secondary border border-border-theme rounded-[16px] max-w-[700px] mx-auto">
          <div class="inline-flex items-center gap-2 px-4 py-[0.375rem] bg-accent-soft rounded-pill text-[0.8125rem] font-semibold text-accent mb-5">
            <span class="w-2 h-2 bg-accent rounded-full inline-block"></span>
            GLUCOSE
          </div>
          <h3 class="font-[family-name:var(--font-display)] text-[1.75rem] font-medium text-text-primary mb-3">{p.glucoseCoreHeading}</h3>
          <p class="text-text-secondary leading-[1.7]">{p.glucoseCoreBody}</p>
        </div>

        <!-- Connector: GLUCOSE → GMC -->
        <div class="flex flex-col items-center mb-6">
          <div class="w-px h-16 bg-[linear-gradient(to_bottom,rgba(255,192,0,0.5),rgba(255,192,0,0.15))]"></div>
          <svg width="14" height="9" viewBox="0 0 14 9" fill="none"><path d="M1 1L7 7.5L13 1" stroke="rgba(255,192,0,0.75)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </div>

        <!-- GMC card -->
        <div class="bg-bg-secondary border border-border-theme rounded-[16px] p-8 max-w-[700px] mx-auto">
          <div class="flex items-center gap-4 mb-4">
            <div class="w-10 h-10 bg-brand-secondary-soft rounded-[10px] flex items-center justify-center text-brand-secondary"><Boxes size={20} /></div>
            <div><h4 class="text-base font-semibold text-text-primary m-0">{p.gmcTitle}</h4><span class="text-[0.8125rem] text-text-muted">{p.gmcSubtitle}</span></div>
          </div>
          <p class="text-text-secondary text-[0.9375rem] leading-[1.7] mb-4">{p.gmcBody}</p>
          <div class="flex flex-wrap gap-2">
            {p.gmcTags.map(tag => (
              <span class="inline-flex items-center py-1 px-3 bg-bg-tertiary rounded-pill text-[0.8125rem] text-text-secondary">{tag}</span>
            ))}
          </div>
        </div>

        <!-- Connector: GMC → Corpus/Tools -->
        <div class="flex flex-col items-center mb-6">
          <div class="w-px h-16 bg-[linear-gradient(to_bottom,rgba(255,192,0,0.5),rgba(255,192,0,0.15))]"></div>
          <svg width="14" height="9" viewBox="0 0 14 9" fill="none"><path d="M1 1L7 7.5L13 1" stroke="rgba(255,192,0,0.75)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </div>

        <!-- Corpus & Tools Row -->
        <div class="grid grid-cols-2 gap-6 max-w-[700px] mx-auto">
          <!-- Corpus -->
          <div class="bg-bg-secondary border border-border-theme rounded-[16px] p-8">
            <div class="flex items-center gap-3 mb-3">
              <div class="w-14 h-14 bg-accent-soft rounded-[14px] flex items-center justify-center shrink-0 text-accent">
                <FileText size={28} />
              </div>
              <div>
                <h4 class="text-[1.1rem] font-semibold text-text-primary m-0">{p.corpusTitle}</h4>
                <span class="text-[0.7rem] text-text-muted uppercase tracking-[0.05em]">{p.corpusSubtitle}</span>
              </div>
            </div>
            <p class="text-[0.9375rem] text-text-secondary leading-[1.6] mb-4">{p.corpusBody}</p>
            <div class="flex flex-wrap gap-[0.625rem]">
              <span class="inline-flex items-center gap-[0.375rem] text-xs bg-bg-tertiary border border-border-theme rounded-pill py-1 px-[0.625rem] text-accent"><FileText size={14} />Manuals</span>
              <span class="inline-flex items-center gap-[0.375rem] text-xs bg-bg-tertiary border border-border-theme rounded-pill py-1 px-[0.625rem] text-accent"><HelpCircle size={14} />FAQs</span>
              <span class="inline-flex items-center gap-[0.375rem] text-xs bg-bg-tertiary border border-border-theme rounded-pill py-1 px-[0.625rem] text-accent"><Boxes size={14} />Products</span>
              <span class="inline-flex items-center gap-[0.375rem] text-xs bg-bg-tertiary border border-border-theme rounded-pill py-1 px-[0.625rem] text-accent"><Edit3 size={14} />Policies</span>
              <span class="inline-flex items-center gap-[0.375rem] text-xs bg-bg-tertiary border border-border-theme rounded-pill py-1 px-[0.625rem] text-accent"><Sparkles size={14} />Marketing</span>
            </div>
          </div>
          <!-- Tools -->
          <div class="bg-bg-secondary border border-border-theme rounded-[16px] p-8">
            <div class="flex items-center gap-3 mb-3">
              <div class="w-14 h-14 bg-accent-soft rounded-[14px] flex items-center justify-center shrink-0 text-accent">
                <Wrench size={28} />
              </div>
              <div>
                <h4 class="text-[1.1rem] font-semibold text-text-primary m-0">{p.toolsTitle}</h4>
                <span class="text-[0.7rem] text-text-muted uppercase tracking-[0.05em]">{p.toolsSubtitle}</span>
              </div>
            </div>
            <p class="text-[0.9375rem] text-text-secondary leading-[1.6] mb-4">{p.toolsBody}</p>
            <div class="flex flex-wrap gap-2">
              <span class="inline-flex items-center gap-[0.375rem] text-[0.65rem] text-text-secondary bg-bg-tertiary border border-border-theme rounded-pill py-1 px-[0.625rem]"><svg viewBox="0 0 273 191" fill="#00A1E0" width="14" height="14"><path d="m113 21.3c8.78-9.14 21-14.8 34.5-14.8 18 0 33.6 10 42 24.9a58 58 0 0 1 23.7-5.05c32.4 0 58.7 26.5 58.7 59.2s-26.3 59.2-58.7 59.2c-3.96 0-7.82-0.398-11.6-1.15-7.35 13.1-21.4 22-37.4 22a42.7 42.7 0 0 1-18.8-4.32c-7.45 17.5-24.8 29.8-45 29.8-21.1 0-39-13.3-45.9-32a45.1 45.1 0 0 1-9.34 0.972c-25.1 0-45.4-20.6-45.4-45.9 0-17 9.14-31.8 22.7-39.8a52.6 52.6 0 0 1-4.35-21c0-29.2 23.7-52.8 52.9-52.8 17.1 0 32.4 8.15 42 20.8"/></svg>Salesforce</span>
              <span class="inline-flex items-center gap-[0.375rem] text-[0.65rem] text-text-secondary bg-bg-tertiary border border-border-theme rounded-pill py-1 px-[0.625rem]"><svg viewBox="0 0 24 24" fill="#FF7A59" width="14" height="14"><path d="M18.164 7.93V5.084a2.2 2.2 0 0 0 1.267-1.978v-.067A2.2 2.2 0 0 0 17.238.845h-.067a2.2 2.2 0 0 0-2.193 2.193v.067a2.2 2.2 0 0 0 1.252 1.973l.013.006v2.852a6.2 6.2 0 0 0-2.969 1.31l.012-.01l-7.828-6.095A2.497 2.497 0 1 0 4.3 4.656l-.012.006l7.697 5.991a6.2 6.2 0 0 0-1.038 3.446a6.2 6.2 0 0 0 1.147 3.607l-.013-.02l-2.342 2.343a2 2 0 0 0-.58-.095h-.002a2.033 2.033 0 1 0 2.033 2.033a2 2 0 0 0-.1-.595l.005.014l2.317-2.317a6.247 6.247 0 1 0 4.782-11.134l-.036-.005zm-.964 9.378a3.206 3.206 0 1 1 3.215-3.207v.002a3.206 3.206 0 0 1-3.207 3.207z"/></svg>HubSpot</span>
              <span class="inline-flex items-center gap-[0.375rem] text-[0.65rem] text-text-secondary bg-bg-tertiary border border-border-theme rounded-pill py-1 px-[0.625rem]"><svg viewBox="0 0 32 32" fill="#0077B5" width="14" height="14"><path d="M0 8.083v15.835h16.172l15.828-15.835zM4.355 11.031h0.005c1.151 0 2.552 0.324 3.567 0.844l-1.093 1.907c-1.115-0.541-1.672-0.588-2.307-0.625-0.943-0.052-1.417 0.287-1.428 0.651-0.005 0.444 0.896 0.844 1.745 1.12 1.281 0.407 2.916 0.953 3.167 2.532l2.349-6.208h2.728l2.751 7.432-0.011-7.432h3.161c3.011 0 4.427 1.020 4.427 3.359 0 2.099-1.452 3.355-3.916 3.355h-1.016l-0.015 2.791-4.781-0.005-0.333-1.213c-0.495 0.167-1.052 0.256-1.641 0.256-0.609 0-1.183-0.095-1.687-0.265l-0.475 1.223-2.667 0.005 0.12-0.615c-0.041 0.037-0.079 0.068-0.12 0.1-0.708 0.572-1.609 0.839-2.713 0.859h-0.287c-1.203 0.016-2.391-0.296-3.437-0.896l0.973-1.932c1.052 0.625 1.715 0.76 2.605 0.745 0.463-0.011 0.796-0.095 1.015-0.319 0.131-0.135 0.204-0.307 0.209-0.495 0.009-0.5-0.709-0.733-1.579-1.005-0.708-0.219-1.516-0.52-2.141-0.984-0.744-0.541-1.104-1.229-1.083-2.197 0.005-0.688 0.276-1.344 0.755-1.833 0.693-0.719 1.808-1.152 3.152-1.152zM18.479 13.255v2.543h0.699c0.921 0 1.661-0.308 1.661-1.287 0-0.948-0.74-1.256-1.661-1.256zM11.697 14.281l-0.995 3.145c0.297 0.115 0.641 0.177 1.005 0.177 0.36 0 0.699-0.063 0.989-0.167l-0.979-3.161z"/></svg>SAP</span>
              <span class="inline-flex items-center gap-[0.375rem] text-[0.65rem] text-text-secondary bg-bg-tertiary border border-border-theme rounded-pill py-1 px-[0.625rem]"><svg viewBox="0 0 24 24" fill="#03363D" width="14" height="14"><path d="M12.914 2.904V16.29L24 2.905zM0 2.906C0 5.966 2.483 8.45 5.543 8.45s5.542-2.484 5.543-5.544zm11.086 4.807L0 21.096h11.086zm7.37 7.84a5.54 5.54 0 0 0-5.542 5.543H24c0-3.06-2.48-5.543-5.543-5.543z"/></svg>Zendesk</span>
              <span class="inline-flex items-center gap-[0.375rem] text-[0.65rem] text-text-secondary bg-bg-tertiary border border-border-theme rounded-pill py-1 px-[0.625rem]"><svg viewBox="0 0 71.1 63.6" fill="#81B5A1" width="14" height="14"><path d="M35.8,0C16.1,0,0,15.9,0,35.6c0,9.8,4,19.3,11.2,26c2.5,2.4,6.4,2.6,9.2,0.5c9-6.7,21.4-6.7,30.4,0c2.8,2.1,6.7,1.9,9.2-0.5C74.3,48,74.9,25.4,61.3,11.1C54.7,4.1,45.4,0.1,35.8,0 M35.6,53.5C26,53.8,18,46.2,17.8,36.7c0-0.3,0-0.6,0-0.9c0-9.8,8-17.8,17.8-17.8s17.8,8,17.8,17.8c0.3,9.6-7.3,17.5-16.8,17.8C36.2,53.5,35.9,53.5,35.6,53.5"/></svg>ServiceNow</span>
              <span class="inline-flex items-center gap-[0.375rem] text-[0.65rem] text-text-secondary bg-bg-tertiary border border-border-theme rounded-pill py-1 px-[0.625rem]"><svg viewBox="0 0 24 24" fill="#002050" width="14" height="14"><path d="M4.59 7.41l4.94 3.54L4.59 24zm0-7.41v6.36l9.53 5.29 4.59-3.52zm0 24l14.82-8.47v-6.7Z"/></svg>Dynamics</span>
              <span class="inline-flex items-center gap-[0.375rem] text-[0.65rem] text-text-secondary bg-bg-tertiary border border-border-theme rounded-pill py-1 px-[0.625rem]"><ExternalLink size={14} />REST API</span>
              <span class="inline-flex items-center gap-[0.375rem] text-[0.65rem] text-text-secondary bg-bg-tertiary border border-border-theme rounded-pill py-1 px-[0.625rem]"><ExternalLink size={14} />Webhooks</span>
            </div>
          </div>
        </div>

        <!-- Connector: Corpus/Tools → Analytics -->
        <div class="flex flex-col items-center mb-6">
          <div class="w-px h-16 bg-[linear-gradient(to_bottom,rgba(255,192,0,0.5),rgba(255,192,0,0.15))]"></div>
          <svg width="14" height="9" viewBox="0 0 14 9" fill="none"><path d="M1 1L7 7.5L13 1" stroke="rgba(255,192,0,0.75)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </div>

        <!-- Analytics -->
        <div class="bg-bg-secondary border border-border-theme rounded-[16px] p-8 max-w-[700px] mx-auto mb-8 text-center">
          <div class="flex items-center justify-center gap-3 mb-3">
            <div class="w-14 h-14 bg-accent-soft rounded-[14px] flex items-center justify-center shrink-0 text-accent">
              <BarChart3 size={28} />
            </div>
            <div class="text-left">
              <h4 class="text-[1.1rem] font-semibold text-text-primary m-0">{p.archAnalyticsTitle}</h4>
              <span class="text-[0.7rem] text-text-muted uppercase tracking-[0.05em]">{p.archAnalyticsSubtitle}</span>
            </div>
          </div>
          <p class="text-[0.9375rem] text-text-secondary leading-[1.6] mb-6">{p.archAnalyticsBody}</p>
          <div class="flex items-start justify-center gap-6">
            <div>
              <div class="text-[0.6rem] uppercase tracking-[0.08em] text-text-muted mb-2">Captures</div>
              <div class="flex flex-col gap-[0.375rem]">
                {p.archAnalyticsCaptures.map(item => (
                  <span class="text-[0.7rem] bg-bg-tertiary border border-border-theme rounded-md py-1 px-[0.625rem] text-text-secondary">{item}</span>
                ))}
              </div>
            </div>
            <div class="flex items-center pt-6 text-accent">
              <ArrowRight size={20} />
            </div>
            <div>
              <div class="text-[0.6rem] uppercase tracking-[0.08em] text-text-muted mb-2">Syncs to</div>
              <div class="flex flex-col gap-[0.375rem]">
                {p.archAnalyticsSyncsTo.map(item => (
                  <span class="text-[0.7rem] bg-bg-tertiary border border-border-theme rounded-md py-1 px-[0.625rem] text-text-secondary">{item}</span>
                ))}
              </div>
            </div>
          </div>
        </div>

        <!-- Comparison -->
        <div class="comparison-row grid grid-cols-2 gap-6 max-w-[800px] mx-auto mt-8">
          <div class="comparison-card p-6 bg-bg-secondary border border-border-theme rounded-xl">
            <div class="text-xs font-semibold uppercase tracking-[0.08em] text-text-muted mb-4">{p.comparisonLegacyLabel}</div>
            <ul class="list-none flex flex-col gap-3">
              {p.traditionalChatbotItems.map((item) => (
                <li class="flex gap-2 text-sm text-text-secondary items-start"><X size={16} class="shrink-0 mt-[2px] text-text-muted" />{item}</li>
              ))}
            </ul>
          </div>
          <div class="comparison-card p-6 bg-accent-soft border border-[rgba(255,192,0,0.3)] rounded-xl">
            <div class="text-xs font-semibold uppercase tracking-[0.08em] text-text-muted mb-4">{p.comparisonGlucoseLabel}</div>
            <ul class="list-none flex flex-col gap-3">
              {p.glucoseAgentItems.map((item) => (
                <li class="flex gap-2 text-sm text-text-primary items-start"><Check size={16} class="shrink-0 mt-[2px] text-accent" />{item}</li>
              ))}
            </ul>
          </div>
        </div>
      </div>
    </section>

    <!-- Developer Resources -->
    <section class="relative py-20 pb-[5.5rem] px-8 bg-bg-primary border-t border-border-theme overflow-hidden" id="developers">
      <!-- radial bg glow -->
      <div class="absolute inset-0 bg-[radial-gradient(ellipse_70%_55%_at_50%_0%,rgba(255,192,0,0.055)_0%,transparent_68%)] pointer-events-none"></div>
      <!-- top accent line -->
      <div class="absolute top-0 left-[10%] right-[10%] h-px bg-[linear-gradient(90deg,transparent,rgba(255,192,0,0.4),transparent)]"></div>

      <div class="max-w-[1100px] mx-auto relative z-[1] text-center">
        <span class="inline-block text-[0.75rem] font-semibold tracking-[0.15em] uppercase text-accent mb-5">{p.devBadge}</span>
        <h2 class="font-[family-name:var(--font-display)] text-[clamp(2rem,4vw,3rem)] font-medium tracking-[-0.02em] text-text-primary leading-[1.2] mb-4">{p.devHeading}</h2>
        <p class="text-text-secondary text-[1.0625rem] max-w-[560px] mx-auto mb-12 leading-[1.75]">{p.devBody}</p>
        <div class="grid grid-cols-3 gap-5 max-w-[880px] mx-auto mb-12">
          {devCards.map((c, i) => (
            <GlowCard iconSVG={c.iconSVG} title={c.title} body={c.body} variant={i % 2 === 0 ? 'gold' : 'teal'} />
          ))}
        </div>
        <a href="/contact" class="inline-flex items-center gap-[0.625rem] py-[0.9375rem] px-9 bg-accent text-black font-semibold text-[0.9375rem] rounded-lg no-underline transition-opacity duration-200">
          {p.devCtaText}
          <ArrowRight size={18} />
        </a>
      </div>
    </section>

    <!-- CTA -->
    <section class="py-20 px-8 text-center bg-bg-primary border-t border-border-theme" id="demo">
      <h2 class="font-[family-name:var(--font-display)] text-[clamp(1.75rem,3vw,2.5rem)] font-medium tracking-[-0.02em] text-text-primary mb-4">{p.ctaHeading}</h2>
      <p class="text-text-secondary text-lg max-w-[560px] mx-auto mb-8 leading-[1.7]">{p.ctaBody}</p>
      <a href="/contact" class="inline-flex items-center gap-2 py-[0.875rem] px-8 bg-accent text-black font-semibold text-[0.9375rem] rounded-lg no-underline">{p.ctaButtonText}</a>
    </section>
  </main>
</BaseLayout>
