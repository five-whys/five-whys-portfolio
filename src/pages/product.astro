        </div>

        <!-- Connector: Corpus/Tools → Analytics -->
        <div style="display: flex; flex-direction: column; align-items: center; margin: 0 0 1.5rem;">
          <div style="width: 1px; height: 64px; background: linear-gradient(to bottom, rgba(255,192,0,0.5), rgba(255,192,0,0.15));"></div>
          <svg width="14" height="9" viewBox="0 0 14 9" fill="none"><path d="M1 1L7 7.5L13 1" stroke="rgba(255,192,0,0.75)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </div>

        <!-- Analytics -->
        <div style="background: var(--color-bg-secondary); border: 1px solid var(--color-border); border-radius: 16px; padding: 2rem; max-width: 700px; margin: 0 auto 2rem; text-align: center;">
          <div style="display: flex; align-items: center; justify-content: center; gap: 0.75rem; margin-bottom: 0.75rem;">
            <div style="width: 56px; height: 56px; background: var(--color-accent-soft); border-radius: 14px; display: flex; align-items: center; justify-content: center; flex-shrink: 0;">
              <BarChart3 size={28} color="var(--color-accent)" />
            </div>
            <div style="text-align: left;">
              <h4 style="font-size: 1.1rem; font-weight: 600; color: var(--color-text-primary); margin: 0;">Analytics</h4>
              <span style="font-size: 0.7rem; color: var(--color-text-muted); text-transform: uppercase; letter-spacing: 0.05em;">Insights &amp; Data Flow</span>
            </div>
          </div>
          <p style="font-size: 0.9375rem; color: var(--color-text-secondary); line-height: 1.6; margin-bottom: 1.5rem;">Customer insights captured and synced back to your systems.</p>
          <div style="display: flex; align-items: flex-start; justify-content: center; gap: 1.5rem;">
            <div>
              <div style="font-size: 0.6rem; text-transform: uppercase; letter-spacing: 0.08em; color: var(--color-text-muted); margin-bottom: 0.5rem;">Captures</div>
              <div style="display: flex; flex-direction: column; gap: 0.375rem;">
                {['User Intent', 'Preferences', 'Feedback', 'Behavior'].map(item => (
                  <span style="font-size: 0.7rem; background: var(--color-bg-tertiary); border: 1px solid var(--color-border); border-radius: 6px; padding: 0.25rem 0.625rem; color: var(--color-text-secondary);">{item}</span>
                ))}
              </div>
            </div>
            <div style="display: flex; align-items: center; padding-top: 1.5rem; color: var(--color-accent);">
              <ArrowRight size={20} />
            </div>
            <div>
              <div style="font-size: 0.6rem; text-transform: uppercase; letter-spacing: 0.08em; color: var(--color-text-muted); margin-bottom: 0.5rem;">Syncs to</div>
              <div style="display: flex; flex-direction: column; gap: 0.375rem;">
                {['CRM', 'Customer Data Platform', 'Data Warehouse', 'Analytics Tools'].map(item => (
                  <span style="font-size: 0.7rem; background: var(--color-bg-tertiary); border: 1px solid var(--color-border); border-radius: 6px; padding: 0.25rem 0.625rem; color: var(--color-text-secondary);">{item}</span>
                ))}
              </div>
            </div>
          </div>
        </div>

        <!-- Comparison -->
        <div class="comparison-row grid grid-cols-2 gap-6 max-w-[800px] mx-auto mt-8">
          <div class="comparison-card p-6 bg-bg-secondary border border-border-theme rounded-xl">
            <div class="text-xs font-semibold uppercase tracking-[0.08em] text-text-muted mb-4">Traditional Chatbots</div>
            <ul class="list-none flex flex-col gap-3">
              <li class="flex gap-2 text-sm text-text-secondary items-start"><X size={16} class="shrink-0 mt-[2px] text-text-muted" />Pre-programmed responses that break when conversations shift</li>
              <li class="flex gap-2 text-sm text-text-secondary items-start"><X size={16} class="shrink-0 mt-[2px] text-text-muted" />Can only provide information, not take action</li>
              <li class="flex gap-2 text-sm text-text-secondary items-start"><X size={16} class="shrink-0 mt-[2px] text-text-muted" />Robotic, template-based responses lacking context</li>
            </ul>
          </div>
          <div class="comparison-card p-6 bg-accent-soft border border-[rgba(255,192,0,0.3)] rounded-xl">
            <div class="text-xs font-semibold uppercase tracking-[0.08em] text-text-muted mb-4">GLUCOSE Agents</div>
            <ul class="list-none flex flex-col gap-3">
              <li class="flex gap-2 text-sm text-text-primary items-start"><Check size={16} class="shrink-0 mt-[2px] text-accent" />Goal-driven reasoning through complexity and edge cases</li>
              <li class="flex gap-2 text-sm text-text-primary items-start"><Check size={16} class="shrink-0 mt-[2px] text-accent" />Executes tasks: books, updates, processes, resolves</li>
              <li class="flex gap-2 text-sm text-text-primary items-start"><Check size={16} class="shrink-0 mt-[2px] text-accent" />Natural dialogue with empathy and brand awareness</li>
            </ul>
          </div>
        </div>
      </div>
    </section>

    <!-- Developer Resources -->
    <section style="position: relative; padding: 5rem 2rem 5.5rem; background: var(--color-bg-primary); border-top: 1px solid var(--color-border); overflow: hidden;" id="developers">
      <!-- radial bg glow -->
      <div style="position: absolute; inset: 0; background: radial-gradient(ellipse 70% 55% at 50% 0%, rgba(255,192,0,0.055) 0%, transparent 68%); pointer-events: none;"></div>
      <!-- top accent line -->
      <div style="position: absolute; top: 0; left: 10%; right: 10%; height: 1px; background: linear-gradient(90deg, transparent, rgba(255,192,0,0.4), transparent);"></div>

      <div style="max-width: 1100px; margin: 0 auto; position: relative; z-index: 1; text-align: center;">
        <!-- label -->
        <span style="display: inline-block; font-size: 0.75rem; font-weight: 600; letter-spacing: 0.15em; text-transform: uppercase; color: var(--color-accent); margin-bottom: 1.25rem;">Build with GLUCOSE</span>

        <!-- heading -->
        <h2 style="font-family: var(--font-display); font-size: clamp(2rem, 4vw, 3rem); font-weight: 500; letter-spacing: -0.02em; color: var(--color-text-primary); line-height: 1.2; margin-bottom: 1rem;">Partner with us</h2>

        <!-- subtext -->
        <p style="color: var(--color-text-secondary); font-size: 1.0625rem; max-width: 560px; margin: 0 auto 3rem; line-height: 1.75;">Build agentic brand representation with brand and product experiences powered by GLUCOSE Agentic AI. Access our architecture documentation, JDL specification, and integration patterns.</p>

        <!-- Resource cards -->
        <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.25rem; max-width: 880px; margin: 0 auto 3rem;">
          {devCards.map((c, i) => (
            <GlowCard iconSVG={c.iconSVG} title={c.title} body={c.body} variant={i % 2 === 0 ? 'gold' : 'teal'} />
          ))}
        </div>

        <!-- CTA -->
        <a href="/contact" style="display: inline-flex; align-items: center; gap: 0.625rem; padding: 0.9375rem 2.25rem; background: var(--color-accent); color: #000; font-weight: 600; font-size: 0.9375rem; border-radius: 8px; text-decoration: none; transition: opacity 0.2s ease;">
          Request Access
          <ArrowRight size={18} />
        </a>
      </div>
    </section>

    <!-- CTA -->
    <section style="padding: 5rem 2rem; text-align: center; background: var(--color-bg-primary); border-top: 1px solid var(--color-border);" id="demo">
      <h2 style="font-family: var(--font-display); font-size: clamp(1.75rem, 3vw, 2.5rem); font-weight: 500; letter-spacing: -0.02em; color: var(--color-text-primary); margin-bottom: 1rem;">See what GLUCOSE can do for you</h2>
      <p style="color: var(--color-text-secondary); font-size: 1.125rem; max-width: 560px; margin: 0 auto 2rem; line-height: 1.7;">Discover how GLUCOSE can help your enterprise run autonomous brand experiences that reach every customer, in every moment that matters.</p>
      <a href="/contact" style="display: inline-flex; align-items: center; gap: 0.5rem; padding: 0.875rem 2rem; background: var(--color-accent); color: #000; font-weight: 600; font-size: 0.9375rem; border-radius: 8px; text-decoration: none;">Request Demo</a>
    </section>
  </main>
</BaseLayout>
