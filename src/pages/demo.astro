---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getEntry } from 'astro:content';

const cms = await getEntry('demoPage', 'demo');
if (!cms) throw new Error('Missing demoPage/demo content entry');

const { heroLabel, heroHeading, heroSubtext, ctaHeading, ctaSubtext } = cms.data;

type FeatureSection = {
  id: string;
  industry: string;
  reversed: boolean;
  label: string;
  heading: string;
  tagline: string;
  body: string;
  linkText: string;
  videoSrc: string;
};

const featureSections = cms.data.featureSections as FeatureSection[];
---

<BaseLayout
  title="GLUCOSE AI Demo - See Agentic AI in Action | 5.Y"
  description="Watch GLUCOSE AI demos showcasing autonomous customer engagement, multi-channel support, and real-time AI conversations on WhatsApp, Telegram, and voice."
  canonicalUrl="https://www.five-whys.com/demo"
  activeNav="demo"
>
  <style>
    /* pseudo-element video overlay */
    .feature-video::before {
      content: '';
      position: absolute;
      inset: 0;
      background: rgba(0,0,0,0);
      transition: background 0.3s ease;
      z-index: 1;
    }
    .feature-video:hover::before {
      background: rgba(0,0,0,0.3);
    }

    /* descendant selectors */
    .feature-video video {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
    }
    .feature-link svg { width: 1rem; height: 1rem; }
    .play-button svg { width: 24px; height: 24px; margin-left: 3px; }
    .video-modal-content video {
      width: 100%;
      height: auto;
      border-radius: 12px;
      display: block;
    }
    .video-modal-close svg { width: 20px; height: 20px; }

    /* JS-toggled state classes */
    .video-modal.active {
      opacity: 1;
      pointer-events: all;
    }
    .video-modal.active .video-modal-content {
      transform: scale(1);
    }
    .feature-section[data-industry].filtered-out {
      display: none;
    }

    /* direction: rtl for reverse layout (not a Tailwind utility) */
    .feature-inner-reverse { direction: rtl; }
    .feature-inner-reverse > * { direction: ltr; }
    @media (max-width: 768px) { .feature-inner-reverse { direction: ltr; } }
  </style>

  <main class="min-h-screen bg-bg-primary">
    <!-- Hero -->
    <section class="pt-20 px-8 pb-12 text-center bg-bg-secondary border-b border-border-theme">
      <span class="inline-block text-[0.75rem] font-semibold tracking-[0.08em] uppercase text-accent mb-4">{heroLabel}</span>
      <h1 class="font-[family-name:var(--font-display)] text-[clamp(2.5rem,5vw,4rem)] font-medium tracking-[-0.02em] text-text-primary mb-5">{heroHeading}</h1>
      <p class="text-text-secondary text-lg max-w-[600px] mx-auto mb-8 leading-[1.7]">{heroSubtext}</p>
      <div class="flex gap-4 justify-center flex-wrap">
        <a href="/contact" class="inline-flex items-center gap-2 py-[0.875rem] px-8 bg-accent text-black font-semibold text-[0.9375rem] rounded-lg no-underline transition-colors duration-200">Request Demo</a>
        <a href={`#${featureSections[0]?.id ?? 'meet-glucose'}`} class="inline-flex items-center gap-2 py-[0.875rem] px-8 bg-transparent text-text-primary font-medium text-[0.9375rem] rounded-lg border border-border-theme no-underline transition-[border-color] duration-200">Watch demos</a>
      </div>
    </section>

    <!-- Filter Tabs -->
    <section class="max-w-[1200px] mx-auto px-6 pt-8">
      <div class="flex gap-3 justify-center flex-wrap mb-12">
        <button class="tab-button active" data-filter="all" onclick="filterDemos('all')">All Demos</button>
        <button class="tab-button" data-filter="automotive" onclick="filterDemos('automotive')">Automotive</button>
        <button class="tab-button" data-filter="consumer" onclick="filterDemos('consumer')">Consumer</button>
      </div>
    </section>

    <!-- Feature Sections -->
    {featureSections.map((section) => (
      <section
        class="feature-section max-w-[1200px] mx-auto px-6 py-16 border-b border-border-theme"
        id={section.id}
        data-industry={section.industry}
      >
        <div class={`grid grid-cols-2 gap-16 items-center max-md:grid-cols-1 max-md:gap-8${section.reversed ? ' feature-inner-reverse' : ''}`}>
          <div>
            <span class="inline-block text-xs font-semibold tracking-[0.08em] uppercase text-accent mb-3">{section.label}</span>
            <h2 class="font-display text-[clamp(1.75rem,3vw,2.5rem)] font-medium tracking-[-0.02em] text-text-primary mb-4">{section.heading}</h2>
            <p class="text-accent text-sm mb-2">{section.tagline}</p>
            <p class="text-text-secondary leading-[1.7] mb-4">{section.body}</p>
            <a
              href="#"
              class="feature-link inline-flex items-center gap-2 text-accent text-[0.9375rem] font-medium no-underline mt-2 transition-[gap] duration-200 hover:gap-3"
              onclick={`openVideoModal('${section.videoSrc}'); return false;`}
            >
              {section.linkText}
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </a>
          </div>
          <div
            class="feature-video group relative rounded-2xl overflow-hidden cursor-pointer bg-bg-tertiary aspect-[16/10]"
            onclick={`openVideoModal('${section.videoSrc}')`}
          >
            <video autoplay muted loop playsinline>
              <source src={section.videoSrc} type="video/mp4">
            </video>
            <div class="video-play-overlay absolute inset-0 flex items-center justify-center z-[2] opacity-0 transition-opacity duration-300 group-hover:opacity-100">
              <div class="play-button w-16 h-16 bg-white/95 rounded-full flex items-center justify-center text-black transition-transform duration-200 group-hover:scale-105">
                <svg viewBox="0 0 24 24" fill="currentColor"><polygon points="5 3 19 12 5 21 5 3"/></svg>
              </div>
            </div>
          </div>
        </div>
      </section>
    ))}

    <!-- CTA -->
    <section class="py-20 px-8 text-center bg-bg-secondary border-t border-border-theme">
      <h2 class="font-[family-name:var(--font-display)] text-[clamp(1.75rem,3vw,2.5rem)] font-medium tracking-[-0.02em] text-text-primary mb-4">{ctaHeading}</h2>
      <p class="text-text-secondary text-lg max-w-[560px] mx-auto mb-8 leading-[1.7]">{ctaSubtext}</p>
      <a href="/contact" class="inline-flex items-center gap-2 py-[0.875rem] px-8 bg-accent text-black font-semibold text-[0.9375rem] rounded-lg no-underline">Request Demo</a>
    </section>
  </main>

  <!-- Video Modal -->
  <div class="video-modal fixed inset-0 z-[2000] flex items-center justify-center opacity-0 pointer-events-none transition-opacity duration-300" id="video-modal">
    <div class="video-modal-backdrop absolute inset-0 bg-black/90" onclick="closeVideoModal()"></div>
    <div class="video-modal-content relative z-[1] w-[min(90vw,1000px)] scale-95 transition-transform duration-300">
      <button class="video-modal-close absolute -top-12 right-0 bg-white/10 border border-white/20 rounded-lg text-white cursor-pointer p-2 flex items-center justify-center transition-colors duration-200 hover:bg-white/20" onclick="closeVideoModal()">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 6L6 18M6 6l12 12"/></svg>
      </button>
      <video id="modal-video" controls>
        <source src="" type="video/mp4">
      </video>
    </div>
  </div>

  <script>
    // Industry filter for demos
    function filterDemos(industry: string) {
      const sections = document.querySelectorAll<HTMLElement>('.feature-section[data-industry]');
      const tabs = document.querySelectorAll<HTMLElement>('.tab-button');
      tabs.forEach(tab => {
        tab.classList.remove('active');
        tab.style.background = 'var(--color-bg-tertiary)';
        tab.style.color = 'var(--color-text-secondary)';
        if (tab.getAttribute('data-filter') === industry) {
          tab.classList.add('active');
          tab.style.background = 'var(--color-accent)';
          tab.style.color = '#000';
        }
      });
      sections.forEach(section => {
        const sectionIndustry = section.getAttribute('data-industry');
        if (industry === 'all' || sectionIndustry === industry) {
          section.classList.remove('filtered-out');
        } else {
          section.classList.add('filtered-out');
        }
      });
    }

    // Video Modal
    const videoModal = document.getElementById('video-modal') as HTMLElement;
    const modalVideo = document.getElementById('modal-video') as HTMLVideoElement;

    function openVideoModal(videoSrc: string) {
      modalVideo.src = videoSrc;
      videoModal.classList.add('active');
      document.body.style.overflow = 'hidden';
      modalVideo.play();
    }

    function closeVideoModal() {
      videoModal.classList.remove('active');
      document.body.style.overflow = '';
      modalVideo.pause();
      modalVideo.src = '';
    }

    // Close modal on Escape key
    document.addEventListener('keydown', (e: KeyboardEvent) => {
      if (e.key === 'Escape' && videoModal.classList.contains('active')) {
        closeVideoModal();
      }
    });

    // Intersection Observer for video autoplay
    const videos = document.querySelectorAll<HTMLVideoElement>('.feature-video video');

    const videoObserver = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          (entry.target as HTMLVideoElement).play();
        } else {
          (entry.target as HTMLVideoElement).pause();
        }
      });
    }, { threshold: 0.3 });

    videos.forEach(video => {
      videoObserver.observe(video);
    });

    // Make functions globally available
    (window as any).filterDemos = filterDemos;
    (window as any).openVideoModal = openVideoModal;
    (window as any).closeVideoModal = closeVideoModal;
  </script>
</BaseLayout>
