---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getEntry } from 'astro:content';

const entry = await getEntry('pages', 'terms');
const { Content } = await entry.render();
---

<BaseLayout
  title="Terms & Conditions | 5.Y"
  description="5.Y Terms & Conditions - Please read these terms carefully before using our website and services."
  canonicalUrl="https://www.five-whys.com/terms"
  activeNav=""
>
  <main class="min-h-screen">
    <section class="pt-16 px-8 pb-8 text-center bg-bg-secondary border-b border-border-theme">
      <h1 class="font-[family-name:var(--font-display)] text-[clamp(2rem,4vw,3rem)] font-medium tracking-[-0.02em] mb-4">
        {entry.data.title}
      </h1>
      <p class="text-text-secondary text-lg">{entry.data.subtitle}</p>
    </section>

    <div class="max-w-[800px] mx-auto px-8 pt-12 pb-20 terms-body">
      <Content />
    </div>
  </main>
</BaseLayout>

<style>
  .terms-body :global(p) {
    color: var(--color-text-secondary);
    line-height: 1.8;
    margin-bottom: 1.5rem;
  }
  .terms-body :global(h2) {
    font-family: var(--font-display);
    font-size: 1.5rem;
    font-weight: 500;
    color: var(--color-text-primary);
    margin-top: 2.5rem;
    margin-bottom: 1rem;
  }
  .terms-body :global(h3) {
    font-size: 1.125rem;
    font-weight: 600;
    color: var(--color-text-primary);
    margin-top: 1.5rem;
    margin-bottom: 0.75rem;
  }
  .terms-body :global(a) {
    color: var(--color-accent);
    text-decoration: underline;
  }
</style>
