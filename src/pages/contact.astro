---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getEntry } from 'astro:content';

const cms = await getEntry('contactPage', 'contact');
if (!cms) throw new Error('Missing contactPage/contact content entry');

const {
  heroHeading, formHeading, formSubtext,
  trustedBrandsLabel, trustedBrandsSubtext,
  formAction, formSubject, formRedirectUrl,
} = cms.data;

const demoFeatures    = cms.data.demoFeatures    as string[];
const industryOptions = cms.data.industryOptions as string[];
---

<BaseLayout
  title="Contact Us | 5.Y"
  description="Get in touch with the 5.Y team. Request a demo of GLUCOSE AI Experience Agents for your enterprise."
  keywords="contact 5.Y, request demo GLUCOSE, enterprise AI demo, AI customer engagement demo"
  canonicalUrl="https://www.five-whys.com/contact"
  activeNav=""
>

  <!-- Main Content -->
  <main class="demo-page">
    <div class="demo-content">
      <!-- Left Column - Info -->
      <div class="demo-info">
        <h1>{heroHeading}</h1>
        <ul class="demo-features">
          {demoFeatures.map((f) => <li>{f}</li>)}
        </ul>
        <div class="trusted-brands">
          <h4>{trustedBrandsLabel}</h4>
          <div class="brand-logos">
            <span class="text-text-muted text-sm">{trustedBrandsSubtext}</span>
          </div>
        </div>
      </div>

      <!-- Right Column - Form -->
      <div class="demo-form-container">
        <div class="demo-form-wrapper">
          <h2>{formHeading}</h2>
          <p class="form-subtitle">{formSubtext}</p>

          <form class="demo-form" id="demo-form" action={formAction} method="POST">
            <input type="hidden" name="_subject" value={formSubject} />
            <input type="hidden" name="_next" value={formRedirectUrl} />

            <div class="form-row">
              <div class="form-group">
                <label for="first-name">First name</label>
                <input type="text" id="first-name" name="first_name" required placeholder="First name" />
              </div>
              <div class="form-group">
                <label for="last-name">Last name</label>
                <input type="text" id="last-name" name="last_name" required placeholder="Last name" />
              </div>
            </div>

            <div class="form-group">
              <label for="job-title">Job title</label>
              <input type="text" id="job-title" name="job_title" required placeholder="VP of Customer Experience" />
            </div>

            <div class="form-group">
              <label for="email">Company email</label>
              <input type="email" id="email" name="email" required placeholder="Company email" />
            </div>

            <div class="form-group">
              <label for="company">Company name</label>
              <input type="text" id="company" name="company" required placeholder="Company name" />
            </div>

            <div class="form-group">
              <label for="industry">Industry</label>
              <select id="industry" name="industry" required>
                <option value="" disabled selected>Select your industry</option>
                {industryOptions.map((opt) => (
                  <option value={opt}>{opt}</option>
                ))}
              </select>
            </div>

            <div class="form-group">
              <label for="message">Message</label>
              <textarea id="message" name="message" placeholder="Tell us about your project or questions..."></textarea>
            </div>

            <p class="form-privacy">By clicking submit, you acknowledge your data will be processed according to our <a href="/privacy">Privacy Policy</a>.</p>

            <div class="form-submit">
              <button type="submit" class="btn btn-accent">Submit</button>
            </div>
          </form>

          <!-- Success Message -->
          <div class="form-success" id="form-success">
            <div class="form-success-icon">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="20 6 9 17 4 12"></polyline>
              </svg>
            </div>
            <h3>Thank you!</h3>
            <p>We've received your request and will reach out soon.</p>
          </div>
        </div>
      </div>
    </div>
  </main>

</BaseLayout>

<script>
  // Form submission handling
  const form = document.getElementById('demo-form') as HTMLFormElement | null;
  const formSuccess = document.getElementById('form-success');

  if (form) {
    form.addEventListener('submit', async function(e) {
      e.preventDefault();

      const formData = new FormData(form);
      const submitBtn = form.querySelector('button[type="submit"]') as HTMLButtonElement | null;

      if (submitBtn) {
        submitBtn.disabled = true;
        submitBtn.textContent = 'Submitting...';
      }

      try {
        const response = await fetch(form.action, {
          method: 'POST',
          body: formData,
          headers: {
            'Accept': 'application/json'
          }
        });

        if (response.ok) {
          form.style.display = 'none';
          const subtitle = document.querySelector('.form-subtitle') as HTMLElement | null;
          const heading = document.querySelector('.demo-form-wrapper h2') as HTMLElement | null;
          if (subtitle) subtitle.style.display = 'none';
          if (heading) heading.style.display = 'none';
          if (formSuccess) formSuccess.classList.add('show');
        } else {
          throw new Error('Form submission failed');
        }
      } catch (error) {
        alert('There was an error submitting the form. Please try again or email us directly at denis@five-whys.com');
        if (submitBtn) {
          submitBtn.disabled = false;
          submitBtn.textContent = 'Submit';
        }
      }
    });
  }
</script>
