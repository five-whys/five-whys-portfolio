    color: var(--color-text-muted);
  }

  /* Carousel Navigation */
  .testimonial-nav {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 1rem;
    margin-top: 2rem;
  }

  .testimonial-dots {
    display: flex;
    gap: 0.5rem;
  }

  .testimonial-dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: var(--color-border);
    border: none;
    cursor: pointer;
    transition: all var(--transition-fast);
  }

  .testimonial-dot.active {
    background: var(--color-accent);
    transform: scale(1.2);
  }

  .testimonial-dot:hover {
    background: var(--color-accent);
  }

  .testimonial-arrow {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background: var(--color-bg-tertiary);
    border: 1px solid var(--color-border);
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all var(--transition-fast);
  }

  .testimonial-arrow:hover {
    background: var(--color-accent);
    border-color: var(--color-accent);
  }

  .testimonial-arrow svg {
    width: 20px;
    height: 20px;
    stroke: var(--color-text-secondary);
    transition: stroke var(--transition-fast);
  }

  .testimonial-arrow:hover svg {
    stroke: var(--color-bg-primary);
  }

  /* ========== CTA SECTION ========== */
  .cta-section {
    padding: 8rem 2rem;
    text-align: center;
    background: linear-gradient(180deg, var(--color-bg-secondary) 0%, var(--color-bg-primary) 100%);
  }

  .cta-inner {
    max-width: 700px;
    margin: 0 auto;
  }

  .cta-section h2 {
    font-family: var(--font-display);
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 500;
    margin-bottom: 1rem;
  }

  .cta-section p {
    font-size: 1.125rem;
    color: var(--color-text-secondary);
    margin-bottom: 2rem;
  }

  .cta-buttons {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  /* ========== RESPONSIVE ========== */
  @media (max-width: 1024px) {
    .comparison-block {
      grid-template-columns: 1fr;
      gap: 2rem;
    }

    .comparison-block.reverse {
      direction: ltr;
    }
  }

  @media (max-width: 768px) {
    .vs-hero {
      padding: 4rem 1.5rem 3rem;
    }

    .section {
      padding: 4rem 1.5rem;
    }

    .comparison-visual {
      min-height: auto;
      padding: 2rem;
    }

    .comparison-table th,
    .comparison-table td {
      padding: 1rem;
      font-size: 0.8125rem;
    }

    .vs-comparison {
      flex-direction: column;
      gap: 1.5rem;
    }

    .vs-arrow {
      transform: rotate(90deg);
    }

    .vs-panel {
      padding: 1.25rem;
    }

    .vs-panel-title {
      font-size: 1.1rem;
    }

    .testimonial-slide {
      min-width: 85vw;
      max-width: 85vw;
    }

    .testimonial-card {
      padding: 1.5rem;
    }

    .testimonial-viewport {
      -webkit-mask-image: linear-gradient(to right, transparent 0%, black 4%, black 96%, transparent 100%);
      mask-image: linear-gradient(to right, transparent 0%, black 4%, black 96%, transparent 100%);
    }

    .testimonial-slides {
      gap: 1rem;
    }

    .testimonial-arrow {
      display: none;
    }
  }

  @media (max-width: 480px) {
    .vs-hero h1 {
      font-size: 1.75rem;
    }

    .section {
      padding: 3rem 1rem;
    }
  }
</style>

<script>
  // Testimonial Carousel — infinite loop with peek on both sides
  const carousel = document.getElementById('testimonialCarousel');
  if (carousel) {
    const viewport = carousel.querySelector('.testimonial-viewport') as HTMLElement;
    const slidesContainer = carousel.querySelector('.testimonial-slides') as HTMLElement;
    const originalSlides = Array.from(carousel.querySelectorAll('.testimonial-slide')) as HTMLElement[];
    const dotsContainer = document.getElementById('testimonialDots') as HTMLElement;
    const prevBtn = document.getElementById('prevSlide') as HTMLButtonElement;
    const nextBtn = document.getElementById('nextSlide') as HTMLButtonElement;
    const totalOriginal = originalSlides.length;
    let currentIndex = totalOriginal;
    let autoplayInterval: ReturnType<typeof setInterval>;
    let isTransitioning = false;

    originalSlides.forEach(s => slidesContainer.appendChild(s.cloneNode(true)));
    [...originalSlides].reverse().forEach(s => slidesContainer.insertBefore(s.cloneNode(true), slidesContainer.firstChild));

    const allSlides = Array.from(slidesContainer.querySelectorAll('.testimonial-slide')) as HTMLElement[];

    originalSlides.forEach((_, index) => {
      const dot = document.createElement('button');
      dot.classList.add('testimonial-dot');
      if (index === 0) dot.classList.add('active');
      dot.addEventListener('click', () => goToSlide(index + totalOriginal));
      dotsContainer.appendChild(dot);
    });
    const dots = dotsContainer.querySelectorAll('.testimonial-dot');

    function getOffset(index: number): number {
      const slide = allSlides[index];
      const viewportWidth = viewport.offsetWidth;
      const slideWidth = slide.offsetWidth;
      return slide.offsetLeft - (viewportWidth - slideWidth) / 2;
    }

    function updateClasses(index: number): void {
      allSlides.forEach((s, i) => s.classList.toggle('active', i === index));
      const realIndex = ((index - totalOriginal) % totalOriginal + totalOriginal) % totalOriginal;
      dots.forEach((d, i) => d.classList.toggle('active', i === realIndex));
    }

    function moveToSlide(index: number, animate: boolean = true): void {
      if (animate !== false) {
        slidesContainer.classList.remove('no-transition');
      } else {
        slidesContainer.classList.add('no-transition');
      }
      currentIndex = index;
      slidesContainer.style.transform = `translateX(-${getOffset(index)}px)`;
      updateClasses(index);
    }

    slidesContainer.addEventListener('transitionend', () => {
      isTransitioning = false;
      if (currentIndex < totalOriginal) {
        moveToSlide(currentIndex + totalOriginal, false);
      } else if (currentIndex >= totalOriginal * 2) {
        moveToSlide(currentIndex - totalOriginal, false);
      }
    });

    function goToSlide(index: number): void {
      if (isTransitioning) return;
      isTransitioning = true;
      moveToSlide(index);
      resetAutoplay();
    }

    function next(): void { goToSlide(currentIndex + 1); }
    function prev(): void { goToSlide(currentIndex - 1); }

    function startAutoplay(): void {
      autoplayInterval = setInterval(next, 6000);
    }

    function resetAutoplay(): void {
      clearInterval(autoplayInterval);
      startAutoplay();
    }

    prevBtn.addEventListener('click', prev);
    nextBtn.addEventListener('click', next);

    carousel.addEventListener('mouseenter', () => clearInterval(autoplayInterval));
    carousel.addEventListener('mouseleave', startAutoplay);

    let touchStartX = 0;
    let touchEndX = 0;
    carousel.addEventListener('touchstart', (e: TouchEvent) => { touchStartX = e.changedTouches[0].screenX; }, { passive: true });
    carousel.addEventListener('touchend', (e: TouchEvent) => {
      touchEndX = e.changedTouches[0].screenX;
      const diff = touchStartX - touchEndX;
      if (Math.abs(diff) > 50) { diff > 0 ? next() : prev(); }
    });

    moveToSlide(totalOriginal, false);
    window.addEventListener('resize', () => moveToSlide(currentIndex, false));

    startAutoplay();
  }
</script>
