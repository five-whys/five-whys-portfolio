---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/sections/PageHero.astro';
import SectionHeader from '../components/ui/SectionHeader.astro';
import {
  Check, Clock, MessageSquare, Boxes, FileText,
  ArrowRight, Wrench, Settings, CheckCircle, Bell, X, MinusCircle,
  ChevronLeft, ChevronRight,
} from 'lucide-astro';
---

<BaseLayout
  title="GLUCOSE vs Traditional Chatbots - AI Comparison | 5.Y"
  description="Compare GLUCOSE agentic AI vs traditional chatbots and FAQ bots. See why autonomous AI agents outperform scripted solutions for customer engagement."
  canonicalUrl="https://www.five-whys.com/vs"
  ogTitle="GLUCOSE vs Traditional Chatbots | 5.Y"
  ogDescription="Compare GLUCOSE agentic AI vs traditional chatbots. See why autonomous AI outperforms scripted solutions."
  twitterTitle="GLUCOSE vs Traditional Chatbots | 5.Y"
  twitterDescription="Compare GLUCOSE agentic AI vs traditional chatbots and FAQ bots."
  activeNav="vs"
>
  <main>
    <!-- VS Hero -->
    <section class="vs-hero">
      <div class="vs-hero-inner">
        <div class="vs-badge">
          <Boxes size={16} />
          Compare Solutions
        </div>
        <h1>Why teams choose <span class="highlight">GLUCOSE</span> over traditional solutions</h1>
        <p>Enterprise teams need autonomous AI agents that understand context, deliver personalized experiences, and scale effortlessly—not rule-based chatbots that frustrate customers.</p>
        <div class="vs-hero-cta">
          <a href="/contact" class="btn btn-accent">Book a Demo</a>
          <a href="/product" class="btn btn-secondary">Explore GLUCOSE</a>
        </div>
      </div>
    </section>

    <!-- Comparison Sections -->
    <section class="py-32 px-8">
      <div class="max-w-[1200px] mx-auto">
        <SectionHeader label="The Difference" heading="What makes GLUCOSE different?" subtext="See why leading brands are switching from traditional chatbots and generic AI solutions to GLUCOSE's autonomous agents." />

        <!-- Visual Comparison -->
        <div style="margin-bottom: 4rem;">
          <div class="vs-comparison">
            <!-- Traditional Chatbot -->
            <div class="vs-panel vs-panel--chatbot">
              <div class="vs-panel-header">
                <div class="vs-panel-icon vs-panel-icon--bad">✕</div>
                <div class="vs-panel-title">Traditional Chatbot</div>
              </div>
              <div class="vs-chat">
                <div class="vs-msg vs-msg--user">
                  <div class="vs-msg-avatar vs-msg-avatar--user">U</div>
                  <div>
                    <div class="vs-msg-label">User</div>
                    <div class="vs-msg-bubble">I want to change my delivery address for order #12345 and also ask about the warranty</div>
                  </div>
                </div>
                <div class="vs-msg">
                  <div class="vs-msg-avatar vs-msg-avatar--bot">B</div>
                  <div>
                    <div class="vs-msg-label">Bot</div>
                    <div class="vs-msg-bubble vs-msg-bubble--bot">I can help you with delivery. Please select an option:<br>1. Track order<br>2. Change address<br>3. Cancel order</div>
                  </div>
                </div>
                <div class="vs-msg vs-msg--user">
                  <div class="vs-msg-avatar vs-msg-avatar--user">U</div>
                  <div class="vs-msg-bubble">Change address</div>
                </div>
                <div class="vs-msg">
                  <div class="vs-msg-avatar vs-msg-avatar--bot">B</div>
                  <div class="vs-msg-bubble vs-msg-bubble--bot">Please enter your new address</div>
                </div>
                <div class="vs-msg vs-msg--user">
                  <div class="vs-msg-avatar vs-msg-avatar--user">U</div>
                  <div class="vs-msg-bubble">123 Main St. Also, what about the warranty?</div>
                </div>
                <div class="vs-msg">
                  <div class="vs-msg-avatar vs-msg-avatar--bot">B</div>
                  <div class="vs-msg-bubble vs-msg-bubble--bot">I'm sorry, I can only help with one thing at a time. Please start a new conversation for warranty questions.</div>
                </div>
              </div>
              <div class="vs-result-emoji">😡</div>
            </div>

            <!-- Arrow -->
            <div class="vs-arrow">→</div>

            <!-- GLUCOSE AI -->
            <div class="vs-panel vs-panel--glucose">
              <div class="vs-panel-header">
                <div class="vs-panel-icon vs-panel-icon--good">✓</div>
                <div class="vs-panel-title">GLUCOSE AI</div>
              </div>
              <div class="vs-chat">
                <div class="vs-msg vs-msg--user">
                  <div class="vs-msg-avatar vs-msg-avatar--user">U</div>
                  <div>
                    <div class="vs-msg-label">User</div>
                    <div class="vs-msg-bubble">I want to change my delivery address for order #12345 and also ask about the warranty</div>
                  </div>
                </div>
                <div class="vs-msg">
                  <div class="vs-msg-avatar vs-msg-avatar--glucose">G</div>
                  <div>
                    <div class="vs-msg-label">GLUCOSE</div>
                    <div class="vs-msg-bubble vs-msg-bubble--ai">
                      I'd be happy to help with both! Let me update the delivery address for order #12345 to 123 Main St.<br><br>
                      <span class="vs-done">✅ Done!</span><br><br>
                      Regarding warranty: Your product comes with a 2-year manufacturer warranty covering defects.<br><br>
                      Would you like me to:<br>
                      1) Email the full warranty details<br>
                      2) Register your product<br>
                      3) Start a warranty claim?
                    </div>
                  </div>
                </div>
              </div>
              <div class="vs-result-emoji">😊</div>
            </div>
          </div>
        </div>

        <!-- Comparison 1: Goal-Driven vs. Script-Based -->
        <div class="comparison-block">
          <div class="comparison-content">
            <h3>Goal-driven reasoning, not scripted responses</h3>
            <p>Traditional chatbots follow rigid decision trees that break when conversations shift. GLUCOSE agents reason through complexity, adapting to context and pursuing goals autonomously.</p>
            <ul>
              <li>
                <Check size={16} />
                Understands intent even with unexpected questions
              </li>
              <li>
                <Check size={16} />
                Handles multi-turn, complex conversations naturally
              </li>
              <li>
                <Check size={16} />
                Balances user needs with business objectives
              </li>
            </ul>
          </div>
          <div class="comparison-visual">
            <div class="visual-icon">
              <Clock size={32} />
            </div>
            <div class="visual-title">Autonomous Goal Pursuit</div>
            <div class="visual-desc">GLUCOSE agents work toward outcomes, not just responses. They understand context, remember history, and make intelligent decisions.</div>
            <div class="chat-mockup">
              <div class="chat-message">
                <div class="chat-avatar user">U</div>
                <div class="chat-bubble">"Actually, wait—can I also ask about warranty coverage?"</div>
              </div>
              <div class="chat-message">
                <div class="chat-avatar">G</div>
                <div class="chat-bubble ai">"Of course! Your vehicle's warranty includes 4-year coverage. I'll also continue helping with the service booking—would you prefer morning or afternoon?"</div>
              </div>
            </div>
          </div>
        </div>

        <!-- Comparison 2: Native Multi-Channel -->
        <div class="comparison-block reverse">
          <div class="comparison-content">
            <h3>Native multi-channel, not bolted-on integrations</h3>
            <p>Most solutions treat messaging channels as an afterthought. GLUCOSE is built from the ground up for WhatsApp, Telegram, LINE, and more—meeting customers where they already are.</p>
            <ul>
              <li>
                <Check size={16} />
                Deploy on WhatsApp, Telegram, LINE, Viber, and more
              </li>
              <li>
                <Check size={16} />
                Consistent experience across all channels
              </li>
              <li>
                <Check size={16} />
                No app downloads required for customers
              </li>
            </ul>
          </div>
          <div class="comparison-visual">
            <div class="visual-icon">
              <MessageSquare size={32} />
            </div>
            <div class="visual-title">Deploy Everywhere</div>
            <div class="visual-desc">One configuration, every channel. Your brand shows up wherever your customers prefer to communicate.</div>
            <div class="flow-diagram">
              <div class="flow-node">
                <svg viewBox="0 0 24 24" fill="#25D366"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
                <span>WhatsApp</span>
              </div>
              <div class="flow-node">
                <svg viewBox="0 0 24 24" fill="#0088CC"><path d="M11.944 0A12 12 0 0 0 0 12a12 12 0 0 0 12 12 12 12 0 0 0 12-12A12 12 0 0 0 12 0a12 12 0 0 0-.056 0zm4.962 7.224c.1-.002.321.023.465.14a.506.506 0 0 1 .171.325c.016.093.036.306.02.472-.18 1.898-.962 6.502-1.36 8.627-.168.9-.499 1.201-.82 1.23-.696.065-1.225-.46-1.9-.902-1.056-.693-1.653-1.124-2.678-1.8-1.185-.78-.417-1.21.258-1.91.177-.184 3.247-2.977 3.307-3.23.007-.032.014-.15-.056-.212s-.174-.041-.249-.024c-.106.024-1.793 1.14-5.061 3.345-.48.33-.913.49-1.302.48-.428-.008-1.252-.241-1.865-.44-.752-.245-1.349-.374-1.297-.789.027-.216.325-.437.893-.663 3.498-1.524 5.83-2.529 6.998-3.014 3.332-1.386 4.025-1.627 4.476-1.635z"/></svg>
                <span>Telegram</span>
              </div>
              <div class="flow-node">
                <svg viewBox="0 0 24 24" fill="#00C300"><path d="M19.365 9.863c.349 0 .63.285.63.631 0 .345-.281.63-.63.63H17.61v1.125h1.755c.349 0 .63.283.63.63 0 .344-.281.629-.63.629h-2.386c-.345 0-.627-.285-.627-.629V8.108c0-.345.282-.63.63-.63h2.386c.346 0 .627.285.627.63 0 .349-.281.63-.63.63H17.61v1.125h1.755zm-3.855 3.016c0 .27-.174.51-.432.596-.064.021-.133.031-.199.031-.193 0-.378-.09-.503-.234l-2.178-2.636v2.243c0 .345-.282.63-.63.63-.345 0-.627-.285-.627-.63V8.108c0-.27.174-.51.432-.596.064-.021.13-.031.199-.031.19 0 .378.09.5.234l2.178 2.636V8.108c0-.345.282-.63.63-.63.346 0 .63.285.63.63v4.771zm-5.741 0c0 .345-.282.63-.63.63-.345 0-.627-.285-.627-.63V8.108c0-.345.282-.63.63-.63.346 0 .627.285.627.63v4.771zm-2.466.63H4.917c-.345 0-.63-.285-.63-.63V8.108c0-.345.285-.63.63-.63.348 0 .63.285.63.63v4.141h1.756c.348 0 .63.285.63.63 0 .345-.282.629-.63.629M24 10.314C24 4.943 18.615.572 12 .572S0 4.943 0 10.314c0 4.811 4.27 8.842 10.035 9.608.391.082.923.258 1.058.59.12.301.079.766.038 1.08l-.164 1.02c-.045.301-.24 1.186 1.049.645 1.291-.539 6.916-4.078 9.436-6.975C23.176 14.393 24 12.458 24 10.314"/></svg>
                <span>LINE</span>
              </div>
              <div class="flow-node highlight">
                <Boxes size={20} />
                <span>GLUCOSE</span>
              </div>
            </div>
          </div>
        </div>

        <!-- Comparison 3: No-Code Setup -->
        <div class="comparison-block">
          <div class="comparison-content">
            <h3>No-code setup, not months of development</h3>
            <p>Traditional enterprise AI deployments take months and require technical teams. GLUCOSE's Management Console lets product managers configure, deploy, and iterate without writing code.</p>
            <ul>
              <li>
                <Check size={16} />
                Visual journey builder for business users
              </li>
              <li>
                <Check size={16} />
                Deploy in days, not months
              </li>
              <li>
                <Check size={16} />
                Iterate and improve without engineering support
              </li>
            </ul>
          </div>
          <div class="comparison-visual">
            <div class="visual-icon">
              <Boxes size={32} />
            </div>
            <div class="visual-title">Management Console</div>
            <div class="visual-desc">Define customer journeys, configure responses, and analyze performance—all through an intuitive interface designed for business users.</div>
            <div class="flow-diagram" style="margin-top: 1.5rem;">
              <div class="flow-node">
                <FileText size={20} />
                <span>Add Docs</span>
              </div>
              <div class="flow-arrow"><ArrowRight size={16} /></div>
              <div class="flow-node">
                <Wrench size={20} />
                <span>Add Tools</span>
              </div>
              <div class="flow-arrow"><ArrowRight size={16} /></div>
              <div class="flow-node">
                <Settings size={20} />
                <span>Configure</span>
              </div>
              <div class="flow-arrow"><ArrowRight size={16} /></div>
              <div class="flow-node highlight">
                <CheckCircle size={20} />
                <span>Go Live</span>
              </div>
            </div>
          </div>
        </div>

        <!-- Comparison 4: Proactive Engagement -->
        <div class="comparison-block reverse">
          <div class="comparison-content">
            <h3>Proactive re-engagement, not just reactive support</h3>
            <p>Traditional chatbots wait for customers to ask questions. GLUCOSE agents proactively engage—sharing relevant information, following up on service needs, and driving conversions.</p>
            <ul>
              <li>
                <Check size={16} />
                Scheduled follow-ups and reminders
              </li>
              <li>
                <Check size={16} />
                Event-triggered communications (IoT, CRM, etc.)
              </li>
              <li>
                <Check size={16} />
                Personalized product recommendations
              </li>
            </ul>
          </div>
          <div class="comparison-visual">
            <div class="visual-icon">
              <Bell size={32} />
            </div>
            <div class="visual-title">Always-On Engagement</div>
            <div class="visual-desc">GLUCOSE doesn't just answer—it anticipates. Proactive outreach keeps customers engaged throughout their journey.</div>
            <div class="chat-mockup">
              <div class="chat-message">
                <div class="chat-avatar">G</div>
                <div class="chat-bubble ai">"Hi! Your vehicle's 10,000km service is coming up. I noticed a convenient slot available next Tuesday at 10am. Would you like me to book it?"</div>
              </div>
              <div class="chat-message">
                <div class="chat-avatar user">U</div>
                <div class="chat-bubble">"Yes, that works perfectly!"</div>
              </div>
              <div class="chat-message">
                <div class="chat-avatar">G</div>
                <div class="chat-bubble ai">"Done! I've booked your service and sent a calendar invite. Need a reminder the day before?"</div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Feature Comparison Table -->
    <section class="comparison-table-section">
      <div class="max-w-[1200px] mx-auto">
        <SectionHeader label="Feature Comparison" heading="GLUCOSE vs. Alternatives" subtext="See how GLUCOSE compares to traditional chatbots and generic AI solutions." />

        <div class="comparison-table-wrapper">
          <table class="comparison-table">
            <thead>
              <tr>
                <th>Features</th>
                <th class="glucose-col">GLUCOSE</th>
                <th>Traditional Chatbots</th>
                <th>Generic AI (GPT wrappers)</th>
              </tr>
            </thead>
            <tbody>
              <tr>
                <td>Goal-driven autonomous reasoning</td>
                <td class="check"><Check size={16} /></td>
                <td class="cross"><X size={16} /></td>
                <td class="partial"><MinusCircle size={16} /></td>
              </tr>
              <tr>
                <td>Native multi-channel deployment</td>
                <td class="check"><Check size={16} /></td>
                <td class="partial"><MinusCircle size={16} /></td>
                <td class="cross"><X size={16} /></td>
              </tr>
              <tr>
                <td>No-code configuration</td>
                <td class="check"><Check size={16} /></td>
                <td class="check"><Check size={16} /></td>
                <td class="cross"><X size={16} /></td>
              </tr>
              <tr>
                <td>Proactive customer engagement</td>
                <td class="check"><Check size={16} /></td>
                <td class="cross"><X size={16} /></td>
                <td class="cross"><X size={16} /></td>
              </tr>
              <tr>
                <td>Enterprise CRM/CDP integrations</td>
                <td class="check"><Check size={16} /></td>
                <td class="partial"><MinusCircle size={16} /></td>
                <td class="partial"><MinusCircle size={16} /></td>
              </tr>
              <tr>
                <td>IoT event-triggered actions</td>
                <td class="check"><Check size={16} /></td>
                <td class="cross"><X size={16} /></td>
                <td class="cross"><X size={16} /></td>
              </tr>
              <tr>
                <td>First-party data insights</td>
                <td class="check"><Check size={16} /></td>
                <td class="partial"><MinusCircle size={16} /></td>
                <td class="cross"><X size={16} /></td>
              </tr>
              <tr>
                <td>Enterprise security (SOC 2, ISO 27001)</td>
                <td class="check"><Check size={16} /></td>
                <td class="partial"><MinusCircle size={16} /></td>
                <td class="partial"><MinusCircle size={16} /></td>
              </tr>
              <tr>
                <td>Brand voice consistency</td>
                <td class="check"><Check size={16} /></td>
                <td class="partial"><MinusCircle size={16} /></td>
                <td class="cross"><X size={16} /></td>
              </tr>
            </tbody>
          </table>
        </div>
      </div>
    </section>

    <!-- Enterprise AI Platform Comparison -->
    <section class="comparison-table-section" style="background: var(--color-bg-primary);">
      <div class="max-w-[1200px] mx-auto">
        <SectionHeader label="Enterprise Comparison" heading="GLUCOSE vs. AI-Native Platforms" subtext="How GLUCOSE compares to enterprise AI platforms in the market today." />

        <div class="comparison-table-wrapper">
          <table class="comparison-table">
            <thead>
              <tr>
                <th>Capability</th>
                <th class="glucose-col">GLUCOSE</th>
                <th>Salesforce AgentForce</th>
                <th>Sierra AI</th>
              </tr>
            </thead>
            <tbody>
              <tr>
                <td>Closes deals without human intervention</td>
                <td class="check"><Check size={16} /></td>
                <td class="partial"><MinusCircle size={16} /></td>
                <td class="partial"><MinusCircle size={16} /></td>
              </tr>
              <tr>
                <td>Engages customers on WhatsApp, LINE, Telegram natively</td>
                <td class="check"><Check size={16} /></td>
                <td class="cross"><X size={16} /></td>
                <td class="partial"><MinusCircle size={16} /></td>
              </tr>
              <tr>
                <td>Proactive lifecycle re-engagement (Planner)</td>
                <td class="check"><Check size={16} /></td>
                <td class="cross"><X size={16} /></td>
                <td class="cross"><X size={16} /></td>
              </tr>
              <tr>
                <td>Model-agnostic (no vendor lock-in)</td>
                <td class="check"><Check size={16} /></td>
                <td class="cross"><X size={16} /></td>
                <td class="partial"><MinusCircle size={16} /></td>
              </tr>
              <tr>
                <td>Vertical-specific product corpus architecture</td>
                <td class="check"><Check size={16} /></td>
                <td class="partial"><MinusCircle size={16} /></td>
                <td class="cross"><X size={16} /></td>
              </tr>
              <tr>
                <td>Live in weeks, not months</td>
                <td class="check"><Check size={16} /></td>
                <td class="cross"><X size={16} /></td>
                <td class="partial"><MinusCircle size={16} /></td>
              </tr>
              <tr>
                <td>Multimodal (voice, text, images, video)</td>
                <td class="check"><Check size={16} /></td>
                <td class="partial"><MinusCircle size={16} /></td>
                <td class="partial"><MinusCircle size={16} /></td>
              </tr>
              <tr>
                <td>Single-tenant deployment option</td>
                <td class="check"><Check size={16} /></td>
                <td class="cross"><X size={16} /></td>
                <td class="cross"><X size={16} /></td>
              </tr>
              <tr>
                <td>Outcome-based pricing</td>
                <td class="check"><Check size={16} /></td>
                <td class="cross"><X size={16} /></td>
                <td class="check"><Check size={16} /></td>
              </tr>
            </tbody>
          </table>
        </div>

        <!-- Reframed Legacy vs Agentic -->
        <div style="margin-top: 4rem;">
          <h3 style="font-family: var(--font-display); font-size: 1.5rem; font-weight: 500; color: var(--color-text-primary); text-align: center; margin-bottom: 2rem;">The Engagement Stack, Reimagined</h3>
          <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 2rem; max-width: 800px; margin: 0 auto;">
            <div style="padding: 2rem; background: var(--color-bg-tertiary); border-radius: 12px; border: 1px solid var(--color-border);">
              <div style="font-size: 0.75rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.15em; color: var(--color-text-muted); margin-bottom: 1rem;">Legacy Era</div>
              <ul style="list-style: none; display: flex; flex-direction: column; gap: 0.75rem;">
                <li style="font-size: 0.9375rem; color: var(--color-text-secondary);">CRM stores records</li>
                <li style="font-size: 0.9375rem; color: var(--color-text-secondary);">Chatbots answer questions</li>
                <li style="font-size: 0.9375rem; color: var(--color-text-secondary);">Marketing automates campaigns</li>
                <li style="font-size: 0.9375rem; color: var(--color-text-secondary);">Humans follow up</li>
              </ul>
            </div>
            <div style="padding: 2rem; background: var(--color-accent-soft); border-radius: 12px; border: 1px solid rgba(255, 192, 0, 0.2);">
              <div style="font-size: 0.75rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.15em; color: var(--color-accent); margin-bottom: 1rem;">Agentic Era</div>
              <ul style="list-style: none; display: flex; flex-direction: column; gap: 0.75rem;">
                <li style="font-size: 0.9375rem; color: var(--color-text-primary); font-weight: 500;">GLUCOSE orchestrates experiences</li>
                <li style="font-size: 0.9375rem; color: var(--color-text-primary); font-weight: 500;">GLUCOSE executes goals</li>
                <li style="font-size: 0.9375rem; color: var(--color-text-primary); font-weight: 500;">GLUCOSE adapts in real time</li>
