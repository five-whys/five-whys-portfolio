---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/sections/PageHero.astro';
import ResultsGrid from '../components/sections/ResultsGrid.astro';
import SuccessStoryCard from '../components/cards/SuccessStoryCard.astro';
import { ArrowRight } from 'lucide-astro';
import { successStories, results, featuredCustomer, featuredTestimonial } from '../data/customers';
---

<BaseLayout
  title="Customer Success Stories - GLUCOSE AI Results | 5.Y"
  description="See how industry leaders use GLUCOSE AI for autonomous customer engagement. Real results from automotive, healthcare, and retail companies."
  keywords="GLUCOSE customers, AI customer success stories, enterprise AI case studies, customer engagement results, AI implementation success"
  canonicalUrl="https://www.five-whys.com/customers"
  ogTitle="Customer Success Stories | 5.Y"
  ogDescription="See how industry leaders use GLUCOSE AI for autonomous customer engagement."
  ogImage="https://www.five-whys.com/Images/og-image.png"
  twitterTitle="Customer Success Stories | 5.Y"
  twitterDescription="Real results from GLUCOSE AI implementations."
  activeNav="customers"
>
  <!-- Hero -->
  <PageHero
    heading="Our Customers"
    subtext="5.Y is trusted by industry leaders delivering autonomous customer experiences across healthcare, mobility, and logistics."
  />

  <!-- Featured Customer - IHH Healthcare -->
  <section class="max-w-[1200px] mx-auto mb-16 px-8">
    <a
      href={featuredCustomer.href}
      class="featured-card grid grid-cols-[1.2fr_1fr] gap-0 bg-bg-tertiary rounded-[20px] overflow-hidden border border-border-theme no-underline text-inherit transition-all duration-300 ease-[cubic-bezier(0.4,0,0.2,1)]"
    >
      <div class="relative min-h-[400px] bg-[linear-gradient(135deg,#1a1a2e_0%,#16213e_100%)] overflow-hidden">
        <img src={featuredCustomer.imageSrc} alt={featuredCustomer.imageAlt} class="w-full h-full object-cover opacity-90" />
        <div class="absolute bottom-0 left-0 right-0 p-8 bg-[linear-gradient(transparent,rgba(0,0,0,0.8))]">
          <img src={featuredCustomer.logoSrc} alt={featuredCustomer.logoAlt} class="h-10 w-auto" />
        </div>
      </div>
      <div class="p-12 flex flex-col justify-center">
        <div class="flex gap-8 mb-8">
          {featuredCustomer.metrics.map((m) => (
            <div>
              <div class="text-[0.75rem] font-medium text-text-muted uppercase tracking-[0.1em] mb-1">{m.label}</div>
              <div class="text-[2rem] font-bold text-accent">{m.value}</div>
            </div>
          ))}
        </div>
        <h2 class="font-[family-name:var(--font-display)] text-2xl font-medium text-text-primary mb-4 leading-[1.3]">{featuredCustomer.heading}</h2>
        <p class="text-text-secondary text-[0.9375rem] leading-[1.6] mb-6">{featuredCustomer.body}</p>
        <span class="inline-flex items-center gap-2 text-accent text-sm font-medium">
          Read the story
          <ArrowRight size={16} />
        </span>
      </div>
    </a>
  </section>

  <!-- Customer Grid - ResultsGrid component -->
  <ResultsGrid results={results} />

  <!-- Success Stories -->
  <section class="bg-bg-secondary py-16 px-8">
    <div class="max-w-[1200px] mx-auto">
      <h2 class="font-[family-name:var(--font-display)] text-[clamp(1.75rem,3vw,2.5rem)] font-medium tracking-[-0.02em] mb-10">Success Stories</h2>
      <div class="grid grid-cols-[repeat(auto-fit,minmax(260px,1fr))] gap-6">
        {successStories.map((story) => <SuccessStoryCard {...story} />)}
      </div>
    </div>
  </section>

  <!-- Testimonial -->
  <section class="py-16 px-8 bg-bg-primary">
    <div class="max-w-[800px] mx-auto">
      <div class="bg-bg-secondary border border-border-theme rounded-[20px] p-12 text-center">
        <img src={featuredTestimonial.logoSrc} alt={featuredTestimonial.logoAlt} class="h-9 w-auto mx-auto mb-8" />
        <blockquote class="font-[family-name:var(--font-display)] text-[clamp(1.25rem,2vw,1.5rem)] font-normal text-text-primary leading-[1.6] tracking-[-0.01em] mb-8">"{featuredTestimonial.quote}"</blockquote>
        <div class="flex items-center justify-center gap-4">
          <img src={featuredTestimonial.avatarSrc} alt={featuredTestimonial.avatarAlt} class="w-12 h-12 rounded-full object-cover" />
          <div class="text-left">
            <div class="font-semibold text-text-primary text-[0.9375rem]">{featuredTestimonial.name}</div>
            <div class="text-text-secondary text-sm">{featuredTestimonial.role}</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="bg-bg-secondary border-t border-border-theme py-20 px-8 text-center" id="demo">
    <h2 class="font-[family-name:var(--font-display)] text-[clamp(2rem,4vw,3rem)] font-medium tracking-[-0.02em] mb-4">See what GLUCOSE can do for you</h2>
    <p class="text-text-secondary text-lg max-w-[600px] mx-auto mb-8">Discover how GLUCOSE can help your enterprise run autonomous brand experiences that reach every customer, in every moment that matters.</p>
    <a href="/contact" class="inline-flex items-center justify-center gap-2 font-[family-name:var(--font-primary)] text-[0.9375rem] font-medium no-underline rounded-pill bg-accent text-bg-primary py-[0.875rem] px-7 transition-all duration-300">Request Demo</a>
  </section>
</BaseLayout>

<style>
  .featured-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 20px 60px rgba(0, 0, 0, 0.2);
    border-color: var(--color-accent);
  }
</style>
