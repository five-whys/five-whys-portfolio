---
import { getEntry } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionHeader from '../components/ui/SectionHeader.astro';
import {
  Zap, Wrench, Building2, Monitor, Activity, Home, Briefcase,
  Boxes, Globe, ShoppingCart, MessageSquare, BarChart3, Clock,
  Bell, Users, BookOpen, Shield, Settings,
} from 'lucide-astro';

const cmsEntry = await getEntry('industriesPage', 'index');
if (!cmsEntry) throw new Error('industriesPage CMS entry not found');
const p = cmsEntry.data;

// Icon resolution map for CMS iconName strings
const industryIconMap: Record<string, any> = {
  Zap, Wrench, Building2, Monitor, Activity, Home, Briefcase,
  Boxes, Globe, ShoppingCart, MessageSquare, BarChart3, Clock,
  Bell, Users, BookOpen, Shield, Settings,
};

---

<BaseLayout
  title="AI Customer Engagement for Automotive, Healthcare & Retail | 5.Y"
  description="GLUCOSE AI agents for automotive, healthcare, retail, and consumer electronics. WhatsApp chatbots, voice AI, and multi-channel customer engagement solutions."
  canonicalUrl="https://www.five-whys.com/industries"
  activeNav="industries"
>
  <style>
    /* ── Industry Overview Cards ────────────────────────────────────────────── */
    .industry-overview-card {
      position: relative;
      overflow: hidden;
      border-radius: 20px;
      border: 1px solid var(--color-border);
      background: var(--color-bg-tertiary);
      padding: 1.5rem;
      text-decoration: none;
      color: var(--color-text-primary);
      /* CSS grid: icon col | title col, desc spans full width */
      display: grid;
      grid-template-columns: 36px 1fr;
      grid-template-rows: auto auto;
      column-gap: 0.75rem;
      row-gap: 0.625rem;
      align-items: center;
      transition: transform 0.3s ease, border-color 0.3s ease, box-shadow 0.3s ease;
    }
    /* gold top-edge line */
    .industry-overview-card::before {
      content: '';
      position: absolute;
      top: 0; left: 0; right: 0;
      height: 1px;
      background: linear-gradient(90deg, transparent, rgba(255,192,0,0.65), transparent);
    }
    /* radial glow from top */
    .industry-overview-card::after {
      content: '';
      position: absolute;
      inset: 0;
      background: radial-gradient(ellipse 130% 55% at 50% 0%, rgba(255,192,0,0.07) 0%, transparent 65%);
      pointer-events: none;
    }
    .industry-overview-card:hover {
      transform: translateY(-5px);
      border-color: rgba(255,192,0,0.28);
      box-shadow: 0 16px 36px rgba(255,192,0,0.06);
    }
    /* place icon in grid cell 1,1 */
    .industry-overview-icon {
      grid-column: 1;
      grid-row: 1;
      align-self: center;
      position: relative;
      z-index: 1;
    }
    .industry-overview-icon svg { width: 100%; height: 100%; }
    /* place title in grid cell 2,1 */
    .industry-overview-card h3 {
      grid-column: 2;
      grid-row: 1;
      position: relative;
      z-index: 1;
      font-size: 0.9375rem;
      font-weight: 600;
      color: var(--color-text-primary);
      margin: 0;
      line-height: 1.35;
    }
    /* desc spans both columns, row 2 */
    .industry-overview-card p {
      grid-column: 1 / 3;
      grid-row: 2;
      position: relative;
      z-index: 1;
      font-size: 0.875rem;
      color: var(--color-text-secondary);
      line-height: 1.6;
      margin: 0;
    }

    /* ── Grids ──────────────────────────────────────────────────────────────── */
    .industries-overview-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
      gap: 1rem;
      margin-bottom: 1.5rem;
    }
    .industry-features-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
      gap: 1.5rem;
      margin-bottom: 2.5rem;
    }
    .industry-features-grid--three {
      grid-template-columns: repeat(3, minmax(220px, 1fr));
      max-width: 980px;
      margin-left: auto;
      margin-right: auto;
    }
    .cross-benefits-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
      gap: 1.25rem;
    }

    /* ── Cross-Benefit Cards ────────────────────────────────────────────────── */
    .cross-benefit-card {
      position: relative;
      overflow: hidden;
      border-radius: 20px;
      border: 1px solid var(--color-border);
      background: var(--color-bg-tertiary);
      padding: 1.5rem;
      display: flex;
      flex-direction: column;
      gap: 0.625rem;
      transition: transform 0.3s ease, border-color 0.3s ease;
    }
    .cross-benefit-card::before {
      content: '';
      position: absolute;
      top: 0; left: 0; right: 0;
      height: 1px;
      background: linear-gradient(90deg, transparent, rgba(255,192,0,0.65), transparent);
    }
    .cross-benefit-card::after {
      content: '';
      position: absolute;
      inset: 0;
      background: radial-gradient(ellipse 130% 55% at 50% 0%, rgba(255,192,0,0.07) 0%, transparent 65%);
      pointer-events: none;
    }
    .cross-benefit-card:hover {
      transform: translateY(-5px);
      border-color: rgba(255,192,0,0.28);
    }
    .cross-benefit-card > * { position: relative; z-index: 1; }
    .cross-benefit-icon {
      width: 2.25rem;
      height: 2.25rem;
      border-radius: 10px;
      display: flex;
      align-items: center;
      justify-content: center;
      background: var(--color-accent-soft);
      color: var(--color-accent);
      flex-shrink: 0;
    }
    .cross-benefit-icon svg { width: 20px; height: 20px; }
    .cross-benefit-card h4 {
      font-size: 0.9375rem;
      font-weight: 600;
      color: var(--color-text-primary);
      margin: 0;
    }
    .cross-benefit-card p {
      font-size: 0.8125rem;
      color: var(--color-text-secondary);
      line-height: 1.55;
      margin: 0;
    }

    /* ── Industry Feature Cards ─────────────────────────────────────────────── */
    .industry-feature-card {
      position: relative;
      overflow: hidden;
      border-radius: 16px;
      border: 1px solid var(--color-border);
      background: var(--color-bg-tertiary);
      padding: 1.5rem;
      display: flex;
      flex-direction: column;
      gap: 0.75rem;
      height: 100%;
      box-sizing: border-box;
      transition: transform 0.3s ease, border-color 0.3s ease, box-shadow 0.3s ease;
    }
    .industry-feature-card::before {
      content: '';
      position: absolute;
      top: 0; left: 0; right: 0;
      height: 1px;
      background: linear-gradient(90deg, transparent, rgba(255,192,0,0.55), transparent);
    }
    .industry-feature-card::after {
      content: '';
      position: absolute;
      inset: 0;
      background: radial-gradient(ellipse 120% 50% at 50% 0%, rgba(255,192,0,0.06) 0%, transparent 65%);
      pointer-events: none;
    }
    .industry-feature-card:hover {
      transform: translateY(-4px);
      border-color: rgba(255,192,0,0.25);
      box-shadow: 0 12px 32px rgba(255,192,0,0.06);
    }
    .industry-feature-card > * { position: relative; z-index: 1; }
    .industry-feature-card-header {
      display: flex;
      align-items: center;
      gap: 0.625rem;
    }
    .industry-feature-card-header h4 { margin: 0; }
    .industry-feature-card-icon {
      width: 1.25rem;
      height: 1.25rem;
      color: var(--color-accent);
      flex-shrink: 0;
    }
    .industry-feature-card-icon svg { width: 100%; height: 100%; }
    .industry-feature-card h4 {
      font-size: 0.9375rem;
      font-weight: 600;
      color: var(--color-text-primary);
      margin: 0;
      line-height: 1.4;
    }
    .industry-feature-card p {
      font-size: 0.875rem;
      color: var(--color-text-secondary);
      line-height: 1.65;
      margin: 0;
    }

    /* ── Stats Row ──────────────────────────────────────────────────────────── */
    .industry-stats-row {
      display: flex;
      flex-wrap: wrap;
      margin-top: 2.5rem;
      border-radius: 16px;
      border: 1px solid var(--color-border);
      background: var(--color-bg-tertiary);
      overflow: hidden;
    }
    .industry-stat {
      flex: 1;
      min-width: 140px;
      padding: 1.25rem 1.75rem;
      border-right: 1px solid var(--color-border);
      display: flex;
      flex-direction: column;
      gap: 0.375rem;
    }
    .industry-stat:last-child { border-right: none; }
    .industry-stat-value {
      font-family: var(--font-display);
      font-size: 1.875rem;
      font-weight: 500;
      color: var(--color-accent);
      letter-spacing: -0.02em;
      line-height: 1.1;
    }
    .industry-stat-label {
      font-size: 0.8125rem;
      color: var(--color-text-secondary);
      line-height: 1.45;
      max-width: 160px;
    }

    /* ── Section category pills ─────────────────────────────────────────────── */
    .section-category-badge {
      display: inline-block;
      padding: 0.3rem 0.875rem;
      border-radius: 100px;
      font-size: 0.75rem;
      font-weight: 700;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      background: rgba(255,192,0,0.1);
      color: var(--color-accent);
      border: 1px solid rgba(255,192,0,0.2);
      margin-bottom: 1.5rem;
    }
    .section-category-badge--muted {
      background: rgba(255,255,255,0.05);
      color: var(--color-text-muted);
      border-color: rgba(255,255,255,0.1);
    }

    /* ── Automotive Intro Layout ───────────────────────────────────────────── */
    .automotive-intro-layout {
      display: grid;
      grid-template-columns: minmax(0, 1fr) minmax(320px, 560px);
      align-items: start;
      column-gap: 2.25rem;
      margin-bottom: 3.5rem;
    }
    .automotive-intro-copy {
      display: flex;
      justify-content: center;
    }
    .automotive-intro-media {
      display: flex;
      justify-content: center;
      width: 100%;
    }
    .automotive-intro-image {
      width: 100%;
      max-width: 700px;
      height: auto;
      border-radius: 16px;
      box-shadow: 0 20px 60px rgba(0,0,0,0.3);
    }

    @media (max-width: 960px) {
      .automotive-intro-layout {
        grid-template-columns: 1fr;
        row-gap: 1.5rem;
      }
      .automotive-intro-copy {
        justify-content: flex-start;
      }
      .industry-features-grid--three {
        grid-template-columns: repeat(2, minmax(220px, 1fr));
      }
    }

    @media (max-width: 640px) {
      .industry-features-grid--three {
        grid-template-columns: 1fr;
      }
    }
  </style>

  <main class="min-h-screen bg-bg-primary">
    <!-- Hero -->
    <section class="pt-[5.5rem] px-8 pb-16 text-center bg-bg-secondary border-b border-border-theme relative overflow-hidden">
      <!-- radial glow -->
      <div class="absolute inset-0 bg-[radial-gradient(ellipse_80%_60%_at_50%_-10%,rgba(255,192,0,0.08)_0%,transparent_70%)] pointer-events-none"></div>
      <div class="relative z-10">
        <span class="inline-block py-[0.3rem] px-[0.875rem] rounded-full text-xs font-bold tracking-[0.1em] uppercase bg-[rgba(255,192,0,0.1)] text-accent border border-[rgba(255,192,0,0.2)] mb-6">{p.heroBadge}</span>
        <h1 class="font-[family-name:var(--font-display)] text-[clamp(2.5rem,5vw,4rem)] font-medium tracking-[-0.02em] text-text-primary m-0 mb-5">{p.heroHeadingPart1}<br><span class="text-accent">{p.heroHeadingAccent}</span> {p.heroHeadingPart2}</h1>
        <p class="text-text-secondary text-lg max-w-[600px] mx-auto leading-[1.7]">{p.heroSubtext}</p>
      </div>
    </section>

    <!-- Industries Overview -->
    <section class="py-16 px-8 bg-bg-secondary" id="industries">
      <div class="max-w-[1200px] mx-auto">
        <SectionHeader
          label={p.overviewLabel}
          heading={p.overviewHeading}
          subtext={p.overviewSubtext}
          centered={true}
          class="max-w-[600px] mb-12"
        />

        <div class="section-category-badge">{p.overviewPrimaryBadge}</div>
        <div class="industries-overview-grid">
          {p.overviewPrimary.map(({ href, iconName, title, desc }) => {
            const Icon = industryIconMap[iconName];
            return (
              <a href={href} class="industry-overview-card">
                <div class="industry-overview-icon w-9 h-9 text-accent"><Icon size={40} /></div>
                <h3 class="font-display text-base font-medium text-text-primary m-0">{title}</h3>
                <p>{desc}</p>
              </a>
            );
          })}
        </div>

        <div class="section-category-badge section-category-badge--muted mt-8">{p.overviewExpansionBadge}</div>
        <div class="industries-overview-grid">
          {p.overviewExpansion.map(({ href, iconName, title, desc }) => {
            const Icon = industryIconMap[iconName];
            return (
              <a href={href} class="industry-overview-card">
                <div class="industry-overview-icon w-9 h-9 text-accent"><Icon size={40} /></div>
                <h3 class="font-display text-base font-medium text-text-primary m-0">{title}</h3>
                <p>{desc}</p>
              </a>
            );
          })}
        </div>
      </div>
    </section>

    <!-- Automotive -->
    <section class="py-16 px-8 bg-bg-primary" id="automotive">
      <div class="max-w-[1200px] mx-auto">
        <div class="automotive-intro-layout">
          <div class="automotive-intro-copy">
            <SectionHeader
              label={p.automotiveLabel}
              heading={p.automotiveHeading}
              subtext={p.automotiveSubtext}
              class="max-w-[700px] mb-0"
            />
          </div>
          <div class="automotive-intro-media">
            <img
              src={p.automotiveImageSrc}
              alt={p.automotiveImageAlt}
              class="automotive-intro-image"
            />
          </div>
        </div>
        <div class="industry-features-grid">
          {p.automotiveCards.map(({ title, body }) => (
            <div class="industry-feature-card">
              <h4>{title}</h4>
              <p>{body}</p>
            </div>
          ))}
        </div>
        <div class="industry-stats-row">
          {p.automotiveStats.map(({ v, l }) => (
            <div class="industry-stat">
              <span class="industry-stat-value">{v}</span>
              <span class="industry-stat-label">{l}</span>
            </div>
          ))}
        </div>
      </div>
    </section>

    {p.primarySections.map((s) => (
      <section class={`py-16 px-8 ${s.bg} border-t border-border-theme`} id={s.id}>
        <div class="max-w-[1200px] mx-auto">
          <SectionHeader
            label={s.label}
            heading={s.heading}
            subtext={s.subtext}
            class="max-w-[700px] mb-10"
          />
          <div class="industry-features-grid">
            {s.cards.map(({ title, body }) => (
              <div class="industry-feature-card">
                <h4>{title}</h4>
                <p>{body}</p>
              </div>
            ))}
          </div>
          <div class="industry-stats-row">
            {s.stats.map(({ v, l }) => (
              <div class="industry-stat">
                <span class="industry-stat-value">{v}</span>
                <span class="industry-stat-label">{l}</span>
              </div>
            ))}
          </div>
        </div>
      </section>
    ))}

    {p.expansionSections.map((s) => (
      <section class={`py-16 px-8 ${s.bg} border-t border-border-theme`} id={s.id}>
        <div class="max-w-[1200px] mx-auto">
          <SectionHeader
            label={s.label}
            heading={s.heading}
            subtext={s.subtext}
            centered={true}
            class="max-w-[700px] mb-10 mx-auto"
          />
          <div class="industry-features-grid industry-features-grid--three">
            {s.cards.map(({ iconName, title, body }) => {
              const Icon = industryIconMap[iconName];
              return (
                <div class="industry-feature-card">
                  <div class="industry-feature-card-header">
                    <div class="industry-feature-card-icon"><Icon size={20} /></div>
                    <h4>{title}</h4>
                  </div>
                  <p>{body}</p>
                </div>
              );
            })}
          </div>
          <div class="text-center">
            <a href="/contact" class="inline-flex items-center mt-8 py-3 px-7 bg-accent text-black font-semibold text-[0.9375rem] rounded-lg no-underline transition-colors duration-200 hover:opacity-90">{s.ctaText}</a>
          </div>
        </div>
      </section>
    ))}

    <!-- Cross-Industry Benefits -->
    <section class="py-16 px-8 bg-bg-secondary border-t border-border-theme" id="benefits">
      <div class="max-w-[1200px] mx-auto">
        <SectionHeader
          label={p.crossBenefitsLabel}
          heading={p.crossBenefitsHeading}
          subtext={p.crossBenefitsSubtext}
          centered={true}
          class="max-w-[540px] mb-12"
        />
        <div class="cross-benefits-grid">
          {p.crossBenefits.map(({ iconName, title, desc }) => {
            const Icon = industryIconMap[iconName];
            return (
              <div class="cross-benefit-card">
                <div class="cross-benefit-icon"><Icon size={20} /></div>
                <h4>{title}</h4>
                <p>{desc}</p>
              </div>
            );
          })}
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="py-20 px-8 text-center bg-bg-primary border-t border-border-theme relative overflow-hidden" id="demo">
      <div class="absolute inset-0 bg-[radial-gradient(ellipse_70%_55%_at_50%_100%,rgba(255,192,0,0.07)_0%,transparent_70%)] pointer-events-none"></div>
      <div class="relative z-10 max-w-[600px] mx-auto">
        <span class="inline-block py-[0.3rem] px-[0.875rem] rounded-full text-xs font-bold tracking-[0.1em] uppercase bg-[rgba(255,192,0,0.1)] text-accent border border-[rgba(255,192,0,0.2)] mb-6">{p.ctaBadge}</span>
        <h2 class="font-[family-name:var(--font-display)] text-[clamp(1.75rem,3vw,2.5rem)] font-medium tracking-[-0.02em] text-text-primary m-0 mb-4">{p.ctaHeading}</h2>
        <p class="text-text-secondary text-[1.0625rem] mx-auto mb-8 leading-[1.7]">{p.ctaBody}</p>
        <a href="/contact" class="inline-flex items-center gap-2 py-[0.875rem] px-8 bg-accent text-black font-bold text-[0.9375rem] rounded-[10px] no-underline transition-opacity duration-200 tracking-[0.01em] hover:opacity-90">{p.ctaButtonText}</a>
      </div>
    </section>
  </main>
</BaseLayout>
