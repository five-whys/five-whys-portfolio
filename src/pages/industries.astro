---
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionHeader from '../components/ui/SectionHeader.astro';
import {
  Zap, Wrench, Building2, Monitor, Activity, Home, Briefcase,
  Boxes, Globe, ShoppingCart, MessageSquare, BarChart3, Clock,
  Bell, Users, BookOpen, Shield, Settings,
} from 'lucide-astro';

// ── Overview grids ─────────────────────────────────────────────────────────
const overviewPrimary = [
  { href: '#automotive',          Icon: Zap,          title: 'Automotive, Mobility & Transportation',  desc: 'Revolutionize the entire ownership journey from consideration to second purchase.' },
  { href: '#commercial-vehicles', Icon: Wrench,       title: 'Commercial & Industrial Vehicles',        desc: 'Keep fleets running with autonomous AI support for diagnostics, maintenance, and operations.' },
  { href: '#industrial',          Icon: Building2,    title: 'Industrial Appliances & Machineries',     desc: 'Maximize asset utilization with real-time operator support and maintenance guidance.' },
  { href: '#electronics',         Icon: Monitor,      title: 'Consumer Appliances',                     desc: 'Turn unboxing into brand loyalty with feature discovery and personalized guidance.' },
  { href: '#healthcare',          Icon: Activity,     title: 'Healthcare',                              desc: 'Provide always-on, personalized care while managing costs and compliance.' },
];
const overviewExpansion = [
  { href: '#property',       Icon: Home,         title: 'Buildings & Property Units', desc: 'Intelligent engagement for property occupants, tenants, and buyers.' },
  { href: '#financial',      Icon: Briefcase,    title: 'Financial Services',          desc: 'Build stronger relationships with immediate, personalized, and secure interactions.' },
  { href: '#energy',         Icon: Zap,          title: 'Energy & Utilities',          desc: 'Modernize customer engagement with proactive insights and automated support.' },
  { href: '#hospitality',    Icon: Globe,        title: 'Hospitality & Travel',        desc: 'Elevate the guest experience from booking to checkout with AI concierge.' },
  { href: '#consumer-goods', Icon: ShoppingCart, title: 'Consumer Goods',              desc: 'Own the direct-to-consumer relationship and drive repeat purchases.' },
];

// ── Industry feature cards (no icons) ──────────────────────────────────────
const automotiveCards = [
  { title: 'Vehicle Configuration & Discovery', body: 'Help customers explore models, compare trims, understand features, and configure their perfect vehicle through natural conversation.' },
  { title: 'Ownership Onboarding',              body: 'Proactively introduce features, explain controls, and personalize the ownership experience from day one—reducing "how-to" support calls.' },
  { title: 'Service & Maintenance',             body: 'Schedule service appointments, explain maintenance alerts, guide troubleshooting, and integrate with DMS systems for seamless experience.' },
  { title: 'Feature Discovery',                 body: 'Most owners never discover half the features they paid for. GLUCOSE contextually introduces features based on usage patterns and preferences.' },
];
const healthcareCards = [
  { title: 'Medical Device Education',   body: 'Guide patients through device setup, usage instructions, and ongoing support for complex medical equipment—from glucose monitors to CPAP machines.' },
  { title: 'Treatment Journey Support',  body: 'Proactive reminders, medication guidance, and personalized health information throughout the patient journey—with full compliance controls.' },
  { title: 'Appointment Management',     body: 'Schedule, reschedule, and provide pre-appointment instructions through natural conversation across messaging platforms.' },
  { title: 'Compliance & Guardrails',    body: 'Built-in IGDs (Instructions & Guidelines Documents) ensure GLUCOSE operates within strict healthcare compliance requirements.' },
];
const appliancesCards = [
  { title: 'Product Onboarding',                   body: 'Guide users through setup, initial configuration, and first-use experiences for smart home devices, appliances, and electronics.' },
  { title: 'Feature Education',                     body: 'Contextually introduce advanced features based on user behavior and preferences—turning casual users into power users.' },
  { title: 'Troubleshooting & Support',             body: 'Instant, 24/7 troubleshooting through natural conversation—reducing support ticket volume while improving customer satisfaction.' },
  { title: 'Accessory & Upgrade Recommendations',  body: 'Contextual recommendations for compatible accessories, software updates, and product upgrades based on usage patterns.' },
];
const financialCards = [
  { title: 'Product Recommendations', body: 'Provide personalized guidance to help customers choose the best financial products for their needs—increasing acquisition and cross-sell rates.' },
  { title: 'Account Support',         body: 'Respond immediately to questions about account balances, fees, transactions, and policies—boosting customer trust and satisfaction.' },
  { title: 'Life-Stage Engagement',   body: 'Proactively engage customers during major life events—home buying, retirement planning, education funding—with contextual product information.' },
  { title: 'Security & Compliance',   body: 'Enterprise-grade security with encrypted data, compliance guardrails, and audit logging for regulated financial services.' },
];
const retailCards = [
  { title: 'Product Discovery',         body: 'Help shoppers find the perfect product through conversational commerce—understanding needs and recommending solutions.' },
  { title: 'Order Support',             body: 'Track orders, handle returns, process exchanges, and resolve issues instantly through natural conversation.' },
  { title: 'Product Usage Guidance',    body: 'Provide ongoing support for complex products—assembly instructions, care guides, usage tips, and troubleshooting.' },
  { title: 'Loyalty & Re-engagement',  body: 'Personalized recommendations, reorder reminders, and loyalty program engagement to drive repeat purchases.' },
];
const industrialCards = [
  { title: 'Operator Training',   body: 'On-demand guidance for equipment operation, safety procedures, and best practices—reducing training time and errors.' },
  { title: 'Maintenance Support', body: 'Proactive maintenance reminders, troubleshooting assistance, and service scheduling integrated with your systems.' },
  { title: 'IoT Integration',     body: 'Connect GLUCOSE to IoT sensors for context-aware support—responding to equipment alerts with relevant guidance.' },
  { title: 'Documentation Access', body: 'Instant access to manuals, specifications, and procedures through natural conversation—no more searching through binders.' },
];

// ── Industry feature cards (with icons, 3-col) ─────────────────────────────
const commercialCards = [
  { Icon: Wrench,       title: 'Predictive Maintenance',      body: 'AI agents that alert operators before breakdowns, schedule service, and coordinate parts availability.' },
  { Icon: MessageSquare, title: 'Driver & Operator Support',  body: '24/7 multimodal assistance for vehicle operation, troubleshooting, and compliance documentation.' },
  { Icon: BarChart3,    title: 'Fleet Analytics',             body: 'Capture first-party data on usage patterns, common issues, and operator needs across your entire fleet.' },
];
const propertyCards = [
  { Icon: Boxes,   title: 'Tenant Support',              body: 'Autonomous handling of maintenance requests, facility bookings, and community communications.' },
  { Icon: Home,    title: 'Property Sales',              body: 'Qualify leads, schedule viewings, and guide prospective buyers through property features via WhatsApp and chat.' },
  { Icon: Clock,   title: 'Smart Building Integration',  body: 'Connect to IoT systems for real-time facility management, energy monitoring, and occupant notifications.' },
];
const energyCards = [
  { Icon: Zap,      title: 'Usage & Billing Support',   body: 'Autonomous agents that explain bills, compare plans, and process account changes instantly.' },
  { Icon: Bell,     title: 'Proactive Notifications',   body: 'Alert customers about outages, maintenance windows, and consumption anomalies before they contact you.' },
  { Icon: Activity, title: 'Demand Response',           body: 'Engage customers in energy-saving programs through intelligent, personalized communication campaigns.' },
];
const hospitalityCards = [
  { Icon: MessageSquare, title: 'AI Concierge',            body: 'Autonomous guest support for bookings, room service, local recommendations, and special requests.' },
  { Icon: Globe,         title: 'Multilingual Engagement', body: 'Serve international guests in 50+ languages across WhatsApp, LINE, and other regional channels.' },
  { Icon: Users,         title: 'Loyalty & Upsell',        body: 'Proactively engage guests with personalized upgrade offers, loyalty rewards, and post-stay follow-ups.' },
];
const consumerGoodsCards = [
  { Icon: BookOpen,  title: 'Product Education',   body: 'Guide consumers through product features, usage tips, and care instructions via conversational AI.' },
  { Icon: BarChart3, title: 'Consumer Insights',   body: 'Capture first-party data on preferences, feedback, and purchase intent directly from conversations.' },
  { Icon: Bell,      title: 'Lifecycle Engagement', body: 'Proactive re-engagement for refills, upgrades, and loyalty programs — building long-term brand relationships.' },
];

// ── Stats rows ─────────────────────────────────────────────────────────────
const automotiveStats   = [{ v: '50%+', l: 'of vehicle features go unused by owners' }, { v: '24/7', l: 'support without call center overhead' }, { v: '50+', l: 'languages for global deployment' }];
const healthcareStats   = [{ v: 'Always-On', l: 'patient support outside office hours' }, { v: 'Compliant', l: 'with healthcare regulations' }, { v: 'Multimodal', l: 'text, voice, images for accessibility' }];
const appliancesStats   = [{ v: 'Reduced', l: 'support ticket volume' }, { v: 'Increased', l: 'feature adoption rates' }, { v: 'Higher', l: 'customer lifetime value' }];
const financialStats    = [{ v: 'Secure', l: 'enterprise-grade encryption' }, { v: 'Compliant', l: 'with financial regulations' }, { v: 'Immediate', l: 'personalized responses' }];
const retailStats       = [{ v: 'Increased', l: 'conversion rates' }, { v: 'Reduced', l: 'return and exchange rates' }, { v: 'Higher', l: 'repeat purchase rates' }];
const industrialStats   = [{ v: 'Minimized', l: 'equipment downtime' }, { v: 'Improved', l: 'safety compliance' }, { v: 'Enhanced', l: 'operator efficiency' }];

// ── Cross-industry benefits ────────────────────────────────────────────────
const crossBenefits = [
  { Icon: Globe,        title: 'Multilingual',          desc: '50+ languages for global deployment' },
  { Icon: Monitor,      title: 'Multimodal',            desc: 'Text, voice, images, and video' },
  { Icon: MessageSquare, title: 'Omnichannel',          desc: 'WhatsApp, Telegram, Line, Viber, and more' },
  { Icon: Shield,       title: 'Enterprise Security',   desc: 'AWS-powered, encrypted, compliant' },
  { Icon: Activity,     title: 'Analytics',             desc: 'First-party data and contextual insights' },
  { Icon: Settings,     title: 'No-Code Management',    desc: 'Configure without technical expertise' },
];
---

<BaseLayout
  title="AI Customer Engagement for Automotive, Healthcare & Retail | 5.Y"
  description="GLUCOSE AI agents for automotive, healthcare, retail, and consumer electronics. WhatsApp chatbots, voice AI, and multi-channel customer engagement solutions."
  canonicalUrl="https://www.five-whys.com/industries"
  activeNav="industries"
>
  <style>
    /* ── Industry Overview Cards ────────────────────────────────────────────── */
    .industry-overview-card {
      position: relative;
      overflow: hidden;
      border-radius: 20px;
      border: 1px solid var(--color-border);
      background: var(--color-bg-tertiary);
      padding: 1.5rem;
      text-decoration: none;
      color: var(--color-text-primary);
      /* CSS grid: icon col | title col, desc spans full width */
      display: grid;
      grid-template-columns: 36px 1fr;
      grid-template-rows: auto auto;
      column-gap: 0.75rem;
      row-gap: 0.625rem;
      align-items: center;
      transition: transform 0.3s ease, border-color 0.3s ease, box-shadow 0.3s ease;
    }
    /* gold top-edge line */
    .industry-overview-card::before {
      content: '';
      position: absolute;
      top: 0; left: 0; right: 0;
      height: 1px;
      background: linear-gradient(90deg, transparent, rgba(255,192,0,0.65), transparent);
    }
    /* radial glow from top */
    .industry-overview-card::after {
      content: '';
      position: absolute;
      inset: 0;
      background: radial-gradient(ellipse 130% 55% at 50% 0%, rgba(255,192,0,0.07) 0%, transparent 65%);
      pointer-events: none;
    }
    .industry-overview-card:hover {
      transform: translateY(-5px);
      border-color: rgba(255,192,0,0.28);
      box-shadow: 0 16px 36px rgba(255,192,0,0.06);
    }
    /* place icon in grid cell 1,1 */
    .industry-overview-icon {
      grid-column: 1;
      grid-row: 1;
      align-self: center;
      position: relative;
      z-index: 1;
    }
    .industry-overview-icon svg { width: 100%; height: 100%; }
    /* place title in grid cell 2,1 */
    .industry-overview-card h3 {
      grid-column: 2;
      grid-row: 1;
      position: relative;
      z-index: 1;
      font-size: 0.9375rem;
      font-weight: 600;
      color: var(--color-text-primary);
      margin: 0;
      line-height: 1.35;
    }
    /* desc spans both columns, row 2 */
    .industry-overview-card p {
      grid-column: 1 / 3;
      grid-row: 2;
      position: relative;
      z-index: 1;
      font-size: 0.875rem;
      color: var(--color-text-secondary);
      line-height: 1.6;
      margin: 0;
    }

    /* ── Grids ──────────────────────────────────────────────────────────────── */
    .industries-overview-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
      gap: 1rem;
      margin-bottom: 1.5rem;
    }
    .industry-features-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
      gap: 1.5rem;
      margin-bottom: 2.5rem;
    }
    .industry-features-grid--three {
      grid-template-columns: repeat(3, minmax(220px, 1fr));
      max-width: 980px;
      margin-left: auto;
      margin-right: auto;
    }
    .cross-benefits-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
      gap: 1.25rem;
    }

    /* ── Cross-Benefit Cards ────────────────────────────────────────────────── */
    .cross-benefit-card {
      position: relative;
      overflow: hidden;
      border-radius: 20px;
      border: 1px solid var(--color-border);
      background: var(--color-bg-tertiary);
      padding: 1.5rem;
      display: flex;
      flex-direction: column;
      gap: 0.625rem;
      transition: transform 0.3s ease, border-color 0.3s ease;
    }
    .cross-benefit-card::before {
      content: '';
      position: absolute;
      top: 0; left: 0; right: 0;
      height: 1px;
      background: linear-gradient(90deg, transparent, rgba(255,192,0,0.65), transparent);
    }
    .cross-benefit-card::after {
      content: '';
      position: absolute;
      inset: 0;
      background: radial-gradient(ellipse 130% 55% at 50% 0%, rgba(255,192,0,0.07) 0%, transparent 65%);
      pointer-events: none;
    }
    .cross-benefit-card:hover {
      transform: translateY(-5px);
      border-color: rgba(255,192,0,0.28);
    }
    .cross-benefit-card > * { position: relative; z-index: 1; }
    .cross-benefit-icon {
      width: 2.25rem;
      height: 2.25rem;
      border-radius: 10px;
      display: flex;
      align-items: center;
      justify-content: center;
      background: var(--color-accent-soft);
      color: var(--color-accent);
      flex-shrink: 0;
    }
    .cross-benefit-icon svg { width: 20px; height: 20px; }
    .cross-benefit-card h4 {
      font-size: 0.9375rem;
      font-weight: 600;
      color: var(--color-text-primary);
      margin: 0;
    }
    .cross-benefit-card p {
      font-size: 0.8125rem;
      color: var(--color-text-secondary);
      line-height: 1.55;
      margin: 0;
    }

    /* ── Industry Feature Cards ─────────────────────────────────────────────── */
    .industry-feature-card {
      position: relative;
      overflow: hidden;
      border-radius: 16px;
      border: 1px solid var(--color-border);
      background: var(--color-bg-tertiary);
      padding: 1.5rem;
      display: flex;
      flex-direction: column;
      gap: 0.75rem;
      height: 100%;
      box-sizing: border-box;
      transition: transform 0.3s ease, border-color 0.3s ease, box-shadow 0.3s ease;
    }
    .industry-feature-card::before {
      content: '';
      position: absolute;
      top: 0; left: 0; right: 0;
      height: 1px;
      background: linear-gradient(90deg, transparent, rgba(255,192,0,0.55), transparent);
    }
    .industry-feature-card::after {
      content: '';
      position: absolute;
      inset: 0;
      background: radial-gradient(ellipse 120% 50% at 50% 0%, rgba(255,192,0,0.06) 0%, transparent 65%);
      pointer-events: none;
    }
    .industry-feature-card:hover {
      transform: translateY(-4px);
      border-color: rgba(255,192,0,0.25);
      box-shadow: 0 12px 32px rgba(255,192,0,0.06);
    }
    .industry-feature-card > * { position: relative; z-index: 1; }
    .industry-feature-card-header {
      display: flex;
      align-items: center;
      gap: 0.625rem;
    }
    .industry-feature-card-header h4 { margin: 0; }
    .industry-feature-card-icon {
      width: 1.25rem;
      height: 1.25rem;
      color: var(--color-accent);
      flex-shrink: 0;
    }
    .industry-feature-card-icon svg { width: 100%; height: 100%; }
    .industry-feature-card h4 {
      font-size: 0.9375rem;
      font-weight: 600;
      color: var(--color-text-primary);
      margin: 0;
      line-height: 1.4;
    }
    .industry-feature-card p {
      font-size: 0.875rem;
      color: var(--color-text-secondary);
      line-height: 1.65;
      margin: 0;
    }

    /* ── Stats Row ──────────────────────────────────────────────────────────── */
    .industry-stats-row {
      display: flex;
      flex-wrap: wrap;
      margin-top: 2.5rem;
      border-radius: 16px;
      border: 1px solid var(--color-border);
      background: var(--color-bg-tertiary);
      overflow: hidden;
    }
    .industry-stat {
      flex: 1;
      min-width: 140px;
      padding: 1.25rem 1.75rem;
      border-right: 1px solid var(--color-border);
      display: flex;
      flex-direction: column;
      gap: 0.375rem;
    }
    .industry-stat:last-child { border-right: none; }
    .industry-stat-value {
      font-family: var(--font-display);
      font-size: 1.875rem;
      font-weight: 500;
      color: var(--color-accent);
      letter-spacing: -0.02em;
      line-height: 1.1;
    }
    .industry-stat-label {
      font-size: 0.8125rem;
      color: var(--color-text-secondary);
      line-height: 1.45;
      max-width: 160px;
    }

    /* ── Section category pills ─────────────────────────────────────────────── */
    .section-category-badge {
      display: inline-block;
      padding: 0.3rem 0.875rem;
      border-radius: 100px;
      font-size: 0.75rem;
      font-weight: 700;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      background: rgba(255,192,0,0.1);
      color: var(--color-accent);
      border: 1px solid rgba(255,192,0,0.2);
      margin-bottom: 1.5rem;
    }
    .section-category-badge--muted {
      background: rgba(255,255,255,0.05);
      color: var(--color-text-muted);
      border-color: rgba(255,255,255,0.1);
    }

    /* ── Automotive Intro Layout ───────────────────────────────────────────── */
    .automotive-intro-layout {
      display: grid;
      grid-template-columns: minmax(0, 1fr) minmax(320px, 560px);
      align-items: start;
      column-gap: 2.25rem;
      margin-bottom: 3.5rem;
    }
    .automotive-intro-copy {
      display: flex;
      justify-content: center;
    }
    .automotive-intro-media {
      display: flex;
      justify-content: center;
      width: 100%;
    }
    .automotive-intro-image {
      width: 100%;
      max-width: 700px;
      height: auto;
      border-radius: 16px;
      box-shadow: 0 20px 60px rgba(0,0,0,0.3);
    }

    @media (max-width: 960px) {
      .automotive-intro-layout {
        grid-template-columns: 1fr;
        row-gap: 1.5rem;
      }
      .automotive-intro-copy {
        justify-content: flex-start;
      }
      .industry-features-grid--three {
        grid-template-columns: repeat(2, minmax(220px, 1fr));
      }
    }

    @media (max-width: 640px) {
      .industry-features-grid--three {
        grid-template-columns: 1fr;
      }
    }
  </style>

  <main class="min-h-screen bg-bg-primary">
    <!-- Hero -->
    <section class="pt-[5.5rem] px-8 pb-16 text-center bg-bg-secondary border-b border-border-theme relative overflow-hidden">
      <!-- radial glow -->
      <div class="absolute inset-0 bg-[radial-gradient(ellipse_80%_60%_at_50%_-10%,rgba(255,192,0,0.08)_0%,transparent_70%)] pointer-events-none"></div>
      <div class="relative z-10">
        <span class="inline-block py-[0.3rem] px-[0.875rem] rounded-full text-xs font-bold tracking-[0.1em] uppercase bg-[rgba(255,192,0,0.1)] text-accent border border-[rgba(255,192,0,0.2)] mb-6">Industries</span>
        <h1 class="font-[family-name:var(--font-display)] text-[clamp(2.5rem,5vw,4rem)] font-medium tracking-[-0.02em] text-text-primary m-0 mb-5">Your AI Agent for<br><span class="text-accent">Industry Leading</span> Experiences</h1>
        <p class="text-text-secondary text-lg max-w-[600px] mx-auto leading-[1.7]">A new way to delight and support your customers, users, and operators across automotive, healthcare, consumer electronics, and beyond.</p>
      </div>
    </section>

    <!-- Industries Overview -->
    <section class="py-16 px-8 bg-bg-secondary" id="industries">
      <div class="max-w-[1200px] mx-auto">
        <SectionHeader
          label="Industries"
          heading="Complex products. Engaging journeys.<br/>One platform."
          subtext="GLUCOSE is built for industries where customer engagement is hard: high intermediation, product complexity, education requirements, and economics that break traditional CRM."
          centered={true}
          class="max-w-[600px] mb-12"
        />

        <div class="section-category-badge">Where We Win First</div>
        <div class="industries-overview-grid">
          {overviewPrimary.map(({ href, Icon, title, desc }) => (
            <a href={href} class="industry-overview-card">
              <div class="industry-overview-icon w-9 h-9 text-accent"><Icon size={40} /></div>
              <h3 class="font-display text-base font-medium text-text-primary m-0">{title}</h3>
              <p>{desc}</p>
            </a>
          ))}
        </div>

        <div class="section-category-badge section-category-badge--muted mt-8">Expansion Verticals</div>
        <div class="industries-overview-grid">
          {overviewExpansion.map(({ href, Icon, title, desc }) => (
            <a href={href} class="industry-overview-card">
              <div class="industry-overview-icon w-9 h-9 text-accent"><Icon size={40} /></div>
              <h3 class="font-display text-base font-medium text-text-primary m-0">{title}</h3>
              <p>{desc}</p>
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- Automotive -->
    <section class="py-16 px-8 bg-bg-primary" id="automotive">
      <div class="max-w-[1200px] mx-auto">
        <div class="automotive-intro-layout">
          <div class="automotive-intro-copy">
            <SectionHeader
              label="Automotive & Mobility"
              heading="Transform the entire ownership journey"
              subtext="From first consideration to second purchase, GLUCOSE engages customers at every touchpoint—discovery, configuration, ownership education, maintenance, feature discovery, and trade-in engagement."
              class="max-w-[700px] mb-0"
            />
          </div>
          <div class="automotive-intro-media">
            <img
              src="/Images/glucose-automotive-usecase.jpg"
              alt="GLUCOSE helping diagnose car warning light via WhatsApp"
              class="automotive-intro-image"
            />
          </div>
        </div>
        <div class="industry-features-grid">
          {automotiveCards.map(({ title, body }) => (
            <div class="industry-feature-card">
              <h4>{title}</h4>
              <p>{body}</p>
            </div>
          ))}
        </div>
        <div class="industry-stats-row">
          {automotiveStats.map(({ v, l }) => (
            <div class="industry-stat">
              <span class="industry-stat-value">{v}</span>
              <span class="industry-stat-label">{l}</span>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Healthcare -->
    <section class="py-16 px-8 bg-bg-secondary border-t border-border-theme" id="healthcare">
      <div class="max-w-[1200px] mx-auto">
        <SectionHeader
          label="Healthcare"
          heading="Personalized care that scales"
          subtext="Patient engagement that respects complexity. Personalized guidance while maintaining compliance. Amplifying clinician reach, not replacing them."
          class="max-w-[700px] mb-10"
        />
        <div class="industry-features-grid">
          {healthcareCards.map(({ title, body }) => (
            <div class="industry-feature-card">
              <h4>{title}</h4>
              <p>{body}</p>
            </div>
          ))}
        </div>
        <div class="industry-stats-row">
          {healthcareStats.map(({ v, l }) => (
            <div class="industry-stat">
              <span class="industry-stat-value">{v}</span>
              <span class="industry-stat-label">{l}</span>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Consumer Appliances -->
    <section class="py-16 px-8 bg-bg-primary border-t border-border-theme" id="electronics">
      <div class="max-w-[1200px] mx-auto">
        <SectionHeader
          label="Consumer Appliances"
          heading="Turn unboxing into brand loyalty"
