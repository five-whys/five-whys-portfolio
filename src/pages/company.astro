---
import BaseLayout from '../layouts/BaseLayout.astro';
import TeamGrid from '../components/sections/TeamGrid.astro';
import VisionCards from '../components/sections/VisionCards.astro';
import ValuesAccordion from '../components/sections/ValuesAccordion.astro';
import { teamMembers, visionCards, values, companyStats, offices } from '../data/company';
---

<BaseLayout
  title="About 5.Y - The Company Behind GLUCOSE AI"
  description="Learn about 5.Y, the company building GLUCOSE - the enterprise agentic AI platform. Meet our team and discover our mission to transform customer engagement."
  keywords="5.Y company, Five Whys, GLUCOSE AI company, agentic AI startup, enterprise AI company, customer engagement AI company"
  canonicalUrl="https://www.five-whys.com/company"
  ogTitle="About 5.Y - The Company Behind GLUCOSE AI"
  ogDescription="Meet the team building GLUCOSE - the enterprise agentic AI platform."
  ogImage="https://www.five-whys.com/Images/og-image.png"
  twitterTitle="About 5.Y | Company"
  twitterDescription="The company behind GLUCOSE agentic AI."
  activeNav="company"
>
  <!-- Hero About -->
  <section class="pt-[6rem] px-8 pb-16 bg-[linear-gradient(180deg,var(--color-bg-secondary)_0%,var(--color-bg-primary)_100%)] border-b border-border-theme font-[family-name:var(--font-primary)]">
    <div class="max-w-[1100px] mx-auto">
      <div class="text-center max-w-[760px] mx-auto mb-10">
        <span class="inline-block mb-3 text-[0.75rem] font-semibold uppercase tracking-[0.12em] text-accent">About 5.Y</span>
        <h1 class="font-[family-name:var(--font-display)] text-[clamp(2.2rem,5vw,4rem)] font-medium leading-[1.1] tracking-[-0.02em] mb-4">Who we are and why we're here</h1>
        <p class="text-text-secondary text-[clamp(1rem,1.8vw,1.2rem)] leading-[1.7]">We build autonomous AI experiences that help enterprises engage every customer in every moment that matters.</p>
      </div>

      <div class="border border-border-theme rounded-[20px] overflow-hidden shadow-[0_20px_60px_rgba(0,0,0,0.18)] max-h-[min(68vh,620px)]">
        <img src="/Images/about.jpg" alt="5.Y Team" class="w-full h-full min-h-[340px] object-cover object-center" />
      </div>
    </div>
  </section>

  <!-- Mission -->
  <section class="py-20 px-8 bg-bg-secondary font-[family-name:var(--font-primary)]">
    <div class="max-w-[900px] mx-auto text-center">
      <h2 class="font-[family-name:var(--font-display)] text-[clamp(1.75rem,3vw,2.5rem)] font-medium leading-[1.3] tracking-[-0.02em] mb-6">5.Y helps enterprises run autonomous brand and product experiences that reach every customer, in every moment that matters.</h2>
      <p class="text-text-secondary text-lg leading-[1.7]">By partnering with industry leaders in automotive, healthcare, consumer electronics, and financial services, we're transforming customer engagement with AI that acts, not just responds—delivering measurable business impact at scale.</p>
    </div>
  </section>

  <!-- Values Accordion -->
  <ValuesAccordion values={values} />

  <!-- Team Grid -->
  <TeamGrid
    heading="Our founders &amp; Team"
    subtext="5.Y was founded by a team of industry veterans who saw the opportunity to transform how enterprises engage with customers through autonomous AI."
    members={teamMembers}
  />

  <!-- Vision Cards -->
  <VisionCards
    label="Our Vision"
    heading="The brand that shows up, wins."
    cards={visionCards}
  />

  <!-- About / Stats / Locations -->
  <section id="about" class="py-16 px-8 bg-bg-secondary font-[family-name:var(--font-primary)]">
    <div class="max-w-[1200px] mx-auto">
      <div class="text-center mb-12">
        <span class="text-[0.75rem] font-semibold uppercase tracking-[0.15em] text-accent">The Company</span>
        <h2 class="font-[family-name:var(--font-display)] text-[clamp(1.75rem,3vw,2.5rem)] font-medium tracking-[-0.02em] mt-2 mb-4">Building the future of customer engagement.</h2>
        <p class="text-text-secondary text-[1.0625rem] max-w-[600px] mx-auto">5.Y is an agentic AI company building GLUCOSE—the platform that enables enterprises to run autonomous brand and product experiences.</p>
      </div>

      <!-- Stats -->
      <div class="grid grid-cols-4 gap-6 mb-12">
        {companyStats.map((stat) => (
          <div class="bg-bg-primary border border-border-theme rounded-[16px] p-8 text-center">
            <div class="font-[family-name:var(--font-display)] text-[2.5rem] font-medium text-accent mb-2">{stat.value}</div>
            <div class="text-sm text-text-secondary uppercase tracking-[0.1em]">{stat.label}</div>
          </div>
        ))}
      </div>

      <!-- Locations -->
      <div class="grid grid-cols-2 gap-8">
        <div>
          <h3 class="text-[1.25rem] font-semibold text-text-primary mb-4">Global Presence</h3>
          <p class="text-text-secondary leading-[1.7] mb-4">With our headquarters in Singapore and a representative office in Seattle, we're building a global platform for autonomous customer engagement.</p>
          <p class="text-text-secondary leading-[1.7]">We chose Singapore for its position at the crossroads of global commerce, and Seattle for access to world-class AI talent and proximity to leading technology enterprises.</p>
        </div>
        <div class="flex flex-col gap-4">
          {offices.map((office) => (
            <div class="bg-bg-primary border border-border-theme rounded-[12px] p-6">
              <div class="flex items-center gap-3 mb-3">
                <div class="w-9 h-9 rounded-[8px] bg-accent-soft flex items-center justify-center text-accent">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="18" height="18"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path><circle cx="12" cy="10" r="3"></circle></svg>
                </div>
                <h4 class="font-semibold text-text-primary">{office.name}</h4>
              </div>
              <p class="text-text-secondary text-[0.9375rem] leading-[1.7]" set:html={office.address.replace(/\n/g, '<br />')}></p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section id="demo" class="bg-bg-primary border-t border-border-theme py-20 px-8 text-center font-[family-name:var(--font-primary)]">
    <h2 class="font-[family-name:var(--font-display)] text-[clamp(2rem,4vw,3rem)] font-medium tracking-[-0.02em] mb-4">See what GLUCOSE can do for you</h2>
    <p class="text-text-secondary text-lg max-w-[600px] mx-auto mb-8">Discover how GLUCOSE can help your enterprise run autonomous brand experiences that reach every customer, in every moment that matters.</p>
    <a href="/contact" class="inline-flex items-center justify-center gap-2 font-[family-name:var(--font-primary)] text-[0.9375rem] font-medium no-underline rounded-pill bg-accent text-bg-primary py-[0.875rem] px-7 transition-all duration-300">Request Demo</a>
  </section>
</BaseLayout>
