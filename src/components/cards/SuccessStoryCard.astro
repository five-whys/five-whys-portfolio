---
interface Props {
  href: string;
  imageSrc: string;
  imageAlt: string;
  brand: string;
  title: string;
  body: string;
}

const { href, imageSrc, imageAlt, brand, title, body } = Astro.props;
---

<a href={href} class="story-card bg-bg-primary border border-border-theme rounded-[12px] overflow-hidden no-underline text-inherit transition-all duration-300 ease-[cubic-bezier(0.4,0,0.2,1)]">
  <img src={imageSrc} alt={imageAlt} class="w-full h-[180px] object-cover" />
  <div class="p-5">
    <span class="text-[0.6875rem] font-semibold text-accent uppercase tracking-[0.12em]">{brand}</span>
    <h3 class="text-base font-semibold text-text-primary my-2 leading-[1.4]">{title}</h3>
    <p class="text-sm text-text-secondary leading-[1.6]">{body}</p>
  </div>
</a>

<style>
  .story-card:hover {
    transform: translateY(-2px);
    border-color: var(--color-accent);
  }
</style>
