---
import { Settings } from 'lucide-astro';

interface Props {
  name: string;
  desc: string;
  badge: 'connected' | 'available';
  iconHtml: string;
}

const { name, desc, badge, iconHtml } = Astro.props;
---

<div class="bg-bg-primary p-5 relative flex flex-col gap-3">
  <span class={badge === 'connected'
    ? 'absolute top-3 right-3 text-[0.6875rem] font-semibold py-[0.2rem] px-[0.6rem] rounded-full bg-[rgba(34,197,94,0.15)] text-[#22c55e]'
    : 'absolute top-3 right-3 text-[0.6875rem] font-semibold py-[0.2rem] px-[0.6rem] rounded-full bg-bg-tertiary text-text-muted'
  }>{badge === 'connected' ? 'Connected' : 'Connect'}</span>
  <div class="flex gap-3 items-start">
    <div class="w-8 h-8 shrink-0 [&_svg]:w-full [&_svg]:h-full [&_img]:w-full [&_img]:h-full" set:html={iconHtml} />
    <div>
      <div class="text-[0.9375rem] font-semibold text-text-primary mb-1">{name}</div>
      <div class="text-[0.8125rem] text-text-secondary leading-[1.4]">{desc}</div>
    </div>
  </div>
  <div class="flex items-center justify-between pt-2 border-t border-border-theme">
    {badge === 'connected' ? (
      <>
        <span class="text-[0.8125rem] font-medium text-accent">Configure</span>
        <Settings class="w-4 h-4 stroke-text-muted" size={16} />
      </>
    ) : (
      <span class="text-[0.8125rem] font-medium py-1 px-3 bg-bg-tertiary rounded text-text-secondary">Connect</span>
    )}
  </div>
</div>
