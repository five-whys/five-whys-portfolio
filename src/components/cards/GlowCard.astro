---
interface Props {
  title: string;
  body: string;
  iconSVG?: string;
  variant?: 'gold' | 'teal';
}

const { title, body, iconSVG, variant = 'gold' } = Astro.props;
---

<div class={`glow-card glow-card-${variant}`}>
  <div class="glow-card-circle">
    {iconSVG
      ? <span class="glow-card-icon" set:html={iconSVG} />
      : <span class="glow-card-icon"><slot name="icon" /></span>
    }
  </div>
  <h4 class="glow-card-title">{title}</h4>
  <p class="glow-card-body">{body}</p>
</div>

<style>
  .glow-card {
    position: relative;
    overflow: hidden;
    border-radius: 24px;
    background: var(--color-bg-tertiary);
    border: 1px solid var(--color-border);
    padding: 2.5rem 1.75rem 2rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    transition: transform 0.3s ease, border-color 0.3s ease, box-shadow 0.3s ease;
  }

  /* radial background glow from icon area */
  .glow-card::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0; height: 60%;
    pointer-events: none;
  }
  .glow-card-gold::before {
    background: radial-gradient(ellipse 90% 80% at 50% 5%, rgba(255,192,0,0.11) 0%, transparent 70%);
  }
  .glow-card-teal::before {
    background: radial-gradient(ellipse 90% 80% at 50% 5%, rgba(3,94,123,0.22) 0%, transparent 70%);
  }

  .glow-card:hover { transform: translateY(-8px); }
  .glow-card-gold:hover { border-color: rgba(255,192,0,0.3); box-shadow: 0 20px 48px rgba(255,192,0,0.07); }
  .glow-card-teal:hover { border-color: rgba(3,94,123,0.45); box-shadow: 0 20px 48px rgba(3,94,123,0.12); }

  /* Icon circle */
  .glow-card-circle {
    width: 104px;
    height: 104px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 1.75rem;
    position: relative;
    z-index: 1;
    flex-shrink: 0;
  }
  .glow-card-gold .glow-card-circle {
    background: radial-gradient(circle, rgba(255,192,0,0.18) 0%, rgba(255,192,0,0.05) 100%);
    border: 1px solid rgba(255,192,0,0.28);
    box-shadow: 0 0 28px rgba(255,192,0,0.2), 0 0 56px rgba(255,192,0,0.07);
  }
  .glow-card-teal .glow-card-circle {
    background: radial-gradient(circle, rgba(3,94,123,0.32) 0%, rgba(3,94,123,0.08) 100%);
    border: 1px solid rgba(3,94,123,0.42);
    box-shadow: 0 0 28px rgba(3,94,123,0.28), 0 0 56px rgba(3,94,123,0.09);
  }

  /* Icon color via currentColor */
  .glow-card-icon {
    width: 48px;
    height: 48px;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    z-index: 1;
  }
  .glow-card-gold .glow-card-icon { color: var(--color-accent); }
  .glow-card-teal .glow-card-icon { color: var(--color-secondary); }
  .glow-card-icon :global(svg) { width: 100%; height: 100%; }

  /* Text */
  .glow-card-title {
    font-size: 1rem;
    font-weight: 700;
    color: var(--color-text-primary);
    margin: 0 0 0.625rem;
    position: relative;
    z-index: 1;
  }
  .glow-card-body {
    font-size: 0.875rem;
    color: var(--color-text-secondary);
    line-height: 1.65;
    margin: 0;
    position: relative;
    z-index: 1;
  }
</style>
