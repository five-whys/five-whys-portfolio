---
interface Props {
  name: string;
}

const { name } = Astro.props;
---

<div style="display: flex; flex-direction: column; align-items: center; gap: 0.5rem; font-size: 0.8125rem; color: var(--color-text-secondary);">
  <div style="width: 48px; height: 48px; background: var(--color-bg-tertiary); border-radius: 12px; display: flex; align-items: center; justify-content: center; border: 1px solid var(--color-border);">
    <slot />
  </div>
  {name}
</div>
