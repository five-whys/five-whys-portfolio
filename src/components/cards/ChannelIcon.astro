---
interface Props {
  name: string;
}

const { name } = Astro.props;
---

<div class="flex flex-col items-center gap-2 text-[0.8125rem] text-text-secondary">
  <div class="w-12 h-12 bg-bg-tertiary rounded-[12px] flex items-center justify-center border border-border-theme">
    <slot />
  </div>
  {name}
</div>
