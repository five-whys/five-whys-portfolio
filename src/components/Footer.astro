---
import LinkedInIcon from '../assets/icons/social/LinkedInIcon.astro';
import XIcon from '../assets/icons/social/XIcon.astro';
import { footerLinkGroups } from '../data/navigation';
---
<footer class="bg-bg-secondary border-t border-border-theme pt-16 pb-8 transition-[background-color,border-color] duration-300">
  <div class="max-w-[1200px] mx-auto px-8">
    <div class="grid grid-cols-[1.2fr_repeat(5,1fr)] gap-8 mb-16">
      <div class="max-w-[280px]">
        <img src="/Images/logo-dark.png" alt="5.Y" class="footer-logo-img h-8 w-auto mb-4" /><img src="/Images/logo.png" alt="5.Y" class="footer-logo-img-light h-8 w-auto mb-4 hidden" />
        <p class="text-sm text-text-secondary leading-relaxed"></p>
      </div>
      {footerLinkGroups.map((group) => (
        <div>
          <h4 class="text-[0.75rem] font-semibold uppercase tracking-[0.1em] text-text-muted mb-4">{group.heading}</h4>
          <ul class="list-none flex flex-col gap-2">
            {group.links.map((link) => (
              <li><a href={link.href} class="text-[0.875rem] text-text-secondary no-underline hover:text-accent transition-colors duration-150">{link.label}</a></li>
            ))}
          </ul>
        </div>
      ))}
    </div>
    <div class="flex items-center justify-between pt-8 border-t border-border-theme flex-wrap gap-4 max-md:flex-col">
      <div class="flex items-center gap-8 flex-wrap max-md:justify-center">
        <span class="text-[0.8125rem] text-text-muted">© 2026 5.Y Holdings Pte. Ltd.</span>
        <a href="/privacy" class="text-[0.8125rem] text-text-secondary no-underline hover:text-text-primary">Privacy Policy</a>
        <a href="/terms" class="text-[0.8125rem] text-text-secondary no-underline hover:text-text-primary">Terms & Conditions</a>
      </div>
      <div class="flex gap-4">
        <a href="https://www.linkedin.com/company/five-whys" aria-label="LinkedIn" target="_blank" rel="noopener noreferrer" class="w-9 h-9 flex items-center justify-center rounded-lg bg-bg-tertiary text-text-secondary transition-all duration-150 hover:bg-accent hover:text-bg-primary">
          <LinkedInIcon class="w-[18px] h-[18px]" />
        </a>
        <a href="https://x.com/5YsAI" aria-label="X" target="_blank" rel="noopener noreferrer" class="w-9 h-9 flex items-center justify-center rounded-lg bg-bg-tertiary text-text-secondary transition-all duration-150 hover:bg-accent hover:text-bg-primary">
          <XIcon class="w-[18px] h-[18px]" />
        </a>
      </div>
    </div>
  </div>
</footer>

<style>
  [data-theme='light'] .footer-logo-img {
    display: none;
  }
  [data-theme='light'] .footer-logo-img-light {
    display: block;
  }
</style>
