---
interface VisionCard {
  title: string;
  body: string;
}

interface Props {
  label: string;
  heading: string;
  cards: VisionCard[];
}

const { label, heading, cards } = Astro.props;
---

<section id="vision" class="py-16 px-8">
  <div class="max-w-[1200px] mx-auto">
    <div class="mb-12">
      <span class="inline-block text-[0.75rem] font-semibold uppercase tracking-[0.15em] text-accent">
        {label}
      </span>
      <h2
        class="font-[family-name:var(--font-display)] text-[clamp(2rem,4vw,3rem)] font-medium tracking-[-0.02em] mt-2"
        set:html={heading}
      />
    </div>
    <div class="grid grid-cols-[repeat(auto-fit,minmax(280px,1fr))] gap-6">
      {cards.map((card) => (
        <div class="vision-card">
          <h3 class="vision-card-title">{card.title}</h3>
          <p class="vision-card-body">{card.body}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .vision-card {
    position: relative;
    overflow: hidden;
    border-radius: 20px;
    border: 1px solid var(--color-border);
    background: var(--color-bg-secondary);
    padding: 2rem;
    transition: transform 0.3s ease, border-color 0.3s ease, box-shadow 0.3s ease;
  }
  .vision-card::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 1px;
    background: linear-gradient(90deg, transparent, rgba(255,192,0,0.65), transparent);
  }
  .vision-card::after {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse 130% 55% at 50% 0%, rgba(255,192,0,0.07) 0%, transparent 65%);
    pointer-events: none;
  }
  .vision-card:hover {
    transform: translateY(-5px);
    border-color: rgba(255,192,0,0.25);
    box-shadow: 0 16px 36px rgba(255,192,0,0.05);
  }
  .vision-card > * { position: relative; z-index: 1; }
  .vision-card-title {
    font-size: 1.0625rem;
    font-weight: 700;
    color: var(--color-accent);
    margin: 0 0 0.75rem;
  }
  .vision-card-body {
    font-size: 0.9375rem;
    color: var(--color-text-secondary);
    line-height: 1.7;
    margin: 0;
  }
</style>
