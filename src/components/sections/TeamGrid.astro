---
const linkedInSVG = `<svg viewBox="0 0 24 24" fill="currentColor" width="16" height="16"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>`;

interface Member {
  imageSrc?: string;
  name: string;
  role: string;
  bio: string;
  linkedInHref?: string;
}

interface Props {
  label?: string;
  heading: string;
  subtext?: string;
  members: Member[];
}

const { label, heading, subtext, members } = Astro.props;
---

<section class="py-16 px-8 bg-bg-secondary">
  <div class="max-w-[1200px] mx-auto">
    <div class="text-center mb-12">
      {label && (
        <span class="inline-block text-[0.75rem] font-semibold tracking-[0.08em] uppercase text-accent mb-3">
          {label}
        </span>
      )}
      <h2
        class="font-[family-name:var(--font-display)] text-[clamp(1.75rem,3vw,2.5rem)] font-medium tracking-[-0.02em] mb-4"
        set:html={heading}
      />
      {subtext && (
        <p class="text-text-secondary text-[1.0625rem] max-w-[600px] mx-auto">
          {subtext}
        </p>
      )}
    </div>
    <div class="grid gap-8">
      {members.map((member) => (
        <div class="team-card bg-bg-primary border border-border-theme rounded-[20px] p-8 text-center">
          {member.imageSrc ? (
            <div class="avatar-wrap mx-auto mb-5">
              <img
                src={member.imageSrc}
                alt={member.name}
                class="founder-avatar w-24 h-24 rounded-full object-cover"
              />
            </div>
          ) : (
            <div class="avatar-wrap mx-auto mb-5">
              <div class="placeholder-avatar w-24 h-24 rounded-full flex items-center justify-center text-[2rem] font-bold text-white">
                +
              </div>
            </div>
          )}
          <h3 class="text-[1.0625rem] font-semibold text-text-primary mb-1">{member.name}</h3>
          <p class="text-[0.8125rem] font-medium text-accent mb-3">{member.role}</p>
          <p class="text-[0.875rem] text-text-secondary leading-[1.6] mb-4">{member.bio}</p>
          {member.linkedInHref && (
            <a
              href={member.linkedInHref}
              target="_blank"
              rel="noopener noreferrer"
              aria-label="LinkedIn"
              class="inline-flex w-8 h-8 items-center justify-center rounded-[8px] bg-accent-soft text-accent"
              set:html={linkedInSVG}
            />
          )}
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .grid {
    grid-template-columns: repeat(3, 1fr);
  }

  @media (max-width: 1024px) {
    .grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 640px) {
    .grid {
      grid-template-columns: 1fr;
    }
  }

  .founder-avatar {
    background: #0A0A0A;
  }

  .team-card {
    position: relative;
    overflow: hidden;
    transition: transform 220ms ease, box-shadow 220ms ease, border-color 220ms ease;
  }

  .team-card::before {
    content: '';
    position: absolute;
    inset: -30% auto auto -20%;
    width: 160px;
    height: 160px;
    background: radial-gradient(circle, color-mix(in srgb, var(--color-accent) 26%, transparent) 0%, transparent 72%);
    pointer-events: none;
    opacity: 0.85;
  }

  .team-card:hover {
    transform: translateY(-4px);
    border-color: color-mix(in srgb, var(--color-accent) 45%, var(--color-border));
    box-shadow: 0 20px 44px rgba(0, 0, 0, 0.18);
  }

  .avatar-wrap {
    width: 106px;
    height: 106px;
    border-radius: 999px;
    padding: 4px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(145deg, color-mix(in srgb, var(--color-accent) 88%, white 12%), color-mix(in srgb, var(--color-accent) 40%, transparent));
    box-shadow: 0 10px 24px color-mix(in srgb, var(--color-accent) 26%, transparent);
  }

  .placeholder-avatar {
    background: linear-gradient(145deg, #23b8ad, #1193a8);
  }

  [data-theme='light'] .founder-avatar {
    background: #FFC000;
  }

  [data-theme='light'] .team-card:hover {
    box-shadow: 0 20px 40px rgba(23, 33, 49, 0.12);
  }
</style>
