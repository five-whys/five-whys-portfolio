---
interface Testimonial {
  quote: string;
  avatarSrc: string;
  avatarAlt: string;
  name: string;
  role: string;
}

interface Props {
  testimonials: Testimonial[];
  label?: string;
  heading?: string;
  subtext?: string;
}

const {
  testimonials,
  label = 'Our Customers',
  heading = 'The results speak for themselves',
  subtext = 'GLUCOSE is trusted by leading brands across industries to transform customer engagement.',
} = Astro.props;
---

<section class="py-[6rem] px-0 bg-bg-secondary overflow-hidden">
  <div class="max-w-[1400px] mx-auto px-8">
    <div class="max-w-[700px] mb-16 text-center mx-auto">
      <span class="inline-block text-xs font-semibold uppercase tracking-[0.15em] text-accent mb-4">
        {label}
      </span>
      <h2 class="font-[family-name:var(--font-display)] text-[clamp(2rem,4vw,3rem)] font-medium leading-[1.2] tracking-[-0.02em] mb-4 text-text-primary">
        {heading}
      </h2>
      <p class="text-lg text-text-secondary leading-[1.7] max-w-[650px]">{subtext}</p>
    </div>

    <div class="testimonial-carousel" id="testimonialCarousel">
      <div class="testimonial-viewport">
        <div class="testimonial-slides">
          {testimonials.map((t, i) => (
            <div class={`testimonial-slide${i === 0 ? ' active' : ''}`}>
              <div class="testimonial-card">
                <blockquote class="testimonial-quote">
                  "{t.quote}"
                </blockquote>
                <div class="testimonial-author">
                  <img
                    class="testimonial-avatar"
                    src={t.avatarSrc}
                    alt={t.avatarAlt}
                  />
                  <div class="testimonial-info">
                    <div class="testimonial-name">{t.name}</div>
                    <div class="testimonial-role">{t.role}</div>
                  </div>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>

      <!-- Navigation -->
      <div class="testimonial-nav">
        <button class="testimonial-arrow" id="prevSlide" aria-label="Previous">
          <svg
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <polyline points="15 18 9 12 15 6"></polyline>
          </svg>
        </button>
        <div class="testimonial-dots" id="testimonialDots">
          <!-- Dots will be generated by JavaScript -->
        </div>
        <button class="testimonial-arrow" id="nextSlide" aria-label="Next">
          <svg
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <polyline points="9 18 15 12 9 6"></polyline>
          </svg>
        </button>
      </div>
    </div>
  </div>
</section>

<style>
  .testimonial-viewport {
    -webkit-mask-image: linear-gradient(to right, transparent 0%, black 6%, black 94%, transparent 100%);
    mask-image: linear-gradient(to right, transparent 0%, black 6%, black 94%, transparent 100%);
  }

  @media (max-width: 768px) {
    .testimonial-viewport {
      -webkit-mask-image: linear-gradient(to right, transparent 0%, black 4%, black 96%, transparent 100%);
      mask-image: linear-gradient(to right, transparent 0%, black 4%, black 96%, transparent 100%);
    }
  }
</style>

<script>
  // Testimonial Carousel — infinite loop with peek on both sides
  const carousel = document.getElementById('testimonialCarousel');
  if (carousel) {
    const viewport = carousel.querySelector('.testimonial-viewport') as HTMLElement;
    const slidesContainer = carousel.querySelector('.testimonial-slides') as HTMLElement;
    const originalSlides = Array.from(
      carousel.querySelectorAll('.testimonial-slide'),
    ) as HTMLElement[];
    const dotsContainer = document.getElementById('testimonialDots') as HTMLElement;
    const prevBtn = document.getElementById('prevSlide') as HTMLElement;
    const nextBtn = document.getElementById('nextSlide') as HTMLElement;
    const totalOriginal = originalSlides.length;
    let currentIndex = totalOriginal;
    let autoplayInterval: ReturnType<typeof setInterval>;
    let isTransitioning = false;

    // Clone all slides: prepend and append a full set for infinite loop
    originalSlides.forEach((s) =>
      slidesContainer.appendChild(s.cloneNode(true)),
    );
    originalSlides
      .slice()
      .reverse()
      .forEach((s) =>
        slidesContainer.insertBefore(
          s.cloneNode(true),
          slidesContainer.firstChild,
        ),
      );

    const allSlides = Array.from(
      slidesContainer.querySelectorAll('.testimonial-slide'),
    ) as HTMLElement[];

    originalSlides.forEach((_, index) => {
      const dot = document.createElement('button');
      dot.classList.add('testimonial-dot');
      if (index === 0) dot.classList.add('active');
      dot.addEventListener('click', () => goToSlide(index + totalOriginal));
      dotsContainer.appendChild(dot);
    });
    const dots = dotsContainer.querySelectorAll('.testimonial-dot');

    function getOffset(index: number) {
      const slide = allSlides[index];
      const viewportWidth = viewport.offsetWidth;
      const slideWidth = slide.offsetWidth;
      return slide.offsetLeft - (viewportWidth - slideWidth) / 2;
    }

    function updateClasses(index: number) {
      allSlides.forEach((s, i) =>
        s.classList.toggle('active', i === index),
      );
      const realIndex =
        (((index - totalOriginal) % totalOriginal) + totalOriginal) %
        totalOriginal;
      dots.forEach((d, i) => d.classList.toggle('active', i === realIndex));
    }

    function moveToSlide(index: number, animate?: boolean) {
      if (animate !== false) {
        slidesContainer.classList.remove('no-transition');
      } else {
        slidesContainer.classList.add('no-transition');
      }
      currentIndex = index;
      slidesContainer.style.transform =
        'translateX(-' + getOffset(index) + 'px)';
      updateClasses(index);
    }

    // After transition ends, silently jump if we're in a cloned region
    slidesContainer.addEventListener('transitionend', () => {
      isTransitioning = false;
      if (currentIndex < totalOriginal) {
        moveToSlide(currentIndex + totalOriginal, false);
      } else if (currentIndex >= totalOriginal * 2) {
        moveToSlide(currentIndex - totalOriginal, false);
      }
    });

    function goToSlide(index: number) {
      if (isTransitioning) return;
      isTransitioning = true;
      moveToSlide(index);
      resetAutoplay();
    }

    function next() {
      goToSlide(currentIndex + 1);
    }

    function prev() {
      goToSlide(currentIndex - 1);
    }

    function startAutoplay() {
      autoplayInterval = setInterval(next, 6000);
    }

    function resetAutoplay() {
      clearInterval(autoplayInterval);
      startAutoplay();
    }

    prevBtn.addEventListener('click', prev);
    nextBtn.addEventListener('click', next);

    carousel.addEventListener('mouseenter', () =>
      clearInterval(autoplayInterval),
    );
    carousel.addEventListener('mouseleave', startAutoplay);

    // Touch/swipe support
    let touchStartX = 0;
    let touchEndX = 0;
    carousel.addEventListener(
      'touchstart',
      (e) => {
        touchStartX = (e as TouchEvent).changedTouches[0].screenX;
      },
      { passive: true },
    );
    carousel.addEventListener('touchend', (e) => {
      touchEndX = (e as TouchEvent).changedTouches[0].screenX;
      const diff = touchStartX - touchEndX;
      if (Math.abs(diff) > 50) {
        diff > 0 ? next() : prev();
      }
    });

    // Initial position (no animation) and recalc on resize
    moveToSlide(totalOriginal, false);
    window.addEventListener('resize', () =>
      moveToSlide(currentIndex, false),
    );

    startAutoplay();
  }
</script>
