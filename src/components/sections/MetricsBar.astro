---
interface Metric {
  value: string;
  label: string;
}

interface Props {
  metrics: Metric[];
}

const { metrics } = Astro.props;
---
<section class="bg-bg-tertiary border-y border-border-theme py-6 px-8">
  <div class="max-w-[1200px] mx-auto flex items-center justify-center gap-12 flex-wrap">
    {metrics.map((m) => (
      <div class="flex items-center gap-3">
        <span class="font-[family-name:var(--font-display)] text-[1.75rem] text-accent leading-none">{m.value}</span>
        <span class="text-[0.8125rem] text-text-secondary leading-[1.3] max-w-[140px]">{m.label}</span>
      </div>
    ))}
  </div>
</section>
