---
import { ChevronDown } from 'lucide-astro';

interface Value {
  title: string;
  body: string;
  iconSVG: string;
}

interface Props {
  values: Value[];
}

const { values } = Astro.props;
---

<section class="py-16 px-8">
  <div class="max-w-[800px] mx-auto">
    <div id="values-accordion" class="border border-border-theme rounded-[16px] overflow-hidden">
      {values.map((value, index) => (
        <div class={`value-item${index < values.length - 1 ? ' border-b border-border-theme' : ''}`}>
          <button
            class="value-header w-full flex items-center justify-between p-6 bg-transparent border-none cursor-pointer text-left"
            aria-expanded={index === 0 ? 'true' : 'false'}
          >
            <div class="flex items-center gap-4">
              <div class="w-10 h-10 rounded-[10px] bg-accent-soft flex items-center justify-center text-accent shrink-0 [&_svg]:w-5 [&_svg]:h-5" set:html={value.iconSVG} />
              <span class="text-[1.0625rem] font-semibold text-text-primary">{value.title}</span>
            </div>
            <ChevronDown
              class="chevron shrink-0 text-text-muted transition-transform duration-300"
              size={20}
            />
          </button>
          <div
            class="value-content overflow-hidden transition-[max-height,padding] duration-300 ease-in-out"
            style={index === 0 ? '' : 'max-height: 0; padding: 0;'}
          >
            <p class="text-text-secondary leading-[1.7] px-6 pb-6 pl-[4.5rem]">{value.body}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<script>
  const accordion = document.querySelector('#values-accordion');

  if (accordion instanceof HTMLElement) {
    const items = Array.from(accordion.querySelectorAll('.value-item')) as HTMLElement[];

    const closeAllItems = () => {
      items.forEach((item) => {
        const button = item.querySelector('.value-header') as HTMLButtonElement | null;
        const content = item.querySelector('.value-content') as HTMLElement | null;
        const chevron = item.querySelector('.chevron') as SVGElement | null;

        if (!button || !content) return;

        button.setAttribute('aria-expanded', 'false');
        content.style.maxHeight = '0px';
        content.style.paddingTop = '0px';
        content.style.paddingBottom = '0px';
        if (chevron) chevron.style.transform = 'rotate(0deg)';
      });
    };

    const openItem = (item: HTMLElement) => {
      const button = item.querySelector('.value-header') as HTMLButtonElement | null;
      const content = item.querySelector('.value-content') as HTMLElement | null;
      const chevron = item.querySelector('.chevron') as SVGElement | null;

      if (!button || !content) return;

      button.setAttribute('aria-expanded', 'true');
      content.style.paddingTop = '0px';
      content.style.paddingBottom = '24px';
      content.style.maxHeight = content.scrollHeight + 'px';
      if (chevron) chevron.style.transform = 'rotate(180deg)';
    };

    items.forEach((item) => {
      const button = item.querySelector('.value-header') as HTMLButtonElement | null;
      if (!button) return;

      button.addEventListener('click', () => {
        const isOpen = button.getAttribute('aria-expanded') === 'true';
        closeAllItems();
        if (!isOpen) openItem(item);
      });
    });

    const firstItem = items[0];
    if (firstItem) {
      closeAllItems();
      openItem(firstItem);
    }
  }
</script>
